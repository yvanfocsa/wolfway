---
// src/components/AudienceSelector.astro
---

<section class="bg-white border-b border-slate-200/60 py-16 sm:py-20 relative z-20 select-none">
  <div class="mx-auto max-w-7xl px-5 lg:px-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-0 divide-y md:divide-y-0 md:divide-x divide-slate-200/80">
      
      <!-- Panel 1: Shippers -->
      <a href="/request-a-quote" class="group flex flex-col justify-between pb-8 md:pb-0 md:px-8 md:first:pl-0 focus-visible:outline focus-visible:outline-3 focus-visible:outline-cyan/70 rounded-sm">
        <div>
          <p class="font-heading text-xs font-bold uppercase tracking-[0.25em] text-[#005F8A] mb-3">
            SHIPPERS
          </p>
          <h3 class="font-heading text-2xl font-extrabold uppercase text-ink leading-tight mb-2.5">
            Move your freight.
          </h3>
          <p class="text-sm text-slate-600 font-body font-light leading-relaxed mb-6">
            Get a competitive freight quote for your next open-deck load.
          </p>
        </div>
        <span class="inline-flex items-center text-xs font-bold uppercase tracking-widest text-[#005F8A] group-hover:text-cyan transition-colors font-body">
          REQUEST A QUOTE
          <svg class="ml-2 h-3.5 w-3.5 transition-transform duration-180 ease-out group-hover:translate-x-1.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>

      <!-- Panel 2: Carrier Partners -->
      <a href="/carrier" class="group flex flex-col justify-between py-8 md:py-0 md:px-8 focus-visible:outline focus-visible:outline-3 focus-visible:outline-cyan/70 rounded-sm">
        <div>
          <p class="font-heading text-xs font-bold uppercase tracking-[0.25em] text-[#005F8A] mb-3">
            CARRIER PARTNERS
          </p>
          <h3 class="font-heading text-2xl font-extrabold uppercase text-ink leading-tight mb-2.5">
            Keep your trucks moving.
          </h3>
          <p class="text-sm text-slate-600 font-body font-light leading-relaxed mb-6">
            Apply to join the WolfWay carrier network for steady loads.
          </p>
        </div>
        <span class="inline-flex items-center text-xs font-bold uppercase tracking-widest text-[#005F8A] group-hover:text-cyan transition-colors font-body">
          BECOME A CARRIER
          <svg class="ml-2 h-3.5 w-3.5 transition-transform duration-180 ease-out group-hover:translate-x-1.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>

      <!-- Panel 3: Drivers -->
      <a href="/drive-with-us" class="group flex flex-col justify-between pt-8 md:pt-0 md:px-8 md:last:pr-0 focus-visible:outline focus-visible:outline-3 focus-visible:outline-cyan/70 rounded-sm">
        <div>
          <p class="font-heading text-xs font-bold uppercase tracking-[0.25em] text-[#005F8A] mb-3">
            DRIVERS
          </p>
          <h3 class="font-heading text-2xl font-extrabold uppercase text-ink leading-tight mb-2.5">
            Drive with purpose.
          </h3>
          <p class="text-sm text-slate-600 font-body font-light leading-relaxed mb-6">
            Opportunities and steady OTR / Owner Operator lanes.
          </p>
        </div>
        <span class="inline-flex items-center text-xs font-bold uppercase tracking-widest text-[#005F8A] group-hover:text-cyan transition-colors font-body">
          EXPLORE OPPORTUNITIES
          <svg class="ml-2 h-3.5 w-3.5 transition-transform duration-180 ease-out group-hover:translate-x-1.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>

    </div>
  </div>
</section>
