---
import Button from './Button.astro';

export interface Props {
  eyebrow?: string;
  heading: string;
  description: string;
  buttonText: string;
  buttonHref: string;
  variant?: 'dark' | 'light';
}

const {
  eyebrow,
  heading,
  description,
  buttonText,
  buttonHref,
  variant = 'dark',
} = Astro.props;

const isDark = variant === 'dark';
---

<section
  class:list={[
    'relative overflow-hidden py-16 sm:py-20 lg:py-24',
    isDark ? 'bg-navy' : 'bg-offwhite',
  ]}
>
  <div class="absolute left-0 top-0 h-1 w-full bg-cyan" aria-hidden="true"></div>
  <div class="mx-auto max-w-7xl px-5 lg:px-10 text-center">
    {eyebrow && (
      <p
        class:list={[
          'readable-kicker mb-3',
          isDark ? 'text-cyan' : 'text-cyan-dark',
        ]}
      >
        {eyebrow}
      </p>
    )}
    <h2
      class:list={[
        'font-heading text-3xl sm:text-4xl lg:text-5xl font-extrabold uppercase leading-none',
        isDark ? 'text-white' : 'text-ink',
      ]}
    >
      {heading}
    </h2>
    <p
      class:list={[
        'mt-4 sm:mt-5 mx-auto max-w-2xl text-base sm:text-lg leading-relaxed',
        isDark ? 'text-slate-300' : 'text-slate-600',
      ]}
    >
      {description}
    </p>
    <div class="mt-6 sm:mt-8">
      <Button
        variant={isDark ? 'primary' : 'primary'}
        href={buttonHref}
        size="lg"
        arrow={true}
        class="group font-heading font-extrabold"
      >
        {buttonText}
      </Button>
    </div>
  </div>
</section>
