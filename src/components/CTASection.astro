---
import Button from './Button.astro';

export interface Props {
  eyebrow?: string;
  heading: string;
  description: string;
  buttonText: string;
  buttonHref: string;
  variant?: 'dark' | 'light';
}

const {
  eyebrow,
  heading,
  description,
  buttonText,
  buttonHref,
  variant = 'dark',
} = Astro.props;

const isDark = variant === 'dark';
---

<section
  class:list={[
    'py-14 sm:py-20 lg:py-28',
    isDark ? 'bg-navy' : 'bg-offwhite',
  ]}
  data-animate="fade-up"
>
  <div class="mx-auto max-w-7xl px-5 lg:px-10 text-center">
    {eyebrow && (
      <p
        class:list={[
          'readable-kicker mb-3',
          isDark ? 'text-cyan' : 'text-[#005F8A]',
        ]}
      >
        {eyebrow}
      </p>
    )}
    <h2
      class:list={[
        'font-heading text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold uppercase',
        isDark ? 'text-white' : 'text-ink',
      ]}
    >
      {heading}
    </h2>
    <p
      class:list={[
        'mt-3 sm:mt-4 mx-auto max-w-2xl text-sm sm:text-base leading-relaxed',
        isDark ? 'text-white/60' : 'text-steel',
      ]}
    >
      {description}
    </p>
    <div class="mt-6 sm:mt-8">
      <Button
        variant={isDark ? 'primary' : 'primary'}
        href={buttonHref}
        size="lg"
        arrow={true}
        class="group"
      >
        {buttonText}
      </Button>
    </div>
  </div>
</section>
