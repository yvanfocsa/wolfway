---
const items = [
  {
    title: 'Carrier Safety Review',
    body: 'FMCSA safety status, insurance coverage, equipment fit, and securement readiness are reviewed before a load is assigned.',
    stat: 'FMCSA',
    label: 'Safety focus',
  },
  {
    title: 'Cargo Protection Plan',
    body: 'Cargo dimensions, weight, tarping needs, and access constraints are checked early so the right open-deck setup arrives prepared.',
    stat: '$250K',
    label: 'Cargo coverage',
  },
  {
    title: 'Privacy-First Quote Flow',
    body: 'Quote forms ask for load details only. Sensitive driver onboarding data is handled later through direct, controlled coordination.',
    stat: 'No SSN',
    label: 'Public forms',
  },
  {
    title: 'Human Dispatch Chain',
    body: 'A real coordinator keeps shippers and drivers aligned with pickup windows, route changes, delivery updates, and recovery plans.',
    stat: '24/7',
    label: 'Dispatch support',
  },
];
---

<section class="bg-white py-16 sm:py-20 lg:py-24 border-y border-slate-100">
  <div class="mx-auto max-w-7xl px-5 lg:px-10">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
      <div>
        <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-extrabold uppercase leading-none text-ink">
          Built for clean handoffs and protected freight
        </h2>
      </div>
      <p class="mobile-readable max-w-2xl text-base leading-relaxed text-slate-600 font-body font-normal">
        Modern logistics is not louder. It is clearer: fewer surprises, better data discipline, tighter coordination, and a visible plan from pickup to delivery.
      </p>
    </div>

    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {items.map((item) => (
        <article class="border-t border-slate-300 pt-6">
          <div class="flex items-baseline gap-3">
            <p class="font-heading text-2xl font-extrabold uppercase leading-none text-cyan-dark">{item.stat}</p>
            <p class="text-sm font-bold uppercase tracking-wider text-slate-500">{item.label}</p>
          </div>
          <h3 class="mt-6 font-heading text-xl font-bold uppercase leading-tight text-ink">{item.title}</h3>
          <p class="mobile-readable mt-3 text-base leading-relaxed text-slate-600 font-body font-normal">{item.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
