---
// src/components/DriverAppModal.astro
---

<!-- Full Driver Application Modal Backdrop & Container -->
<div
  id="driver-app-modal"
  class="fixed inset-0 z-[9999] bg-slate-950/75 backdrop-blur-md flex items-center justify-center p-4 sm:p-6 opacity-0 pointer-events-none transition-all duration-300 ease-out select-none overflow-y-auto"
  aria-hidden="true"
>
  <div
    id="modal-content-card"
    class="relative w-full max-w-3xl bg-white rounded-2xl shadow-2xl overflow-hidden my-8 border border-slate-200/80 transform scale-95 opacity-0 translate-y-4 transition-all duration-300 ease-out"
  >
    <!-- Header Bar -->
    <div class="bg-navy px-6 py-5 flex items-center justify-between text-white border-b border-white/10">
      <div>
        <p class="font-heading text-xs font-bold uppercase tracking-[0.2em] text-cyan">DOT EMPLOYMENT APPLICATION</p>
        <h3 class="font-heading text-lg font-extrabold uppercase text-white">WolfWay CDL-A Driver Application</h3>
      </div>
      <button
        id="close-driver-modal"
        class="h-9 w-9 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white/80 hover:text-white transition-colors"
        aria-label="Close application"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Progress Indicator -->
    <div class="bg-slate-50 border-b border-slate-200/80 px-6 py-3">
      <div class="flex items-center justify-between text-xs font-heading font-bold uppercase tracking-wider text-slate-500 mb-2">
        <span id="step-indicator-text">Step 1 of 3: Personal &amp; Contact Information</span>
        <span id="step-percentage-text" class="text-cyan">0% Completed</span>
      </div>
      <div class="w-full bg-slate-200 h-2 rounded-full overflow-hidden">
        <div id="step-progress-bar" class="bg-cyan h-full w-0 transition-all duration-300"></div>
      </div>
    </div>

    <!-- Application Form Container -->
    <form id="full-driver-form" class="p-6 sm:p-8 space-y-6" novalidate>
      <input type="hidden" name="formType" value="full_driver_app" />

      <!-- STEP 1: PERSONAL & CONTACT -->
      <div id="modal-step-1" class="space-y-5">
        <div class="p-4 bg-cyan/5 border border-cyan/20 rounded-xl mb-4 text-xs text-slate-700 font-body leading-relaxed">
          <strong class="font-bold text-navy block font-heading uppercase text-xs mb-0.5">FMCSA DOT Compliance Notice:</strong>
          In compliance with Federal &amp; State equal opportunity laws, qualified CDL applicants are considered without regard to race, color, or protected status.
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1.5 font-body">First Name <span class="text-cyan">*</span></label>
            <input type="text" name="first_name" required autocomplete="given-name" placeholder="John" class="w-full border border-slate-200 px-4 py-3 rounded-lg text-sm outline-none focus:border-cyan focus:ring-2 focus:ring-cyan/20 font-body" />
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1.5 font-body">Last Name <span class="text-cyan">*</span></label>
            <input type="text" name="last_name" required autocomplete="family-name" placeholder="Doe" class="w-full border border-slate-200 px-4 py-3 rounded-lg text-sm outline-none focus:border-cyan focus:ring-2 focus:ring-cyan/20 font-body" />
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1.5 font-body">Age Eligibility <span class="text-cyan">*</span></label>
            <select name="age_eligibility" required class="w-full border border-slate-200 px-4 py-3 rounded-lg text-sm outline-none focus:border-cyan focus:ring-2 focus:ring-cyan/20 font-body bg-white">
              <option value="">Select eligibility</option>
              <option value="22_or_older">I am 22 or older</option>
              <option value="under_22">I am under 22</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1.5 font-body">Preferred Contact <span class="text-cyan">*</span></label>
            <select name="preferred_contact" required class="w-full border border-slate-200 px-4 py-3 rounded-lg text-sm outline-none focus:border-cyan focus:ring-2 focus:ring-cyan/20 font-body bg-white">
              <option value="">Select method</option>
              <option value="Phone">Phone</option>
              <option value="Text">Text</option>
              <option value="Email">Email</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1.5 font-body">Primary Phone <span class="text-cyan">*</span></label>
            <input type="tel" name="phone" required autocomplete="tel" placeholder="(555) 123-4567" class="w-full border border-slate-200 px-4 py-3 rounded-lg text-sm outline-none focus:border-cyan focus:ring-2 focus:ring-cyan/20 font-body" />
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1.5 font-body">Email Address <span class="text-cyan">*</span></label>
            <input type="email" name="email" required autocomplete="email" placeholder="john@email.com" class="w-full border border-slate-200 px-4 py-3 rounded-lg text-sm outline-none focus:border-cyan focus:ring-2 focus:ring-cyan/20 font-body" />
          </div>
        </div>

        <p class="rounded-lg border border-cyan/20 bg-cyan/5 p-4 text-sm leading-relaxed text-slate-700">
          For privacy, this public form does not collect SSN, full date of birth, or full CDL number. Those details are handled later through direct onboarding.
        </p>


      </div>

      <!-- STEP 2: ADDRESS & RESIDENCE HISTORY -->
      <div id="modal-step-2" class="space-y-5 hidden">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="sm:col-span-2">
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1.5 font-body">Current Street Address <span class="text-cyan">*</span></label>
            <input type="text" name="address_line1" required autocomplete="street-address" placeholder="123 Main Street, Apt 4B" class="w-full border border-slate-200 px-4 py-3 rounded-lg text-sm outline-none focus:border-cyan focus:ring-2 focus:ring-cyan/20 font-body" />
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1.5 font-body">City &amp; State <span class="text-cyan">*</span></label>
            <input type="text" name="city_state" required placeholder="Chicago, IL" class="w-full border border-slate-200 px-4 py-3 rounded-lg text-sm outline-none focus:border-cyan focus:ring-2 focus:ring-cyan/20 font-body" />
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1.5 font-body">Zip Code <span class="text-cyan">*</span></label>
            <input type="text" name="zip" required autocomplete="postal-code" placeholder="60601" class="w-full border border-slate-200 px-4 py-3 rounded-lg text-sm outline-none focus:border-cyan focus:ring-2 focus:ring-cyan/20 font-body" />
          </div>
        </div>

        <div>
          <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">Have you lived at this address for 3 or more years? <span class="text-cyan">*</span></label>
          <div class="flex gap-6">
            <label class="flex items-center gap-2 text-sm text-ink cursor-pointer font-body">
              <input type="radio" name="residence_3yrs" value="Yes" checked class="accent-cyan h-4 w-4" /> Yes
            </label>
            <label class="flex items-center gap-2 text-sm text-ink cursor-pointer font-body">
              <input type="radio" name="residence_3yrs" value="No" class="accent-cyan h-4 w-4" /> No
            </label>
          </div>
        </div>
      </div>

      <!-- STEP 3: CDL & DRIVING HISTORY -->
      <div id="modal-step-3" class="space-y-5 hidden">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1.5 font-body">CDL-A License Status <span class="text-cyan">*</span></label>
            <select name="cdl_status" required class="w-full border border-slate-200 px-4 py-3 rounded-lg text-sm outline-none focus:border-cyan focus:ring-2 focus:ring-cyan/20 font-body bg-white">
              <option value="">Select status</option>
              <option value="Active CDL-A">Active CDL-A</option>
              <option value="CDL-A permit">CDL-A permit</option>
              <option value="Not currently licensed">Not currently licensed</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1.5 font-body">State of Issue <span class="text-cyan">*</span></label>
            <input type="text" name="cdl_state" required placeholder="IL" class="w-full border border-slate-200 px-4 py-3 rounded-lg text-sm outline-none focus:border-cyan focus:ring-2 focus:ring-cyan/20 font-body" />
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1.5 font-body">Verifiable OTR Experience <span class="text-cyan">*</span></label>
            <select name="experience" required class="w-full border border-slate-200 px-4 py-3 rounded-lg text-sm outline-none focus:border-cyan focus:ring-2 focus:ring-cyan/20 font-body bg-white">
              <option value="1-3 years">1 to 3 years</option>
              <option value="3-5 years">3 to 5 years</option>
              <option value="5+ years">5+ years</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1.5 font-body">Traffic Accidents / Violations (Past 3 Yrs)</label>
            <select name="mvr_clean" class="w-full border border-slate-200 px-4 py-3 rounded-lg text-sm outline-none focus:border-cyan focus:ring-2 focus:ring-cyan/20 font-body bg-white">
              <option value="Clean MVR Record">Clean MVR Record (0 violations)</option>
              <option value="1 minor violation">1 minor violation</option>
              <option value="2+ violations">2+ violations</option>
            </select>
          </div>
        </div>
      </div>

      <!-- SUCCESS CONFIRMATION CARD (Hidden initially) -->
      <div id="modal-success-card" class="p-8 bg-green-50 border border-green-200 rounded-xl text-center space-y-3 hidden">
        <div class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-green-500 text-white mx-auto">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h4 class="font-heading text-xl font-bold uppercase text-green-900">Application Submitted!</h4>
        <p class="text-sm text-green-700 font-body leading-relaxed max-w-md mx-auto">
          Thank you for applying to WolfWay Logistics LLC. A recruitment coordinator will review your CDL record and call or text you within 24 hours.
        </p>
      </div>

      <!-- Navigation Footer Controls -->
      <div id="modal-footer-controls" class="pt-4 border-t border-slate-100 flex items-center justify-between">
        <button
          type="button"
          id="modal-btn-prev"
          class="px-5 py-2.5 rounded-lg border border-slate-200 text-slate-600 font-heading text-xs font-bold uppercase hover:bg-slate-50 transition-colors opacity-50 cursor-not-allowed"
          disabled
        >
          &larr; Back
        </button>

        <button
          type="button"
          id="modal-btn-next"
          class="px-6 py-2.5 rounded-lg bg-cyan text-navy font-heading text-xs font-bold uppercase hover:bg-[#00D4E0] transition-colors shadow-xs"
        >
          Next Step &rarr;
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  import { initAntiSpam, validateAntiSpam, recordSubmission } from '@/scripts/anti-spam';

  let currentStep = 1;
  const maxSteps = 3;

  function initDriverModal() {
    const modal = document.getElementById('driver-app-modal');
    const closeBtn = document.getElementById('close-driver-modal');
    const prevBtn = document.getElementById('modal-btn-prev') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('modal-btn-next') as HTMLButtonElement | null;
    const form = document.getElementById('full-driver-form') as HTMLFormElement | null;
    const footerControls = document.getElementById('modal-footer-controls');
    const successCard = document.getElementById('modal-success-card');

    const modalCard = document.getElementById('modal-content-card');

    if (!modal || !closeBtn || !prevBtn || !nextBtn || !form) return;

    // Initialize anti-spam protections
    initAntiSpam(form);

    // Global triggers for opening modal
    document.querySelectorAll('[data-trigger-driver-modal]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        openModal();
      });
    });

    closeBtn.addEventListener('click', closeModal);

    // Backdrop click close
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    // ESC key close
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('pointer-events-none')) {
        closeModal();
      }
    });

    function openModal() {
      // Calculate scrollbar width to prevent horizontal layout shift
      const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
      if (scrollbarWidth > 0) {
        document.body.style.paddingRight = `${scrollbarWidth}px`;
      }
      document.body.style.overflow = 'hidden';

      modal?.classList.remove('opacity-0', 'pointer-events-none');
      modal?.classList.add('opacity-100', 'pointer-events-auto');

      setTimeout(() => {
        modalCard?.classList.remove('scale-95', 'opacity-0', 'translate-y-4');
        modalCard?.classList.add('scale-100', 'opacity-100', 'translate-y-0');
      }, 20);
    }

    function closeModal() {
      modalCard?.classList.add('scale-95', 'opacity-0', 'translate-y-4');
      modalCard?.classList.remove('scale-100', 'opacity-100', 'translate-y-0');

      setTimeout(() => {
        modal?.classList.add('opacity-0', 'pointer-events-none');
        modal?.classList.remove('opacity-100', 'pointer-events-auto');
        document.body.style.overflow = '';
        document.body.style.paddingRight = '';
      }, 200);
    }

    function updateStepUI() {
      document.getElementById('modal-step-1')?.classList.toggle('hidden', currentStep !== 1);
      document.getElementById('modal-step-2')?.classList.toggle('hidden', currentStep !== 2);
      document.getElementById('modal-step-3')?.classList.toggle('hidden', currentStep !== 3);

      const stepText = document.getElementById('step-indicator-text');
      const stepPct = document.getElementById('step-percentage-text');
      const bar = document.getElementById('step-progress-bar');

      if (currentStep === 1) {
        if (stepText) stepText.textContent = 'Step 1 of 3: Personal & Contact Information';
        if (stepPct) stepPct.textContent = '0% Completed';
        if (bar) bar.style.width = '0%';
        prevBtn!.disabled = true;
        prevBtn!.classList.add('opacity-50', 'cursor-not-allowed');
        nextBtn!.textContent = 'Next Step \u2192';
      } else if (currentStep === 2) {
        if (stepText) stepText.textContent = 'Step 2 of 3: Address & Residence History';
        if (stepPct) stepPct.textContent = '33% Completed';
        if (bar) bar.style.width = '33%';
        prevBtn!.disabled = false;
        prevBtn!.classList.remove('opacity-50', 'cursor-not-allowed');
        nextBtn!.textContent = 'Next Step \u2192';
      } else if (currentStep === 3) {
        if (stepText) stepText.textContent = 'Step 3 of 3: CDL License & Driving History';
        if (stepPct) stepPct.textContent = '66% Completed';
        if (bar) bar.style.width = '66%';
        prevBtn!.disabled = false;
        prevBtn!.classList.remove('opacity-50', 'cursor-not-allowed');
        nextBtn!.textContent = 'Submit Official Application';
      }
    }

    nextBtn.addEventListener('click', () => {
      if (currentStep < maxSteps) {
        currentStep++;
        updateStepUI();
      } else {
        // Anti-spam validation before final submission
        const spamCheck = validateAntiSpam(form!);
        if (!spamCheck.valid) {
          return; // Silently block spam
        }

        // Record submission for rate limiting
        recordSubmission();

        // Submit
        document.getElementById('modal-step-1')?.classList.add('hidden');
        document.getElementById('modal-step-2')?.classList.add('hidden');
        document.getElementById('modal-step-3')?.classList.add('hidden');
        if (footerControls) footerControls.classList.add('hidden');
        if (successCard) successCard.classList.remove('hidden');
      }
    });

    prevBtn.addEventListener('click', () => {
      if (currentStep > 1) {
        currentStep--;
        updateStepUI();
      }
    });
  }

  initDriverModal();
  document.addEventListener('astro:page-load', initDriverModal);
</script>
