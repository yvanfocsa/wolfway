---
import Button from './Button.astro';

const experienceLevels = [
  'Less than 1 year',
  '1–3 years',
  '3–5 years',
  '5–10 years',
  '10+ years',
];
---

<form id="driver-form" class="space-y-6" novalidate>
  <input type="hidden" name="formType" value="driver" />
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <!-- Name -->
    <div>
      <label for="driver-name" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-2">
        Full Name <span class="text-cyan">*</span>
      </label>
      <input
        type="text"
        id="driver-name"
        name="name"
        required
        autocomplete="name"
        class="w-full border border-slate-200 bg-slate-50/50 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300"
        placeholder="John Doe"
      />
      <p class="form-error mt-1.5 text-xs text-red-500 hidden">Please enter your name.</p>
    </div>

    <!-- Phone -->
    <div>
      <label for="driver-phone" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-2">
        Phone <span class="text-cyan">*</span>
      </label>
      <input
        type="tel"
        id="driver-phone"
        name="phone"
        required
        autocomplete="tel"
        class="w-full border border-slate-200 bg-slate-50/50 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300"
        placeholder="(555) 123-4567"
      />
      <p class="form-error mt-1.5 text-xs text-red-500 hidden">Please enter a valid phone number.</p>
    </div>

    <!-- Email -->
    <div>
      <label for="driver-email" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-2">
        Email <span class="text-cyan">*</span>
      </label>
      <input
        type="email"
        id="driver-email"
        name="email"
        required
        autocomplete="email"
        class="w-full border border-slate-200 bg-slate-50/50 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300"
        placeholder="john@email.com"
      />
      <p class="form-error mt-1.5 text-xs text-red-500 hidden">Please enter a valid email address.</p>
    </div>

    <!-- City / State -->
    <div>
      <label for="driver-location" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-2">
        City / State <span class="text-cyan">*</span>
      </label>
      <input
        type="text"
        id="driver-location"
        name="location"
        required
        class="w-full border border-slate-200 bg-slate-50/50 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300"
        placeholder="Chicago, IL"
      />
      <p class="form-error mt-1.5 text-xs text-red-500 hidden">Please enter your city and state.</p>
    </div>
  </div>

  <!-- Applying As (Styled as modern select cards) -->
  <fieldset class="space-y-3">
    <legend class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-2">
      Applying As <span class="text-cyan">*</span>
    </legend>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <label class="relative flex items-center p-4 border border-slate-200 rounded-sm cursor-pointer transition-all hover:bg-slate-50 bg-slate-50/20 select-none group">
        <input
          type="radio"
          name="applying_as"
          value="OTR Driver"
          required
          class="h-4 w-4 text-cyan border-slate-300 focus:ring-cyan mr-3"
        />
        <div>
          <span class="text-sm font-semibold text-ink block">OTR Driver</span>
          <span class="text-xs text-slate-600 block mt-0.5">Over-the-road long haul</span>
        </div>
      </label>
      <label class="relative flex items-center p-4 border border-slate-200 rounded-sm cursor-pointer transition-all hover:bg-slate-50 bg-slate-50/20 select-none group">
        <input
          type="radio"
          name="applying_as"
          value="Owner Operator"
          class="h-4 w-4 text-cyan border-slate-300 focus:ring-cyan mr-3"
        />
        <div>
          <span class="text-sm font-semibold text-ink block">Owner Operator</span>
          <span class="text-xs text-slate-600 block mt-0.5">Haul with your own truck</span>
        </div>
      </label>
    </div>
    <p class="form-error mt-1.5 text-xs text-red-500 hidden">Please select an option.</p>
  </fieldset>

  <!-- CDL Experience -->
  <div>
    <label for="driver-experience" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-2">
      CDL Experience <span class="text-cyan">*</span>
    </label>
    <div class="relative">
      <select
        id="driver-experience"
        name="cdl_experience"
        required
        class="w-full border border-slate-200 bg-slate-50/50 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 appearance-none cursor-pointer"
      >
        <option value="" disabled selected>Select experience</option>
        {experienceLevels.map((level) => (
          <option value={level}>{level}</option>
        ))}
      </select>
      <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-4 text-slate-400">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </div>
    </div>
    <p class="form-error mt-1.5 text-xs text-red-500 hidden">Please select your experience level.</p>
  </div>

  <!-- Message -->
  <div>
    <label for="driver-message" class="block text-xs font-semibold uppercase tracking-wider text-slate-500 mb-2">
      Message
    </label>
    <textarea
      id="driver-message"
      name="message"
      rows="4"
      class="w-full border border-slate-200 bg-slate-50/50 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 resize-y"
      placeholder="Tell us about your experience, equipment, or availability..."
    ></textarea>
  </div>

  <!-- Submit -->
  <div class="pt-2">
    <Button
      type="submit"
      variant="primary"
      size="default"
      arrow={true}
      class="group w-full sm:w-auto"
    >
      Submit Application
    </Button>
  </div>

  <!-- Success -->
  <div id="driver-success" class="hidden p-5 border border-green-500/20 bg-green-500/5 rounded-sm">
    <p class="text-sm font-medium text-green-700 font-body">
      Thank you for your interest! We'll review your application and get back to you shortly.
    </p>
  </div>

  <!-- Error -->
  <div id="driver-error" class="hidden p-5 border border-red-500/20 bg-red-500/5 rounded-sm">
    <p class="text-sm font-medium text-red-600 font-body">
      Please fix the highlighted fields and try again.
    </p>
  </div>
</form>

<script>
  import { validateForm } from '@/scripts/forms';
  const form = document.getElementById('driver-form') as HTMLFormElement | null;
  if (form) validateForm(form, 'driver-success', 'driver-error');
</script>
