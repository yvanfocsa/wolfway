---
// src/components/DriverForm.astro
---

<div class="space-y-8">
  <div
    id="page-driver-progress"
    class="driver-progress"
    role="progressbar"
    aria-label="Application progress"
    aria-valuemin="0"
    aria-valuemax="100"
    aria-valuenow="33"
  >
    <div class="flex flex-wrap items-center justify-between gap-2">
      <span id="page-driver-step-title" class="text-base font-bold text-navy">Step 1 of 3: Your details</span>
      <span id="page-driver-step-pct" class="text-base font-bold text-cyan-dark">33% complete</span>
    </div>
    <ol class="mt-5 grid grid-cols-3 gap-2" aria-label="Application steps">
      <li id="page-driver-progress-step-1" class="driver-progress-step" data-state="current">
        <span class="driver-progress-number">1</span>
        <span>About you</span>
      </li>
      <li id="page-driver-progress-step-2" class="driver-progress-step" data-state="upcoming">
        <span class="driver-progress-number">2</span>
        <span>Address</span>
      </li>
      <li id="page-driver-progress-step-3" class="driver-progress-step" data-state="upcoming">
        <span class="driver-progress-number">3</span>
        <span>CDL history</span>
      </li>
    </ol>
    <div class="mt-4 h-1.5 overflow-hidden rounded-full bg-slate-200" aria-hidden="true">
      <div id="page-driver-progress-bar" class="h-full bg-cyan transition-[width] duration-300 ease-out" style="width: 33%"></div>
    </div>
  </div>

  <form id="driver-form" class="site-form min-h-[500px] space-y-7" novalidate>
    <input type="hidden" name="formType" value="full_driver_app" />

    <div id="driver-success" class="hidden rounded-lg bg-emerald-50 p-8 text-center" role="status" aria-live="polite">
      <div class="flex flex-col items-center justify-center gap-4">
        <div class="flex h-14 w-14 items-center justify-center rounded-full bg-emerald-600 text-white">
          <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h4 class="font-heading text-3xl font-extrabold uppercase text-navy">Application submitted</h4>
        <p class="max-w-lg text-base leading-relaxed text-slate-700">
          Thank you for applying to <strong class="font-semibold text-navy">WolfWay Logistics LLC</strong>. A recruiter will review your information and contact you within 24 hours.
        </p>
      </div>
    </div>

    <div id="driver-error" class="hidden rounded-md bg-red-50 p-4 text-red-800" role="alert" aria-live="assertive" tabindex="-1">
      <p class="font-semibold">Check the highlighted fields before continuing.</p>
    </div>

    <fieldset id="page-step-1" class="space-y-7">
      <legend class="sr-only">Personal and contact information</legend>
      <div class="form-notice flex items-start gap-3 p-4">
        <svg class="mt-0.5 h-5 w-5 shrink-0 text-cyan-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
        </svg>
        <p>
          <strong class="block font-bold text-navy">Equal opportunity notice</strong>
          Qualified CDL applicants are considered without regard to race, color, or other protected status under federal and state law.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        <div class="space-y-2">
          <label for="driver-firstname" class="block">
            First Name <span class="text-cyan-dark font-bold">*</span>
          </label>
          <input
            type="text"
            id="driver-firstname"
            name="first_name"
            required
            maxlength="40"
            autocomplete="given-name"
            aria-invalid="false"
            class="px-4 py-3.5"
            placeholder="John"
          />
        </div>

        <div class="space-y-2">
          <label for="driver-lastname" class="block">
            Last Name <span class="text-cyan-dark font-bold">*</span>
          </label>
          <input
            type="text"
            id="driver-lastname"
            name="last_name"
            required
            maxlength="40"
            autocomplete="family-name"
            aria-invalid="false"
            class="px-4 py-3.5"
            placeholder="Doe"
          />
        </div>

        <div class="space-y-2">
          <label for="driver-age-eligible" class="block">
            Age Eligibility <span class="text-cyan-dark font-bold">*</span>
          </label>
          <select
            id="driver-age-eligible"
            name="age_eligibility"
            required
            aria-invalid="false"
            class="px-4 py-3.5"
          >
            <option value="" disabled selected>Select eligibility</option>
            <option value="22_or_older">I am 22 or older</option>
            <option value="under_22">I am under 22</option>
          </select>
        </div>

        <div class="space-y-2">
          <label for="driver-contact-pref" class="block">
            Preferred Contact Method <span class="text-cyan-dark font-bold">*</span>
          </label>
          <select
            id="driver-contact-pref"
            name="preferred_contact"
            required
            aria-invalid="false"
            class="px-4 py-3.5"
          >
            <option value="" disabled selected>Select method</option>
            <option value="Phone">Phone</option>
            <option value="Text">Text</option>
            <option value="Email">Email</option>
          </select>
        </div>

        <div class="space-y-2">
          <label for="driver-phone" class="block">
            Primary Phone <span class="text-cyan-dark font-bold">*</span>
          </label>
          <input
            type="tel"
            id="driver-phone"
            name="phone"
            required
            maxlength="14"
            autocomplete="tel"
            inputmode="tel"
            aria-invalid="false"
            class="px-4 py-3.5"
            placeholder="(555) 123-4567"
          />
        </div>

        <div class="space-y-2">
          <label for="driver-email" class="block">
            Email Address <span class="text-cyan-dark font-bold">*</span>
          </label>
          <input
            type="email"
            id="driver-email"
            name="email"
            required
            maxlength="60"
            autocomplete="email"
            inputmode="email"
            aria-invalid="false"
            class="px-4 py-3.5"
            placeholder="john@email.com"
          />
        </div>
      </div>

      <div class="flex items-start gap-3 rounded-md bg-slate-100 p-4 text-[15px] leading-relaxed text-slate-700">
        <svg class="mt-0.5 h-5 w-5 shrink-0 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 00-9 0v3.75m-.75 0h10.5A2.25 2.25 0 0119.5 12.75v6A2.25 2.25 0 0117.25 21H6.75a2.25 2.25 0 01-2.25-2.25v-6A2.25 2.25 0 016.75 10.5z" />
        </svg>
        <p><strong class="font-semibold text-navy">Privacy first.</strong> We do not collect your SSN, full date of birth, or full CDL number here. Those details are handled later through direct onboarding.</p>
      </div>
    </fieldset>

    <fieldset id="page-step-2" class="hidden space-y-7">
      <legend class="sr-only">Address and residence history</legend>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        <div class="space-y-2 sm:col-span-2">
          <label for="driver-street" class="block">
            Current Street Address <span class="text-cyan-dark font-bold">*</span>
          </label>
          <input
            type="text"
            id="driver-street"
            name="address_line1"
            required
            autocomplete="street-address"
            maxlength="100"
            aria-invalid="false"
            class="px-4 py-3.5"
            placeholder="123 Main Street, Apt 4B"
          />
        </div>

        <div class="space-y-2">
          <label for="driver-location" class="block">
            City &amp; State <span class="text-cyan-dark font-bold">*</span>
          </label>
          <input
            type="text"
            id="driver-location"
            name="city_state"
            required
            maxlength="80"
            autocomplete="address-level2"
            aria-invalid="false"
            class="px-4 py-3.5"
            placeholder="Chicago, IL"
          />
        </div>

        <div class="space-y-2">
          <label for="driver-zip" class="block">
            Zip Code <span class="text-cyan-dark font-bold">*</span>
          </label>
          <input
            type="text"
            id="driver-zip"
            name="zip"
            required
            autocomplete="postal-code"
            inputmode="numeric"
            pattern="[0-9]{5}(-[0-9]{4})?"
            maxlength="10"
            aria-invalid="false"
            class="px-4 py-3.5"
            placeholder="60601"
          />
        </div>
      </div>

      <div class="rounded-md bg-slate-100 p-4">
        <p class="mb-3 text-[15px] font-bold text-slate-800">
          Residence address for 3 or more years? <span class="text-cyan-dark font-bold">*</span>
        </p>
        <div class="flex flex-wrap gap-6">
          <label class="flex min-h-11 items-center gap-2.5 text-base font-semibold text-ink">
            <input type="radio" name="residence_3yrs" value="Yes" checked /> Yes
          </label>
          <label class="flex min-h-11 items-center gap-2.5 text-base font-semibold text-ink">
            <input type="radio" name="residence_3yrs" value="No" /> No
          </label>
        </div>
      </div>
    </fieldset>

    <fieldset id="page-step-3" class="hidden space-y-7">
      <legend class="sr-only">CDL license and driving history</legend>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        <div class="space-y-2">
          <label for="driver-cdl" class="block">
            CDL-A License Status <span class="text-cyan-dark font-bold">*</span>
          </label>
          <select
            id="driver-cdl"
            name="cdl_status"
            required
            aria-invalid="false"
            class="px-4 py-3.5"
          >
            <option value="" disabled selected>Select status</option>
            <option value="Active CDL-A">Active CDL-A</option>
            <option value="CDL-A permit">CDL-A permit</option>
            <option value="Not currently licensed">Not currently licensed</option>
          </select>
        </div>

        <div class="space-y-2">
          <label for="driver-state" class="block">
            State of Issue <span class="text-cyan-dark font-bold">*</span>
          </label>
          <input
            type="text"
            id="driver-state"
            name="cdl_state"
            required
            maxlength="2"
            autocapitalize="characters"
            aria-invalid="false"
            class="px-4 py-3.5 uppercase"
            placeholder="IL"
          />
        </div>

        <div class="space-y-2">
          <label for="driver-exp" class="block">
            Verifiable OTR Experience <span class="text-cyan-dark font-bold">*</span>
          </label>
          <select
            id="driver-exp"
            name="experience"
            required
            aria-invalid="false"
            class="px-4 py-3.5"
          >
            <option value="" disabled selected>Select experience</option>
            <option value="1-3 years">1 to 3 years</option>
            <option value="3-5 years">3 to 5 years</option>
            <option value="5+ years">5+ years</option>
          </select>
        </div>

        <div class="space-y-2">
          <label for="driver-mvr" class="block">
            Traffic Accidents / Violations (Past 3 Yrs)
          </label>
          <select
            id="driver-mvr"
            name="mvr_clean"
            class="px-4 py-3.5"
          >
            <option value="Clean MVR Record">Clean MVR Record (0 violations)</option>
            <option value="1 minor violation">1 minor violation</option>
            <option value="2+ violations">2+ violations</option>
          </select>
        </div>
      </div>
    </fieldset>

    <div id="page-footer-controls" class="flex flex-col-reverse gap-3 border-t border-slate-200 pt-6 sm:flex-row sm:items-center sm:justify-between">
      <button
        type="button"
        id="page-btn-prev"
        class="inline-flex min-h-13 items-center justify-center gap-2 rounded-sm border border-slate-300 px-6 py-3 text-[15px] font-extrabold uppercase tracking-[0.04em] text-slate-700 transition-colors hover:bg-slate-100 disabled:opacity-45"
        disabled
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        <span>Back</span>
      </button>

      <button
        type="button"
        id="page-btn-next"
        class="inline-flex min-h-13 items-center justify-center gap-2 rounded-sm bg-cyan px-7 py-3 text-[15px] font-extrabold uppercase tracking-[0.04em] text-navy transition-colors hover:bg-cyan-hover"
      >
        <span id="page-btn-next-label">Continue</span>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </button>
    </div>
  </form>
</div>

<style>
  .driver-progress {
    border-bottom: 1px solid #dbe2ea;
    padding-bottom: 1.5rem;
  }

  .driver-progress-step {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 0.5rem;
    color: #64748b;
    font-size: 0.9375rem;
    font-weight: 700;
  }

  .driver-progress-number {
    display: inline-flex;
    width: 1.75rem;
    height: 1.75rem;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    border: 1px solid #cbd5e1;
    border-radius: 50%;
    background: #ffffff;
    color: #475569;
    font-size: 0.875rem;
  }

  .driver-progress-step[data-state='current'] {
    color: #111722;
  }

  .driver-progress-step[data-state='current'] .driver-progress-number,
  .driver-progress-step[data-state='complete'] .driver-progress-number {
    border-color: #00a8e1;
    background: #00a8e1;
    color: #111722;
  }

  @media (max-width: 520px) {
    .driver-progress-step {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.4rem;
      font-size: 0.875rem;
      line-height: 1.25;
    }
  }
</style>

<script>
  import { initAntiSpam, validateAntiSpam, recordSubmission } from '@/scripts/anti-spam';

  let step = 1;

  function initPageDriverForm() {
    const prevBtn = document.getElementById('page-btn-prev') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('page-btn-next') as HTMLButtonElement | null;
    const nextBtnLabel = document.getElementById('page-btn-next-label');
    const form = document.getElementById('driver-form') as HTMLFormElement | null;
    const errorCard = document.getElementById('driver-error');
    const successCard = document.getElementById('driver-success');
    const footerControls = document.getElementById('page-footer-controls');
    const progress = document.getElementById('page-driver-progress');
    const progressSteps = Array.from(document.querySelectorAll<HTMLElement>('.driver-progress-step'));

    if (!prevBtn || !nextBtn || !nextBtnLabel || !form) return;
    if (form.dataset.driverFormBound === 'true') return;
    form.dataset.driverFormBound = 'true';
    step = 1;
    const previousButton = prevBtn;
    const nextButtonLabel = nextBtnLabel;

    // Initialize anti-spam protections
    initAntiSpam(form);

    function updatePageStepUI() {
      document.getElementById('page-step-1')?.classList.toggle('hidden', step !== 1);
      document.getElementById('page-step-2')?.classList.toggle('hidden', step !== 2);
      document.getElementById('page-step-3')?.classList.toggle('hidden', step !== 3);

      const stepTitle = document.getElementById('page-driver-step-title');
      const stepPct = document.getElementById('page-driver-step-pct');
      const bar = document.getElementById('page-driver-progress-bar');
      const percentages = [33, 67, 100];
      const titles = [
        'Step 1 of 3: Your details',
        'Step 2 of 3: Your address',
        'Step 3 of 3: CDL history',
      ];
      const currentPercentage = percentages[step - 1];

      if (errorCard) errorCard.classList.add('hidden');

      if (stepTitle) stepTitle.textContent = titles[step - 1] ?? titles[0];
      if (stepPct) stepPct.textContent = `${currentPercentage}% complete`;
      if (bar) bar.style.width = `${currentPercentage}%`;
      progress?.setAttribute('aria-valuenow', String(currentPercentage));
      previousButton.disabled = step === 1;
      nextButtonLabel.textContent = step === 3 ? 'Submit application' : 'Continue';

      progressSteps.forEach((item, index) => {
        const itemStep = index + 1;
        item.dataset.state = itemStep < step ? 'complete' : itemStep === step ? 'current' : 'upcoming';
        if (itemStep === step) item.setAttribute('aria-current', 'step');
        else item.removeAttribute('aria-current');
      });
    }

    function validateCurrentStep(): boolean {
      const currentStepEl = document.getElementById(`page-step-${step}`);
      if (!currentStepEl) return true;

      const requiredInputs = currentStepEl.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[required]');
      let isValid = true;
      const invalidInputs: Array<HTMLInputElement | HTMLSelectElement> = [];
      let eligibilityMessage = '';

      requiredInputs.forEach((input) => {
        const failsRequirement =
          (input.id === 'driver-age-eligible' && input.value === 'under_22') ||
          (input.id === 'driver-cdl' && input.value !== 'Active CDL-A');
        const isInputInvalid = !input.checkValidity() || failsRequirement;

        if (isInputInvalid) {
          isValid = false;
          invalidInputs.push(input);
          input.setAttribute('aria-invalid', 'true');
          if (input.id === 'driver-age-eligible' && failsRequirement) {
            eligibilityMessage = 'Applicants must be at least 22 years old for this position.';
          }
          if (input.id === 'driver-cdl' && failsRequirement) {
            eligibilityMessage = 'An active Class A CDL is required for this position.';
          }
        } else {
          input.setAttribute('aria-invalid', 'false');
        }
      });

      if (errorCard) {
        if (!isValid) {
          const errorText = errorCard.querySelector('p');
          if (errorText) errorText.textContent = eligibilityMessage || 'Check the highlighted fields before continuing.';
          errorCard.classList.remove('hidden');
        } else {
          errorCard.classList.add('hidden');
        }
      }

      invalidInputs[0]?.focus();

      return isValid;
    }

    nextBtn.addEventListener('click', (e) => {
      e.preventDefault();
      if (!validateCurrentStep()) return;

      if (step < 3) {
        step++;
        updatePageStepUI();
      } else {
        // Anti-spam validation before final submission
        const spamCheck = validateAntiSpam(form!);
        if (!spamCheck.valid) {
          if (errorCard) {
            const errorText = errorCard.querySelector('p');
            if (errorText) errorText.textContent = 'Unable to process your submission. Please try again in a moment.';
            errorCard.classList.remove('hidden');
          }
          return;
        }

        // Record submission for rate limiting
        recordSubmission();

        // Complete Application & set 100% progress
        const stepTitle = document.getElementById('page-driver-step-title');
        const stepPct = document.getElementById('page-driver-step-pct');
        const bar = document.getElementById('page-driver-progress-bar');

        if (stepTitle) stepTitle.textContent = 'Application Completed';
        if (stepPct) stepPct.textContent = '100% complete';
        if (bar) bar.style.width = '100%';
        progress?.setAttribute('aria-valuenow', '100');
        progressSteps.forEach((item) => {
          item.dataset.state = 'complete';
          item.removeAttribute('aria-current');
        });

        document.getElementById('page-step-1')?.classList.add('hidden');
        document.getElementById('page-step-2')?.classList.add('hidden');
        document.getElementById('page-step-3')?.classList.add('hidden');
        if (successCard) successCard.classList.remove('hidden');
        footerControls?.classList.add('hidden');
      }
    });

    prevBtn.addEventListener('click', (e) => {
      e.preventDefault();
      if (step > 1) {
        step--;
        updatePageStepUI();
      }
    });

    form.addEventListener('input', (event) => {
      const target = event.target;
      if (target instanceof HTMLInputElement || target instanceof HTMLSelectElement) {
        target.setAttribute('aria-invalid', 'false');
      }
    });

    updatePageStepUI();
  }

  initPageDriverForm();
  document.addEventListener('astro:page-load', initPageDriverForm);
</script>
