---
// src/components/DriverForm.astro
---

<div class="space-y-6">
  <!-- Interactive Progress Bar -->
  <div class="bg-slate-100 p-4 rounded-xl border border-slate-200/80">
    <div class="flex items-center justify-between text-xs font-heading font-bold uppercase tracking-wider text-slate-600 mb-2">
      <span id="page-driver-step-title" class="text-navy font-extrabold">Step 1 of 3: Personal &amp; Contact Information</span>
      <span id="page-driver-step-pct" class="text-cyan font-extrabold">0% Completed</span>
    </div>
    <div class="w-full bg-slate-200 h-2.5 rounded-full overflow-hidden">
      <div id="page-driver-progress-bar" class="bg-cyan h-full w-0 transition-all duration-300"></div>
    </div>
  </div>

  <form id="driver-form" class="space-y-6 min-h-[500px]" novalidate>
    <input type="hidden" name="formType" value="full_driver_app" />

    <!-- SUCCESS MESSAGE CARD WITH CELEBRATORY ANIMATION -->
    <div id="driver-success" class="hidden p-10 border border-emerald-500/30 bg-emerald-500/5 rounded-2xl text-center transition-all duration-500">
      <div class="flex flex-col items-center justify-center gap-4">
        <div class="relative flex h-16 w-16 items-center justify-center rounded-full bg-emerald-500 text-white shadow-xl shadow-emerald-500/30">
          <span class="absolute inset-0 rounded-full bg-emerald-400 animate-ping opacity-30"></span>
          <svg class="h-8 w-8 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        
        <h4 class="font-heading text-2xl font-extrabold text-navy uppercase tracking-wide mt-2">Application Submitted!</h4>
        <p class="text-sm sm:text-base text-slate-700 font-body font-light max-w-lg leading-relaxed">
          Thank you for applying to <strong class="font-semibold text-navy">WolfWay Logistics LLC</strong>. A recruitment coordinator will review your CDL records and contact you within 24 hours.
        </p>
      </div>
    </div>

    <!-- ERROR MESSAGE CARD -->
    <div id="driver-error" class="hidden p-4 border border-red-500/20 bg-red-500/5 rounded-lg">
      <p class="text-sm font-medium text-red-600 font-body text-center">
        Please fill out all required fields on this step to continue.
      </p>
    </div>

    <!-- STEP 1: PERSONAL & CONTACT INFORMATION -->
    <div id="page-step-1" class="space-y-6">
      <div class="p-4 bg-cyan/5 border border-cyan/20 rounded-xl text-xs text-slate-700 font-body leading-relaxed">
        <strong class="font-bold text-navy block font-heading uppercase text-xs mb-0.5">FMCSA DOT Equal Opportunity Notice:</strong>
        In compliance with Federal &amp; State equal opportunity laws, qualified CDL applicants are considered without regard to race, color, or protected status.
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label for="driver-firstname" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
            First Name <span class="text-cyan font-bold">*</span>
          </label>
          <input
            type="text"
            id="driver-firstname"
            name="first_name"
            required
            maxlength="40"
            autocomplete="given-name"
            class="w-full border border-slate-200 bg-white px-4 py-3.5 rounded-lg text-sm sm:text-base text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
            placeholder="John"
          />
        </div>

        <div>
          <label for="driver-lastname" class="block text-xs sm:text-sm font-extrabold uppercase tracking-wider text-slate-800 mb-2 font-body">
            Last Name <span class="text-cyan font-bold">*</span>
          </label>
          <input
            type="text"
            id="driver-lastname"
            name="last_name"
            required
            maxlength="40"
            autocomplete="family-name"
            class="w-full border border-slate-200 bg-white px-4 py-3.5 rounded-lg text-sm sm:text-base text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
            placeholder="Doe"
          />
        </div>

        <div>
          <label for="driver-age-eligible" class="block text-xs sm:text-sm font-extrabold uppercase tracking-wider text-slate-800 mb-2 font-body">
            Age Eligibility <span class="text-cyan font-bold">*</span>
          </label>
          <select
            id="driver-age-eligible"
            name="age_eligibility"
            required
            class="w-full border border-slate-200 bg-white px-4 py-3.5 rounded-lg text-sm sm:text-base text-ink focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
          >
            <option value="">Select eligibility</option>
            <option value="22_or_older">I am 22 or older</option>
            <option value="under_22">I am under 22</option>
          </select>
        </div>

        <div>
          <label for="driver-contact-pref" class="block text-xs sm:text-sm font-extrabold uppercase tracking-wider text-slate-800 mb-2 font-body">
            Preferred Contact Method <span class="text-cyan font-bold">*</span>
          </label>
          <select
            id="driver-contact-pref"
            name="preferred_contact"
            required
            class="w-full border border-slate-200 bg-white px-4 py-3.5 rounded-lg text-sm sm:text-base text-ink focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
          >
            <option value="">Select method</option>
            <option value="Phone">Phone</option>
            <option value="Text">Text</option>
            <option value="Email">Email</option>
          </select>
        </div>

        <div>
          <label for="driver-phone" class="block text-xs sm:text-sm font-extrabold uppercase tracking-wider text-slate-800 mb-2 font-body">
            Primary Phone <span class="text-cyan font-bold">*</span>
          </label>
          <input
            type="tel"
            id="driver-phone"
            name="phone"
            required
            maxlength="14"
            autocomplete="tel"
            class="w-full border border-slate-200 bg-white px-4 py-3.5 rounded-lg text-sm sm:text-base text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
            placeholder="(555) 123-4567"
          />
        </div>

        <div>
          <label for="driver-email" class="block text-xs sm:text-sm font-extrabold uppercase tracking-wider text-slate-800 mb-2 font-body">
            Email Address <span class="text-cyan font-bold">*</span>
          </label>
          <input
            type="email"
            id="driver-email"
            name="email"
            required
            maxlength="60"
            autocomplete="email"
            class="w-full border border-slate-200 bg-white px-4 py-3.5 rounded-lg text-sm sm:text-base text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
            placeholder="john@email.com"
          />
        </div>
      </div>

      <p class="rounded-lg border border-cyan/20 bg-cyan/5 p-4 text-sm leading-relaxed text-slate-700">
        For privacy, this public form does not collect SSN, full date of birth, or full CDL number. Those details are handled later through direct onboarding.
      </p>


    </div>

    <!-- STEP 2: ADDRESS & RESIDENCE HISTORY -->
    <div id="page-step-2" class="space-y-6 hidden">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div class="sm:col-span-2">
          <label for="driver-street" class="block text-xs sm:text-sm font-extrabold uppercase tracking-wider text-slate-800 mb-2 font-body">
            Current Street Address <span class="text-cyan font-bold">*</span>
          </label>
          <input
            type="text"
            id="driver-street"
            name="address_line1"
            required
            autocomplete="street-address"
            class="w-full border border-slate-200 bg-white px-4 py-3.5 rounded-lg text-sm sm:text-base text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
            placeholder="123 Main Street, Apt 4B"
          />
        </div>

        <div>
          <label for="driver-location" class="block text-xs sm:text-sm font-extrabold uppercase tracking-wider text-slate-800 mb-2 font-body">
            City &amp; State <span class="text-cyan font-bold">*</span>
          </label>
          <input
            type="text"
            id="driver-location"
            name="city_state"
            required
            class="w-full border border-slate-200 bg-white px-4 py-3.5 rounded-lg text-sm sm:text-base text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
            placeholder="Chicago, IL"
          />
        </div>

        <div>
          <label for="driver-zip" class="block text-xs sm:text-sm font-extrabold uppercase tracking-wider text-slate-800 mb-2 font-body">
            Zip Code <span class="text-cyan font-bold">*</span>
          </label>
          <input
            type="text"
            id="driver-zip"
            name="zip"
            required
            autocomplete="postal-code"
            class="w-full border border-slate-200 bg-white px-4 py-3.5 rounded-lg text-sm sm:text-base text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
            placeholder="60601"
          />
        </div>
      </div>

      <div class="p-4 bg-slate-50 border border-slate-200 rounded-xl">
        <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-3 font-body">
          Residence address for 3 or more years? <span class="text-cyan font-bold">*</span>
        </label>
        <div class="flex gap-8">
          <label class="flex items-center gap-2 text-sm text-ink cursor-pointer font-body font-semibold">
            <input type="radio" name="residence_3yrs" value="Yes" checked class="accent-cyan h-4.5 w-4.5" /> Yes
          </label>
          <label class="flex items-center gap-2 text-sm text-ink cursor-pointer font-body font-semibold">
            <input type="radio" name="residence_3yrs" value="No" class="accent-cyan h-4.5 w-4.5" /> No
          </label>
        </div>
      </div>
    </div>

    <!-- STEP 3: CDL LICENSE & DRIVING HISTORY -->
    <div id="page-step-3" class="space-y-6 hidden">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label for="driver-cdl" class="block text-xs sm:text-sm font-extrabold uppercase tracking-wider text-slate-800 mb-2 font-body">
            CDL-A License Status <span class="text-cyan font-bold">*</span>
          </label>
          <select
            id="driver-cdl"
            name="cdl_status"
            required
            class="w-full border border-slate-200 bg-white px-4 py-3.5 rounded-lg text-sm sm:text-base text-ink focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
          >
            <option value="">Select status</option>
            <option value="Active CDL-A">Active CDL-A</option>
            <option value="CDL-A permit">CDL-A permit</option>
            <option value="Not currently licensed">Not currently licensed</option>
          </select>
        </div>

        <div>
          <label for="driver-state" class="block text-xs sm:text-sm font-extrabold uppercase tracking-wider text-slate-800 mb-2 font-body">
            State of Issue <span class="text-cyan font-bold">*</span>
          </label>
          <input
            type="text"
            id="driver-state"
            name="cdl_state"
            required
            class="w-full border border-slate-200 bg-white px-4 py-3.5 rounded-lg text-sm sm:text-base text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
            placeholder="IL"
          />
        </div>

        <div>
          <label for="driver-exp" class="block text-xs sm:text-sm font-extrabold uppercase tracking-wider text-slate-800 mb-2 font-body">
            Verifiable OTR Experience <span class="text-cyan font-bold">*</span>
          </label>
          <select
            id="driver-exp"
            name="experience"
            required
            class="w-full border border-slate-200 bg-white px-4 py-3.5 rounded-lg text-sm text-ink focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
          >
            <option value="1-3 years">1 to 3 years</option>
            <option value="3-5 years">3 to 5 years</option>
            <option value="5+ years">5+ years</option>
          </select>
        </div>

        <div>
          <label for="driver-mvr" class="block text-xs sm:text-sm font-extrabold uppercase tracking-wider text-slate-800 mb-2 font-body">
            Traffic Accidents / Violations (Past 3 Yrs)
          </label>
          <select
            id="driver-mvr"
            name="mvr_clean"
            class="w-full border border-slate-200 bg-white px-4 py-3.5 rounded-lg text-sm text-ink focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
          >
            <option value="Clean MVR Record">Clean MVR Record (0 violations)</option>
            <option value="1 minor violation">1 minor violation</option>
            <option value="2+ violations">2+ violations</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Navigation Footer Controls -->
    <div id="page-footer-controls" class="pt-6 border-t border-slate-100 flex items-center justify-between">
      <button
        type="button"
        id="page-btn-prev"
        class="px-6 py-3 rounded-lg border border-slate-300 text-slate-600 font-heading text-xs font-bold uppercase hover:bg-slate-100 transition-colors opacity-50 cursor-not-allowed"
        disabled
      >
        &larr; Back
      </button>

      <button
        type="button"
        id="page-btn-next"
        class="px-8 py-3.5 rounded-lg bg-cyan text-navy font-heading text-xs font-bold uppercase tracking-wider hover:bg-[#00D4E0] transition-colors shadow-xs"
      >
        Next Step &rarr;
      </button>
    </div>
  </form>
</div>

<script>
  import { initAntiSpam, validateAntiSpam, recordSubmission } from '@/scripts/anti-spam';

  let step = 1;

  function initPageDriverForm() {
    const prevBtn = document.getElementById('page-btn-prev') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('page-btn-next') as HTMLButtonElement | null;
    const form = document.getElementById('driver-form') as HTMLFormElement | null;
    const errorCard = document.getElementById('driver-error');
    const successCard = document.getElementById('driver-success');
    const footerControls = document.getElementById('page-footer-controls');

    if (!prevBtn || !nextBtn || !form) return;
    if (form.dataset.driverFormBound === 'true') return;
    form.dataset.driverFormBound = 'true';

    // Initialize anti-spam protections
    initAntiSpam(form);

    function updatePageStepUI() {
      document.getElementById('page-step-1')?.classList.toggle('hidden', step !== 1);
      document.getElementById('page-step-2')?.classList.toggle('hidden', step !== 2);
      document.getElementById('page-step-3')?.classList.toggle('hidden', step !== 3);

      const stepTitle = document.getElementById('page-driver-step-title');
      const stepPct = document.getElementById('page-driver-step-pct');
      const bar = document.getElementById('page-driver-progress-bar');

      if (errorCard) errorCard.classList.add('hidden');

      if (step === 1) {
        if (stepTitle) stepTitle.textContent = 'Step 1 of 3: Personal & Contact Information';
        if (stepPct) stepPct.textContent = '0% Completed';
        if (bar) bar.style.width = '0%';
        prevBtn!.disabled = true;
        prevBtn!.classList.add('opacity-50', 'cursor-not-allowed');
        nextBtn!.textContent = 'Next Step \u2192';
      } else if (step === 2) {
        if (stepTitle) stepTitle.textContent = 'Step 2 of 3: Address & Residence History';
        if (stepPct) stepPct.textContent = '33% Completed';
        if (bar) bar.style.width = '33%';
        prevBtn!.disabled = false;
        prevBtn!.classList.remove('opacity-50', 'cursor-not-allowed');
        nextBtn!.textContent = 'Next Step \u2192';
      } else if (step === 3) {
        if (stepTitle) stepTitle.textContent = 'Step 3 of 3: CDL License & Driving History';
        if (stepPct) stepPct.textContent = '66% Completed';
        if (bar) bar.style.width = '66%';
        prevBtn!.disabled = false;
        prevBtn!.classList.remove('opacity-50', 'cursor-not-allowed');
        nextBtn!.textContent = 'Submit Official Application';
      }
    }

    function validateCurrentStep(): boolean {
      const currentStepEl = document.getElementById(`page-step-${step}`);
      if (!currentStepEl) return true;

      const requiredInputs = currentStepEl.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[required]');
      let isValid = true;

      requiredInputs.forEach((input) => {
        if (!input.value.trim()) {
          isValid = false;
          input.classList.add('border-red-500', 'ring-2', 'ring-red-500/20');
        } else {
          input.classList.remove('border-red-500', 'ring-2', 'ring-red-500/20');
        }
      });

      if (errorCard) {
        if (!isValid) {
          errorCard.classList.remove('hidden');
        } else {
          errorCard.classList.add('hidden');
        }
      }

      return isValid;
    }

    nextBtn.addEventListener('click', (e) => {
      e.preventDefault();
      if (!validateCurrentStep()) return;

      if (step < 3) {
        step++;
        updatePageStepUI();
      } else {
        // Anti-spam validation before final submission
        const spamCheck = validateAntiSpam(form!);
        if (!spamCheck.valid) {
          if (errorCard) {
            const errorText = errorCard.querySelector('p');
            if (errorText) errorText.textContent = 'Unable to process your submission. Please try again in a moment.';
            errorCard.classList.remove('hidden');
          }
          return;
        }

        // Record submission for rate limiting
        recordSubmission();

        // Complete Application & set 100% progress
        const stepTitle = document.getElementById('page-driver-step-title');
        const stepPct = document.getElementById('page-driver-step-pct');
        const bar = document.getElementById('page-driver-progress-bar');

        if (stepTitle) stepTitle.textContent = 'Application Completed';
        if (stepPct) stepPct.textContent = '100% Completed';
        if (bar) bar.style.width = '100%';

        document.getElementById('page-step-1')?.classList.add('hidden');
        document.getElementById('page-step-2')?.classList.add('hidden');
        document.getElementById('page-step-3')?.classList.add('hidden');
        if (successCard) successCard.classList.remove('hidden');
        footerControls?.classList.add('hidden');
      }
    });

    prevBtn.addEventListener('click', (e) => {
      e.preventDefault();
      if (step > 1) {
        step--;
        updatePageStepUI();
      }
    });
  }

  initPageDriverForm();
  document.addEventListener('astro:page-load', initPageDriverForm);
</script>
