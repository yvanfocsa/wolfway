---
// src/components/FAQ.astro

export interface FAQItem {
  question: string;
  answer: string;
}

export interface Props {
  items: FAQItem[];
  eyebrow?: string;
  title?: string;
}

const { 
  items, 
  eyebrow = "COMMON QUESTIONS", 
  title = "Frequently Asked Questions" 
} = Astro.props;
---

<div class="faq-container w-full select-none">
  <!-- FAQ Header -->
  <div class="mb-10 text-center">
    <h2 class="font-heading text-3xl font-bold uppercase text-ink">
      {title}
    </h2>
  </div>

  <!-- FAQ Accordion Stack -->
  <div class="max-w-3xl mx-auto space-y-4">
    {items.map((item, idx) => (
      <details class="faq-item group border border-slate-200 bg-white rounded-sm transition-all duration-300">
        <summary class="faq-summary flex items-center justify-between p-5 cursor-pointer font-heading text-base font-bold uppercase text-ink list-none outline-none focus-visible:bg-slate-50 rounded-sm">
          <span>{item.question}</span>
          <svg class="h-4.5 w-4.5 text-slate-500 transition-transform duration-300 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="faq-content overflow-hidden transition-all">
          <div class="p-5 pt-0 border-t border-slate-100 text-sm leading-relaxed text-slate-600 font-body font-light">
            {item.answer}
          </div>
        </div>
      </details>
    ))}
  </div>
</div>

<script>
  import { gsap } from 'gsap';

  function initFaqAnimations() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return; // Do not animate for reduced motion

    const detailsElements = document.querySelectorAll('.faq-item') as NodeListOf<HTMLDetailsElement>;

    detailsElements.forEach((details) => {
      const summary = details.querySelector('.faq-summary') as HTMLElement | null;
      const content = details.querySelector('.faq-content') as HTMLElement | null;

      if (!summary || !content) return;

      // Handle custom clicks to animate
      summary.addEventListener('click', (e) => {
        e.preventDefault(); // Intercept browser native open toggle

        const isOpen = details.hasAttribute('open');

        if (isOpen) {
          // Close animation
          const height = content.scrollHeight;
          // Set initial height
          gsap.fromTo(content, 
            { height: height }, 
            { 
              height: 0, 
              duration: 0.35, 
              ease: 'power2.out',
              onComplete: () => {
                details.removeAttribute('open');
                content.removeAttribute('style'); // Clear height styles
              }
            }
          );
        } else {
          // Open animation
          details.setAttribute('open', 'true');
          const height = content.scrollHeight;
          
          gsap.fromTo(content, 
            { height: 0 }, 
            { 
              height: height, 
              duration: 0.35, 
              ease: 'power2.out',
              onComplete: () => {
                content.removeAttribute('style'); // Clear height styles
              }
            }
          );
        }
      });
    });
  }

  // Initial load
  initFaqAnimations();

  // Astro page-load trigger for persistent view navigation
  document.addEventListener('astro:page-load', initFaqAnimations);
</script>

<style>
  /* Hide native summary marker in all browsers */
  .faq-summary::-webkit-details-marker {
    display: none;
  }
  .faq-summary {
    list-style: none;
  }
</style>
