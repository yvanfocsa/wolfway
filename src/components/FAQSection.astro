---
// src/components/FAQSection.astro
import Button from './Button.astro';
import { shipperFAQs } from '@/content/faq';

const topFAQs = shipperFAQs.slice(0, 4);
---

<section class="bg-white py-16 sm:py-20 lg:py-24 border-b border-slate-100 select-none">
  <div class="mx-auto max-w-7xl px-5 lg:px-10">
    <div class="grid lg:grid-cols-12 gap-12 items-start">
      <!-- Left Header Column -->
      <div class="lg:col-span-4 space-y-4">
        <h2 class="font-heading text-2xl sm:text-3xl lg:text-4xl font-extrabold uppercase text-ink leading-tight">
          Everything you need to know
        </h2>
        <p class="text-sm text-slate-600 font-body font-light leading-relaxed">
          Have questions about trailer specs, quote response times, or cargo insurance limits? We answer everything upfront.
        </p>
        <div class="pt-2">
          <Button href="/faq" variant="outlineInk" size="md" arrow={true}>
            View All FAQs
          </Button>
        </div>
      </div>

      <!-- Right Accordion Column -->
      <div class="lg:col-span-8 space-y-4">
        {topFAQs.map((faq) => (
          <details class="group bg-slate-50/50 border border-slate-200/80 rounded-xl overflow-hidden transition-all duration-300 shadow-xs open:bg-white open:border-cyan/40">
            <summary class="flex items-center justify-between p-5 sm:p-6 cursor-pointer select-none font-heading text-base sm:text-lg font-bold uppercase text-ink group-hover:text-cyan transition-colors">
              <span>{faq.question}</span>
              <span class="ml-4 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-slate-100 group-open:bg-cyan group-open:text-navy transition-colors">
                <svg class="h-3.5 w-3.5 transition-transform duration-300 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </summary>
            <div class="px-5 sm:px-6 pb-6 pt-1 text-slate-600 font-body font-light text-sm leading-relaxed border-t border-slate-100">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>
