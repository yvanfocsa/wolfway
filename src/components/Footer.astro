---
import Button from '@/components/Button.astro';
import { footerNav } from '@/content/navigation';
import { company } from '@/content/company';

const year = new Date().getFullYear();
const primaryNav = footerNav.filter(
  ({ href }) => !['/request-a-quote', '/privacy-policy', '/terms'].includes(href),
);
---

<footer class="bg-navy text-white">
  <div class="page-shell py-8 sm:py-10">
    <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
      <a href="/" class="group flex min-h-12 items-center gap-3">
        <img
          src="/images/logo-icon-v2-64.webp"
          srcset="/images/logo-icon-v2-64.webp 64w, /images/logo-icon-v2.webp 128w"
          sizes="48px"
          alt=""
          width="48"
          height="48"
          loading="lazy"
          decoding="async"
          class="h-12 w-12 shrink-0 object-contain transition-transform duration-300 group-hover:scale-105"
        />
        <span>
          <span class="block font-heading text-xl font-extrabold uppercase leading-none tracking-wider transition-colors group-hover:text-cyan">
            WolfWay Logistics LLC
          </span>
          <span class="mt-1 block text-[15px] leading-snug text-slate-300">
            {company.tagline}
          </span>
        </span>
      </a>

      <Button href="/request-a-quote" variant="primary" size="sm" arrow={true} class="w-full sm:w-auto">
        Request a Quote
      </Button>
    </div>

    <div class="mt-6 border-t border-white/10 pt-3 lg:flex lg:items-center lg:justify-between lg:gap-8">
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap gap-x-5 sm:gap-x-7">
          {primaryNav.map((item) => (
            <li>
              <a
                href={item.href}
                class="inline-flex min-h-11 items-center text-base font-semibold text-slate-300 transition-colors duration-200 hover:text-white"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="flex flex-wrap items-center gap-x-6 lg:shrink-0 lg:justify-end">
        <a
          href={`tel:${company.phoneRaw}`}
          class="inline-flex min-h-11 items-center text-base font-semibold text-white transition-colors duration-200 hover:text-cyan"
        >
          {company.phone}
        </a>
        <a
          href={`mailto:${company.email}`}
          class="inline-flex min-h-11 items-center text-base font-semibold text-slate-300 transition-colors duration-200 hover:text-white"
        >
          Email dispatch
        </a>
      </div>
    </div>

    <div class="mt-2 flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between sm:gap-6">
      <p class="text-[15px] leading-relaxed text-slate-400">
        &copy; {year} {company.name}. All rights reserved.
      </p>
      <div class="flex flex-wrap gap-x-6">
        <a href="/privacy-policy" class="inline-flex min-h-11 items-center text-[15px] text-slate-400 transition-colors duration-200 hover:text-white">
          Privacy Policy
        </a>
        <a href="/terms" class="inline-flex min-h-11 items-center text-[15px] text-slate-400 transition-colors duration-200 hover:text-white">
          Terms of Service
        </a>
      </div>
    </div>
  </div>
</footer>
