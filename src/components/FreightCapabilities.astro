---
import Button from './Button.astro';

const freightTypes = [
  {
    title: 'Machinery & Equipment',
    description: 'Construction, agricultural, industrial, and crated machinery matched with the right deck height and securement plan.',
  },
  {
    title: 'Steel & Fabrication',
    description: 'Coils, plate, beams, pipe, and fabricated sections coordinated around weight distribution, protection, and site access.',
  },
  {
    title: 'Building Materials',
    description: 'Lumber, roofing, precast products, and jobsite freight handled with practical pickup and delivery coordination.',
  },
  {
    title: 'Project Freight',
    description: 'Irregular, time-sensitive, and multi-load moves planned around dimensions, appointments, permits, and communication.',
  },
];
---

<section class="bg-navy py-16 sm:py-20 lg:py-24 text-white">
  <div class="mx-auto max-w-7xl px-5 lg:px-10">
    <div class="grid gap-12 lg:grid-cols-[0.78fr_1.22fr] lg:gap-16">
      <div class="lg:pt-2">
        <p class="readable-kicker text-cyan">Freight We Move</p>
        <h2 class="mt-3 max-w-xl font-heading text-3xl sm:text-4xl lg:text-5xl font-extrabold uppercase leading-none text-white">
          The right setup starts with the load
        </h2>
        <p class="mt-5 max-w-lg text-base sm:text-lg leading-relaxed text-slate-300">
          Open-deck freight is never one-size-fits-all. WolfWay reviews the commodity, dimensions, weight, loading method, and site constraints before matching equipment.
        </p>
        <div class="mt-8">
          <Button href="/services" variant="outline" size="md" arrow={true} class="w-full font-heading font-extrabold sm:w-auto">
            Explore Equipment Options
          </Button>
        </div>
      </div>

      <div class="border-t border-white/20">
        {freightTypes.map((item) => (
          <article class="grid gap-3 border-b border-white/20 py-6 transition-colors duration-200 hover:bg-white/[0.035] sm:px-4 md:grid-cols-[0.6fr_1fr] md:gap-8 md:py-8">
            <h3 class="font-heading text-2xl font-bold uppercase leading-tight text-white">{item.title}</h3>
            <p class="max-w-2xl text-base leading-relaxed text-slate-300">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
