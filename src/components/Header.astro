---
import { mainNav } from '@/content/navigation';
import Button from '@/components/Button.astro';
import { ArrowRight, Menu, Phone, X } from '@lucide/astro';

const pathname = new URL(Astro.request.url).pathname;
// Normalize pathname (strip trailing slash if any, except for root)
const currentPath = pathname.endsWith('/') && pathname !== '/' ? pathname.slice(0, -1) : pathname;
---

<div id="scroll-progress" class="fixed left-0 top-0 z-[80] h-0.5 w-full origin-left scale-x-0 bg-cyan shadow-[0_0_20px_rgba(0,168,225,0.45)]" aria-hidden="true"></div>

<header id="site-header" class="fixed top-0 left-0 z-50 w-full transition-all duration-200 border-b select-none py-4 border-transparent bg-transparent text-white group is-transparent">
  <nav class="mx-auto max-w-7xl px-5 lg:px-10 flex items-center justify-between">
    <!-- Logo & Brand Name -->
    <a href="/" class="group/logo flex min-h-13 shrink-0 items-center gap-3" focus-visible>
      <img
        id="header-logo"
        src="/images/logo-icon-v2-64.webp"
        srcset="/images/logo-icon-v2-64.webp 64w, /images/logo-icon-v2.webp 128w"
        sizes="52px"
        alt=""
        width="52"
        height="52"
        loading="eager"
        decoding="sync"
        fetchpriority="high"
        class="h-13 w-13 shrink-0 object-contain transition-transform duration-300 group-hover/logo:scale-105"
      />
      <span
        id="header-title"
        class="min-w-0 whitespace-nowrap text-white transition-colors duration-300 group-hover/logo:text-cyan group-[.is-scrolled]:text-ink"
      >
        <span class="block font-heading text-[22px] font-extrabold uppercase leading-none tracking-normal">
          WolfWay
        </span>
        <span class="mt-1 block font-heading text-sm font-bold uppercase leading-none tracking-normal text-white/75 transition-colors duration-300 group-hover/logo:text-cyan group-[.is-scrolled]:text-slate-600">
          Logistics LLC
        </span>
      </span>
    </a>

    <!-- Desktop Nav Links & CTA -->
    <div class="hidden lg:flex items-center gap-8">
      <div class="flex items-center gap-5">
        {mainNav.map((item) => {
          const isActive = item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href);
          return (
            <a
              href={item.href}
              aria-current={isActive ? 'page' : undefined}
              class="group/link relative inline-flex min-h-11 items-center rounded-sm px-2.5 py-1.5 font-body text-sm font-bold uppercase tracking-wider text-white/90 transition-colors duration-200 hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan/70 group-[.is-scrolled]:text-slate-700 group-[.is-scrolled]:hover:text-ink"
            >
              {item.label}
              <span 
                class:list={[
                  "absolute bottom-0 left-2.5 right-2.5 h-[2px] bg-cyan transition-transform duration-300 origin-left",
                  isActive ? "scale-x-100" : "scale-x-0 group-hover/link:scale-x-100"
                ]} 
                aria-hidden="true"
              ></span>
            </a>
          );
        })}
      </div>
      <div class="flex items-center gap-4">
        <a
          href="tel:+12244464256"
          class="hidden min-h-11 items-center gap-1.5 font-body text-sm font-bold uppercase tracking-wider text-white/90 transition-colors hover:text-cyan group-[.is-scrolled]:text-ink xl:flex"
        >
          <Phone class="h-3.5 w-3.5 shrink-0 text-cyan" stroke-width={2.25} aria-hidden="true" />
          +1 (224) 446-4256
        </a>
        <Button 
          href="/driver-application" 
          variant="primary" 
          size="sm" 
          class="rounded-sm font-heading font-extrabold tracking-wider uppercase focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan/70"
        >
          Apply to Drive
        </Button>
      </div>
    </div>

    <!-- Mobile Menu Open Toggle -->
    <button
      id="mobile-menu-open"
      class="relative z-50 flex h-11 w-11 items-center justify-center rounded-sm border border-white/20 bg-navy/20 text-white transition-[background-color,border-color,color] duration-200 hover:bg-white/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan/70 focus-visible:outline-offset-2 group-[.is-scrolled]:border-slate-200 group-[.is-scrolled]:bg-slate-100 group-[.is-scrolled]:text-ink group-[.is-scrolled]:hover:bg-slate-200/70 lg:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="sr-only">Open menu</span>
      <Menu class="h-6 w-6" stroke-width={2.25} aria-hidden="true" />
    </button>
  </nav>
</header>

<!-- Mobile Menu Drawer (Right-side slideout) -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] lg:hidden pointer-events-none"
  aria-hidden="true"
  inert
>
  <!-- Backdrop (dimmer overlay) -->
  <div
    id="menu-backdrop"
    class="pointer-events-none absolute inset-0 bg-navy/55 opacity-0 backdrop-blur-[3px] transition-opacity duration-300"
  ></div>

  <!-- Sliding Drawer Panel -->
  <div
    id="menu-panel"
    class="pointer-events-auto absolute bottom-0 right-0 top-0 flex w-[min(88vw,22.5rem)] translate-x-full flex-col justify-between border-l border-slate-200/80 bg-white shadow-[-8px_0_14px_rgba(15,23,42,0.12)] transition-transform duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]"
    role="dialog"
    aria-modal="true"
    aria-labelledby="mobile-menu-title"
  >
    <!-- Drawer Header -->
    <div class="flex items-center justify-between border-b border-slate-200 px-5 py-4">
      <h2 id="mobile-menu-title" class="sr-only">Mobile navigation</h2>
      <a href="/" class="group/drawer-logo flex min-h-11 items-center gap-3 rounded-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan/70 focus-visible:outline-offset-2" aria-label="WolfWay Logistics LLC Home">
        <img src="/images/logo-icon-v2-64.webp" srcset="/images/logo-icon-v2-64.webp 64w, /images/logo-icon-v2.webp 128w" sizes="44px" alt="" width="44" height="44" loading="lazy" decoding="async" class="h-11 w-11 shrink-0 object-contain transition-transform duration-200 group-hover/drawer-logo:scale-105" />
        <span class="min-w-0 whitespace-nowrap text-ink">
          <span class="block font-heading text-xl font-extrabold uppercase leading-none tracking-normal">WolfWay</span>
          <span class="mt-1 block font-heading text-sm font-bold uppercase leading-none tracking-normal text-slate-500">Logistics LLC</span>
        </span>
      </a>
      <!-- Close button -->
      <button
        id="mobile-menu-close"
        class="ml-3 flex h-11 w-11 shrink-0 items-center justify-center rounded-sm border border-slate-200 bg-slate-50 text-ink transition-[background-color,border-color,color] duration-200 hover:border-cyan/40 hover:bg-cyan/10 hover:text-cyan-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan/70 focus-visible:outline-offset-2"
        aria-label="Close menu"
      >
        <X class="h-6 w-6" stroke-width={2.25} aria-hidden="true" />
      </button>
    </div>

    <!-- Navigation links -->
    <nav class="flex flex-1 flex-col justify-start gap-2 overflow-y-auto overscroll-contain px-4 py-5" aria-label="Mobile navigation">
      {mainNav.map((item, i) => {
        const isActive = item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href);
        return (
          <a
            href={item.href}
            aria-current={isActive ? 'page' : undefined}
            class:list={[
              "mobile-nav-link group flex min-h-14 items-center justify-between gap-4 rounded-sm border px-4 py-3 transition-[background-color,border-color,color] duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan/70 focus-visible:outline-offset-2",
              isActive
                ? "border-cyan/25 bg-cyan/10 text-navy"
                : "border-transparent text-ink hover:border-slate-200 hover:bg-slate-50"
            ]}
            style={`--i: ${i};`}
          >
            <span class="font-heading text-xl font-extrabold uppercase leading-none tracking-normal">
              {item.label}
            </span>
            <ArrowRight
              class:list={[
                "h-5 w-5 shrink-0 transition-transform duration-200 group-hover:translate-x-1",
                isActive ? "text-cyan-dark" : "text-slate-400 group-hover:text-cyan-dark"
              ]}
              stroke-width={2.25}
              aria-hidden="true"
            />
          </a>
        );
      })}
    </nav>

    <!-- Bottom CTA -->
    <div class="border-t border-slate-200 bg-slate-50 px-5 pb-[max(1.25rem,env(safe-area-inset-bottom))] pt-5">
      <Button
        id="menu-cta"
        href="/driver-application"
        variant="primary"
        size="md"
        class="w-full justify-center rounded-sm font-heading font-extrabold uppercase tracking-normal"
      >
        Apply to Drive
        <ArrowRight class="ml-2.5 h-4 w-4 transition-transform duration-200 group-hover/btn:translate-x-1" stroke-width={2.25} aria-hidden="true" />
      </Button>

      <a href="tel:+12244464256" class="mt-2 flex min-h-12 items-center justify-center gap-2.5 rounded-sm px-3 font-body text-base font-bold text-navy transition-colors duration-200 hover:bg-white hover:text-cyan-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan/70 focus-visible:outline-offset-2">
        <Phone class="h-4 w-4 shrink-0 text-cyan-dark" stroke-width={2.25} aria-hidden="true" />
        +1 (224) 446-4256
      </a>
    </div>
  </div>
</div>

<script>
  function setupHeaderScroll() {
    const header = document.getElementById('site-header');
    if (!header) return;

    const transparentClasses = ['is-transparent', 'bg-transparent', 'py-4', 'border-transparent', 'text-white'];
    const solidClasses = ['is-scrolled', 'backdrop-blur-md', 'bg-white/90', 'py-2', 'border-slate-200/80', 'shadow-xs', 'text-ink'];

    const setTransparent = () => {
      header.classList.remove(...solidClasses);
      header.classList.add(...transparentClasses);
    };

    const setSolid = () => {
      header.classList.remove(...transparentClasses);
      header.classList.add(...solidClasses);
    };

    const hero = document.querySelector('[data-header-overlay="true"]');
    
    if (hero) {
      const heroRect = hero.getBoundingClientRect();
      heroRect.bottom > header.getBoundingClientRect().height && heroRect.top < window.innerHeight ? setTransparent() : setSolid();
      const headerHeight = Math.ceil(header.getBoundingClientRect().height);

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            setTransparent();
          } else {
            setSolid();
          }
        });
      }, {
        threshold: 0,
        rootMargin: `-${headerHeight}px 0px 0px 0px`
      });

      observer.observe(hero);
      
      // Save observer reference to disconnect on view transitions
      (window as any).headerObserver = observer;
    } else {
      setSolid();
    }
  }

  function setupMobileMenu() {
    const menu = document.getElementById('mobile-menu');
    const backdrop = document.getElementById('menu-backdrop');
    const panel = document.getElementById('menu-panel');
    const openBtn = document.getElementById('mobile-menu-open') as HTMLButtonElement | null;
    const closeBtn = document.getElementById('mobile-menu-close') as HTMLButtonElement | null;

    if (!menu || !backdrop || !panel || !openBtn) return;
    if (openBtn.dataset.menuBound === 'true') return;
    openBtn.dataset.menuBound = 'true';

    let isOpen = false;
    let previousBodyOverflow = '';
    const closeDelay = window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 0 : 300;
    const focusableSelector = [
      'a[href]',
      'button:not([disabled])',
      'input:not([disabled])',
      'select:not([disabled])',
      'textarea:not([disabled])',
      '[tabindex]:not([tabindex="-1"])'
    ].join(',');

    function getFocusableMenuItems() {
      return Array.from(panel!.querySelectorAll<HTMLElement>(focusableSelector))
        .filter((item) => item.offsetParent !== null);
    }

    function openMenu() {
      isOpen = true;
      menu!.classList.remove('pointer-events-none');
      menu!.classList.add('pointer-events-auto');
      menu!.setAttribute('aria-hidden', 'false');
      menu!.removeAttribute('inert');
      openBtn!.setAttribute('aria-expanded', 'true');
      
      // Animate backdrop
      backdrop!.classList.remove('opacity-0', 'pointer-events-none');
      backdrop!.classList.add('opacity-100', 'pointer-events-auto');

      // Animate panel
      panel!.classList.remove('translate-x-full');
      panel!.classList.add('translate-x-0');

      previousBodyOverflow = document.body.style.overflow;
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => closeBtn?.focus());
    }

    function closeMenu(restoreFocus = true) {
      isOpen = false;
      openBtn!.setAttribute('aria-expanded', 'false');
      menu!.setAttribute('aria-hidden', 'true');
      menu!.setAttribute('inert', '');
      
      // Animate backdrop out
      backdrop!.classList.remove('opacity-100', 'pointer-events-auto');
      backdrop!.classList.add('opacity-0', 'pointer-events-none');

      // Animate panel out
      panel!.classList.remove('translate-x-0');
      panel!.classList.add('translate-x-full');

      document.body.style.overflow = previousBodyOverflow;
      if (restoreFocus) openBtn!.focus();

      setTimeout(() => {
        if (!isOpen) {
          menu!.classList.remove('pointer-events-auto');
          menu!.classList.add('pointer-events-none');
        }
      }, closeDelay);
    }

    openBtn.addEventListener('click', openMenu);
    closeBtn?.addEventListener('click', () => closeMenu());
    backdrop.addEventListener('click', () => closeMenu());

    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => closeMenu(false));
    });

    document.addEventListener('keydown', e => {
      if (!isOpen) return;

      if (e.key === 'Escape') {
        closeMenu();
        return;
      }

      if (e.key !== 'Tab') return;

      const focusableItems = getFocusableMenuItems();
      const firstItem = focusableItems[0];
      const lastItem = focusableItems[focusableItems.length - 1];
      if (!firstItem || !lastItem) return;

      if (e.shiftKey && document.activeElement === firstItem) {
        e.preventDefault();
        lastItem.focus();
      } else if (!e.shiftKey && document.activeElement === lastItem) {
        e.preventDefault();
        firstItem.focus();
      }
    });
  }

  function setupScrollProgress() {
    const progress = document.getElementById('scroll-progress') as HTMLElement | null;
    if (!progress || progress.dataset.progressBound === 'true') return;
    progress.dataset.progressBound = 'true';

    function updateProgress() {
      const scrollable = document.documentElement.scrollHeight - window.innerHeight;
      const amount = scrollable > 0 ? Math.min(window.scrollY / scrollable, 1) : 0;
      progress!.style.transform = `scaleX(${amount})`;
    }

    updateProgress();
    window.addEventListener('scroll', updateProgress, { passive: true });
    window.addEventListener('resize', updateProgress, { passive: true });
    document.addEventListener('astro:page-load', updateProgress);
  }

  // Initial setup
  setupHeaderScroll();
  setupMobileMenu();
  setupScrollProgress();

  // Astro page-load trigger for persistent header initialization
  document.addEventListener('astro:page-load', () => {
    // Disconnect old observer if any
    if ((window as any).headerObserver) {
      (window as any).headerObserver.disconnect();
    }
    setupHeaderScroll();
    setupMobileMenu();
    setupScrollProgress();
  });
</script>

<style>
  /* Mobile stacked link animations */
  @keyframes mobileLinkIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .translate-x-0 .mobile-nav-link {
    animation: mobileLinkIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(var(--i) * 40ms + 80ms);
  }

  @media (prefers-reduced-motion: reduce) {
    #menu-panel,
    #menu-backdrop,
    .mobile-nav-link,
    .mobile-nav-link svg {
      animation: none !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
