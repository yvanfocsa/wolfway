---
import { mainNav } from '@/content/navigation';
import Button from '@/components/Button.astro';
---

<header id="site-header" class="fixed top-0 left-0 z-50 w-full transition-all duration-300 py-3 lg:py-4">
  <nav class="mx-auto max-w-7xl px-4 sm:px-5 lg:px-10">
    <div
      id="header-inner"
      class="flex items-center justify-between px-4 py-2 lg:px-6 lg:py-2 transition-all duration-300 bg-navy/35 border border-white/5 backdrop-blur-md rounded-xl shadow-lg"
    >
      <!-- Logo & Brand Name -->
      <a href="/" class="relative z-50 flex items-center gap-2.5 group" aria-label="WolfWay Logistics home">
        <img
          id="header-logo"
          src="/images/logo_icon.png"
          alt="WolfWay Logo"
          class="h-14 w-14 sm:h-16 sm:w-16 object-contain transition-all duration-300 group-hover:scale-105"
        />
        <span
          id="header-title"
          class="font-heading text-base sm:text-lg md:text-xl font-extrabold uppercase tracking-widest text-white group-hover:text-cyan transition-all duration-300"
        >
          WolfWay
        </span>
      </a>

      <!-- Desktop Nav Links & CTA -->
      <div class="hidden lg:flex items-center gap-7">
        <div class="flex items-center gap-4">
          {mainNav.map((item) => (
            <a
              href={item.href}
              class="text-[11px] font-medium uppercase tracking-[0.2em] text-white/70 hover:text-white px-2 py-1 transition-all duration-300 relative group/link"
            >
              {item.label}
              <span class="absolute bottom-0 left-2 right-2 h-0.5 bg-cyan scale-x-0 group-hover/link:scale-x-100 transition-transform duration-300 origin-center" aria-hidden="true"></span>
            </a>
          ))}
        </div>
        <Button href="/request-a-quote" variant="primary" size="sm" arrow={true} class="group text-xs py-2 px-4">
          Request a Quote
        </Button>
      </div>

      <!-- Hamburger button (only shows when menu is CLOSED) -->
      <button
        id="mobile-menu-open"
        class="relative z-50 flex h-10 w-10 items-center justify-center lg:hidden rounded-lg bg-white/8 border border-white/10 hover:bg-white/15 active:scale-95 transition-all duration-200"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="sr-only">Open menu</span>
        <div class="flex flex-col gap-[5px]">
          <span class="block h-[2px] w-[18px] bg-white rounded-full"></span>
          <span class="block h-[2px] w-[14px] bg-white/60 rounded-full self-end"></span>
          <span class="block h-[2px] w-[18px] bg-white rounded-full"></span>
        </div>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile menu overlay — rendered OUTSIDE header so it truly covers everything -->
<div
  id="mobile-menu-overlay"
  class="fixed inset-0 z-[60] lg:hidden"
  aria-hidden="true"
  style="pointer-events:none;"
>
  <!-- Backdrop -->
  <div
    id="menu-backdrop"
    class="absolute inset-0 bg-navy/60 backdrop-blur-sm"
    style="opacity:0; transition: opacity 0.4s ease;"
  ></div>

  <!-- Panel — slides in from the right -->
  <div
    id="menu-panel"
    class="absolute top-0 right-0 h-full w-[82vw] max-w-xs flex flex-col"
    style="
      background: linear-gradient(160deg, #141d2e 0%, #0f1520 100%);
      border-left: 1px solid rgba(255,255,255,0.06);
      transform: translateX(100%);
      transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
      box-shadow: -20px 0 60px rgba(0,0,0,0.5);
    "
  >
    <!-- Panel header: logo + close button -->
    <div class="flex items-center justify-between px-6 pt-5 pb-4 border-b border-white/5">
      <a href="/" class="flex items-center gap-2.5" id="menu-logo-link" aria-label="Home">
        <img src="/images/logo_icon.png" alt="WolfWay" class="h-10 w-10 object-contain" />
        <span class="font-heading text-base font-extrabold uppercase tracking-widest text-white">WolfWay</span>
      </a>

      <!-- Close button — prominent X inside the panel -->
      <button
        id="mobile-menu-close"
        class="flex h-10 w-10 items-center justify-center rounded-xl bg-white/5 border border-white/10 hover:bg-red-500/10 hover:border-red-400/30 active:scale-95 transition-all duration-200 group"
        aria-label="Close menu"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M2 2l14 14M16 2L2 16" stroke="white" stroke-width="2" stroke-linecap="round" class="group-hover:stroke-red-400 transition-colors duration-200"/>
        </svg>
      </button>
    </div>

    <!-- Nav links -->
    <nav class="flex-1 flex flex-col justify-center px-6 py-4 gap-0.5" aria-label="Mobile navigation">
      {mainNav.map((item, i) => (
        <a
          href={item.href}
          class="mobile-nav-link group flex items-center justify-between py-4 border-b border-white/5 last:border-0"
          style={`--i: ${i};`}
        >
          <span class="font-heading text-lg font-bold uppercase tracking-wider text-white/70 group-hover:text-white group-active:text-cyan transition-colors duration-200">
            {item.label}
          </span>
          <svg class="h-4 w-4 text-white/20 group-hover:text-cyan group-hover:translate-x-1 transition-all duration-200" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      ))}
    </nav>

    <!-- CTA + Contact -->
    <div class="px-6 pb-8 pt-4 border-t border-white/5 space-y-4">
      <Button
        id="menu-cta"
        href="/request-a-quote"
        variant="primary"
        size="lg"
        arrow={true}
        class="w-full justify-center"
      >
        Request a Quote
      </Button>

      <div class="text-center pt-2">
        <p class="text-[10px] uppercase tracking-[0.2em] text-white/25 font-semibold mb-1.5">Call us anytime</p>
        <a href="tel:+12244464256" class="text-base font-heading font-bold text-white/80 hover:text-cyan transition-colors">
          +1 (224) 446-4256
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  /* ── Elements ── */
  const header   = document.getElementById('site-header');
  const logo     = document.getElementById('header-logo');
  const title    = document.getElementById('header-title');
  const openBtn  = document.getElementById('mobile-menu-open')  as HTMLButtonElement | null;
  const closeBtn = document.getElementById('mobile-menu-close') as HTMLButtonElement | null;
  const overlay  = document.getElementById('mobile-menu-overlay') as HTMLElement | null;
  const backdrop = document.getElementById('menu-backdrop')     as HTMLElement | null;
  const panel    = document.getElementById('menu-panel')        as HTMLElement | null;

  let menuOpen = false;

  /* ── Scroll shrink ── */
  function onScroll() {
    if (!header) return;
    if (window.scrollY > 40) {
      header.classList.add('header-scrolled');
      logo?.classList.remove('h-14','w-14','sm:h-16','sm:w-16');
      logo?.classList.add('h-9','w-9');
      title?.classList.remove('text-base','sm:text-lg','md:text-xl');
      title?.classList.add('text-sm','md:text-base');
    } else {
      header.classList.remove('header-scrolled');
      logo?.classList.add('h-14','w-14','sm:h-16','sm:w-16');
      logo?.classList.remove('h-9','w-9');
      title?.classList.add('text-base','sm:text-lg','md:text-xl');
      title?.classList.remove('text-sm','md:text-base');
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  /* ── Open ── */
  function openMenu() {
    menuOpen = true;
    if (overlay) overlay.style.pointerEvents = 'auto';
    overlay?.setAttribute('aria-hidden','false');
    openBtn?.setAttribute('aria-expanded','true');
    if (backdrop) backdrop.style.opacity = '1';
    if (panel)    panel.style.transform  = 'translateX(0)';
    document.body.style.overflow = 'hidden';
  }

  /* ── Close ── */
  function closeMenu() {
    menuOpen = false;
    if (backdrop) backdrop.style.opacity = '0';
    if (panel)    panel.style.transform  = 'translateX(100%)';
    openBtn?.setAttribute('aria-expanded','false');
    overlay?.setAttribute('aria-hidden','true');
    // wait for animation before removing pointer events
    setTimeout(() => {
      if (!menuOpen && overlay) overlay.style.pointerEvents = 'none';
    }, 450);
    document.body.style.overflow = '';
  }

  /* ── Bind ── */
  openBtn?.addEventListener('click',  openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  // Tap backdrop to close
  backdrop?.addEventListener('click', closeMenu);

  // Close on any nav link click
  overlay?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Escape key
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && menuOpen) closeMenu();
  });
</script>

<style>
  /* Header transitions */
  #site-header { transition: padding 0.4s cubic-bezier(0.16,1,0.3,1); }
  #header-inner { transition: all 0.4s cubic-bezier(0.16,1,0.3,1); }

  :global(.header-scrolled) {
    padding-top: 0.5rem !important;
    padding-bottom: 0.5rem !important;
  }
  :global(.header-scrolled) #header-inner {
    background-color: rgba(17,23,34,0.92);
    border-color: rgba(255,255,255,0.08);
    box-shadow: 0 8px 30px rgba(0,0,0,0.25);
  }

  /* Staggered nav links when panel opens */
  @keyframes linkIn {
    from { opacity: 0; transform: translateX(20px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  #menu-panel[style*="translateX(0)"] .mobile-nav-link {
    animation: linkIn 0.4s cubic-bezier(0.16,1,0.3,1) both;
    animation-delay: calc(var(--i) * 55ms + 200ms);
  }

  /* CTA fade-in */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  #menu-panel[style*="translateX(0)"] #menu-cta {
    animation: fadeUp 0.45s cubic-bezier(0.16,1,0.3,1) both;
    animation-delay: 420ms;
  }
</style>
