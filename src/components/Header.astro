---
import { mainNav } from '@/content/navigation';
import Button from '@/components/Button.astro';

const pathname = new URL(Astro.request.url).pathname;
// Normalize pathname (strip trailing slash if any, except for root)
const currentPath = pathname.endsWith('/') && pathname !== '/' ? pathname.slice(0, -1) : pathname;
---

<div id="scroll-progress" class="fixed left-0 top-0 z-[80] h-0.5 w-full origin-left scale-x-0 bg-cyan shadow-[0_0_20px_rgba(0,168,225,0.45)]" aria-hidden="true"></div>

<header id="site-header" class="fixed top-0 left-0 z-50 w-full transition-all duration-200 border-b select-none py-5 border-transparent bg-transparent text-white group is-transparent">
  <nav class="mx-auto max-w-7xl px-5 lg:px-10 flex items-center justify-between">
    <!-- Logo & Brand Name -->
    <a href="/" class="group/logo flex min-h-11 items-center gap-2.5" aria-label="WolfWay Home" focus-visible>
      <img
        id="header-logo"
        src="/images/logo_icon.png"
        alt="WolfWay Logo"
        width="40"
        height="40"
        class="h-10 w-10 object-contain transition-transform duration-300 group-hover/logo:scale-105"
      />
      <span
        id="header-title"
        class="font-heading text-sm sm:text-base font-extrabold uppercase tracking-wider transition-colors duration-300 text-white group-hover/logo:text-cyan group-[.is-scrolled]:text-ink"
      >
        WolfWay Logistics LLC
      </span>
    </a>

    <!-- Desktop Nav Links & CTA -->
    <div class="hidden lg:flex items-center gap-8">
      <div class="flex items-center gap-5">
        {mainNav.map((item) => {
          const isActive = item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href);
          return (
            <a
              href={item.href}
              class="group/link relative inline-flex min-h-11 items-center rounded-sm px-2.5 py-1.5 font-body text-sm font-bold uppercase tracking-wider text-white/90 transition-colors duration-200 hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan/70 group-[.is-scrolled]:text-slate-700 group-[.is-scrolled]:hover:text-ink"
            >
              {item.label}
              <span 
                class:list={[
                  "absolute bottom-0 left-2.5 right-2.5 h-[2px] bg-cyan transition-transform duration-300 origin-left",
                  isActive ? "scale-x-100" : "scale-x-0 group-hover/link:scale-x-100"
                ]} 
                aria-hidden="true"
              ></span>
            </a>
          );
        })}
      </div>
      <div class="flex items-center gap-4">
        <a
          href="tel:+12244464256"
          class="hidden min-h-11 items-center gap-1.5 font-body text-sm font-bold uppercase tracking-wider text-white/90 transition-colors hover:text-cyan group-[.is-scrolled]:text-ink xl:flex"
        >
          <svg class="w-3.5 h-3.5 text-cyan shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          +1 (224) 446-4256
        </a>
        <Button 
          href="/driver-application" 
          variant="primary" 
          size="sm" 
          class="rounded-sm font-heading font-extrabold tracking-wider uppercase focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan/70"
        >
          Apply to Drive
        </Button>
      </div>
    </div>

    <!-- Mobile Menu Open Toggle -->
    <button
      id="mobile-menu-open"
      class="relative z-50 flex h-11 w-11 items-center justify-center lg:hidden rounded-sm transition-all duration-200 text-white bg-white/5 border border-white/10 hover:bg-white/10 focus-visible:outline-cyan/70 group-[.is-scrolled]:text-ink group-[.is-scrolled]:bg-slate-100 group-[.is-scrolled]:border-slate-200 group-[.is-scrolled]:hover:bg-slate-200/60"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="sr-only">Open menu</span>
      <div class="flex flex-col gap-[5px]">
        <span class="block h-[2px] w-[18px] bg-current rounded-full transition-transform"></span>
        <span class="block h-[2px] w-[12px] bg-current rounded-full transition-all self-end group-hover:w-[18px]"></span>
        <span class="block h-[2px] w-[18px] bg-current rounded-full transition-transform"></span>
      </div>
    </button>
  </nav>
</header>

<!-- Mobile Menu Drawer (Right-side slideout) -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] lg:hidden pointer-events-none"
  aria-hidden="true"
  inert
>
  <!-- Backdrop (dimmer overlay) -->
  <div
    id="menu-backdrop"
    class="absolute inset-0 bg-slate-900/15 backdrop-blur-[2px] opacity-0 transition-opacity duration-300 pointer-events-none"
  ></div>

  <!-- Sliding Drawer Panel -->
  <div
    id="menu-panel"
    class="absolute top-0 right-0 bottom-0 w-[80vw] max-w-[300px] bg-white/90 backdrop-blur-2xl border-l border-slate-200/50 shadow-2xl flex flex-col justify-between translate-x-full transition-transform duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] pointer-events-auto"
    role="dialog"
    aria-modal="true"
    aria-labelledby="mobile-menu-title"
  >
    <!-- Drawer Header -->
    <div class="flex items-center justify-between px-5 pt-6 pb-4 border-b border-slate-100">
      <h2 id="mobile-menu-title" class="sr-only">Mobile navigation</h2>
      <!-- Close button -->
      <button
        id="mobile-menu-close"
        class="ml-auto flex h-11 w-11 items-center justify-center rounded-full bg-slate-100 hover:bg-red-50 hover:text-red-500 transition-colors"
        aria-label="Close menu"
      >
        <svg width="12" height="12" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M2 2l14 14M16 2L2 16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <!-- Navigation links -->
    <nav class="flex-1 flex flex-col justify-start px-5 py-6 gap-1" aria-label="Mobile navigation">
      {mainNav.map((item, i) => {
        const isActive = item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href);
        return (
          <a
            href={item.href}
            class="mobile-nav-link group flex items-center justify-between py-3 px-4 rounded-xl transition-all duration-200 hover:bg-slate-50"
            style={`--i: ${i};`}
          >
            <span class:list={[
              "font-heading text-lg font-bold uppercase tracking-wider transition-colors",
              isActive ? "text-cyan" : "text-ink/80 group-hover:text-ink"
            ]}>
              {item.label}
            </span>
            <svg class:list={[
              "w-4 h-4 transition-transform group-hover:translate-x-1",
              isActive ? "text-cyan" : "text-slate-400"
            ]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        );
      })}
    </nav>

    <!-- Bottom CTA -->
    <div class="px-5 pb-8 pt-4 border-t border-slate-100 space-y-4">
      <Button
        id="menu-cta"
        href="/driver-application"
        variant="primary"
        size="md"
        arrow={true}
        class="w-full justify-center rounded-lg uppercase tracking-wider font-heading font-extrabold"
      >
        Apply to Drive
      </Button>

      <div class="text-center">
        <p class="text-xs uppercase tracking-[0.2em] text-slate-400 font-bold mb-1 font-body">Speak with dispatch</p>
        <a href="tel:+12244464256" class="inline-flex min-h-11 items-center text-sm font-heading font-bold uppercase tracking-wider text-ink hover:text-cyan transition-colors">
          +1 (224) 446-4256
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  function setupHeaderScroll() {
    const header = document.getElementById('site-header');
    if (!header) return;

    // Check if the current page has a Hero section
    const hero = document.querySelector('section.relative.h-\\[100svh\\], section.relative.h-\\[100dvh\\], #hero-bg-container');
    
    if (hero) {
      // Use IntersectionObserver to track scroll state dynamically
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            header.classList.remove('is-scrolled', 'backdrop-blur-md', 'bg-white/90', 'py-3', 'border-slate-200/80', 'shadow-xs', 'text-ink');
            header.classList.add('is-transparent', 'bg-transparent', 'py-5', 'border-transparent', 'text-white');
          } else {
            header.classList.remove('is-transparent', 'bg-transparent', 'py-5', 'border-transparent', 'text-white');
            header.classList.add('is-scrolled', 'backdrop-blur-md', 'bg-white/90', 'py-3', 'border-slate-200/80', 'shadow-xs', 'text-ink');
          }
        });
      }, {
        threshold: 0,
        rootMargin: '-80px 0px 0px 0px' // Trigger slightly before scrolling past header height
      });

      observer.observe(hero);
      
      // Save observer reference to disconnect on view transitions
      (window as any).headerObserver = observer;
    } else {
      // No hero exists: immediately set scrolled state
      header.classList.remove('is-transparent', 'bg-transparent', 'py-5', 'border-transparent', 'text-white');
      header.classList.add('is-scrolled', 'backdrop-blur-md', 'bg-white/90', 'py-3', 'border-slate-200/80', 'shadow-xs', 'text-ink');
    }
  }

  function setupMobileMenu() {
    const menu = document.getElementById('mobile-menu');
    const backdrop = document.getElementById('menu-backdrop');
    const panel = document.getElementById('menu-panel');
    const openBtn = document.getElementById('mobile-menu-open') as HTMLButtonElement | null;
    const closeBtn = document.getElementById('mobile-menu-close') as HTMLButtonElement | null;

    if (!menu || !backdrop || !panel || !openBtn) return;
    if (openBtn.dataset.menuBound === 'true') return;
    openBtn.dataset.menuBound = 'true';

    let isOpen = false;
    const focusableSelector = [
      'a[href]',
      'button:not([disabled])',
      'input:not([disabled])',
      'select:not([disabled])',
      'textarea:not([disabled])',
      '[tabindex]:not([tabindex="-1"])'
    ].join(',');

    function getFocusableMenuItems() {
      return Array.from(panel!.querySelectorAll<HTMLElement>(focusableSelector))
        .filter((item) => item.offsetParent !== null);
    }

    function openMenu() {
      isOpen = true;
      menu!.classList.remove('pointer-events-none');
      menu!.classList.add('pointer-events-auto');
      menu!.setAttribute('aria-hidden', 'false');
      menu!.removeAttribute('inert');
      openBtn!.setAttribute('aria-expanded', 'true');
      
      // Animate backdrop
      backdrop!.classList.remove('opacity-0', 'pointer-events-none');
      backdrop!.classList.add('opacity-100', 'pointer-events-auto');

      // Animate panel
      panel!.classList.remove('translate-x-full');
      panel!.classList.add('translate-x-0');

      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => closeBtn?.focus());
    }

    function closeMenu(restoreFocus = true) {
      isOpen = false;
      openBtn!.setAttribute('aria-expanded', 'false');
      menu!.setAttribute('aria-hidden', 'true');
      menu!.setAttribute('inert', '');
      
      // Animate backdrop out
      backdrop!.classList.remove('opacity-100', 'pointer-events-auto');
      backdrop!.classList.add('opacity-0', 'pointer-events-none');

      // Animate panel out
      panel!.classList.remove('translate-x-0');
      panel!.classList.add('translate-x-full');

      document.body.style.overflow = '';
      if (restoreFocus) openBtn!.focus();

      setTimeout(() => {
        if (!isOpen) {
          menu!.classList.remove('pointer-events-auto');
          menu!.classList.add('pointer-events-none');
        }
      }, 300);
    }

    openBtn.addEventListener('click', openMenu);
    closeBtn?.addEventListener('click', () => closeMenu());
    backdrop.addEventListener('click', () => closeMenu());

    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => closeMenu(false));
    });

    document.addEventListener('keydown', e => {
      if (!isOpen) return;

      if (e.key === 'Escape') {
        closeMenu();
        return;
      }

      if (e.key !== 'Tab') return;

      const focusableItems = getFocusableMenuItems();
      const firstItem = focusableItems[0];
      const lastItem = focusableItems[focusableItems.length - 1];
      if (!firstItem || !lastItem) return;

      if (e.shiftKey && document.activeElement === firstItem) {
        e.preventDefault();
        lastItem.focus();
      } else if (!e.shiftKey && document.activeElement === lastItem) {
        e.preventDefault();
        firstItem.focus();
      }
    });
  }

  function setupScrollProgress() {
    const progress = document.getElementById('scroll-progress') as HTMLElement | null;
    if (!progress || progress.dataset.progressBound === 'true') return;
    progress.dataset.progressBound = 'true';

    function updateProgress() {
      const scrollable = document.documentElement.scrollHeight - window.innerHeight;
      const amount = scrollable > 0 ? Math.min(window.scrollY / scrollable, 1) : 0;
      progress!.style.transform = `scaleX(${amount})`;
    }

    updateProgress();
    window.addEventListener('scroll', updateProgress, { passive: true });
    window.addEventListener('resize', updateProgress, { passive: true });
    document.addEventListener('astro:page-load', updateProgress);
  }

  // Initial setup
  setupHeaderScroll();
  setupMobileMenu();
  setupScrollProgress();

  // Astro page-load trigger for persistent header initialization
  document.addEventListener('astro:page-load', () => {
    // Disconnect old observer if any
    if ((window as any).headerObserver) {
      (window as any).headerObserver.disconnect();
    }
    setupHeaderScroll();
    setupMobileMenu();
    setupScrollProgress();
  });
</script>

<style>
  /* Mobile stacked link animations */
  @keyframes mobileLinkIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .translate-x-0 .mobile-nav-link {
    animation: mobileLinkIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(var(--i) * 40ms + 80ms);
  }
</style>
