---
import Button from './Button.astro';
---

<section class="relative h-[100svh] min-h-[600px] lg:h-[100dvh] flex items-center overflow-hidden bg-navy">
  <!-- Video background -->
  <div class="absolute inset-0 z-0">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      class="h-full w-full object-cover"
      aria-hidden="true"
    >
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>
    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-navy/80"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-7xl px-5 lg:px-10 pt-28 sm:pt-24 pb-10 w-full flex flex-col justify-center h-full">
    <div class="max-w-3xl">
      <!-- H1 -->
      <div class="overflow-hidden mb-5 lg:mb-8">
        <h1
          id="hero-heading"
          class="font-heading text-[2.6rem] leading-[0.93] sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-extrabold uppercase text-white tracking-tight"
        >
          Open-deck freight,<br />handled right.
        </h1>
      </div>

      <!-- Body content -->
      <div class="space-y-5 lg:space-y-8">
        <!-- Description -->
        <p class="text-sm sm:text-base md:text-lg leading-relaxed text-white/75 max-w-xl font-body font-light">
          Reliable flatbed, step deck and open-deck transportation built around safety, communication and dependable delivery.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col xs:flex-row sm:flex-row gap-3 sm:gap-4 pt-1">
          <Button variant="primary" href="/request-a-quote" size="lg" arrow={true} class="group w-full sm:w-auto justify-center">
            Request a Quote
          </Button>
          <Button variant="secondary" href="/drive-with-us" size="lg" class="w-full sm:w-auto justify-center">
            Drive With Us
          </Button>
        </div>

        <!-- Phone contact -->
        <p class="text-xs text-white/50 font-body pt-1 flex items-center gap-1.5">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
          Or speak with dispatch: 
          <a href="tel:+12244464256" class="text-white/80 hover:text-cyan transition-colors font-semibold">
            +1 (224) 446-4256
          </a>
        </p>
      </div>
    </div>
  </div>

  <!-- Bottom gradient fade to blend with off-white next section -->
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-[#F5F7FA] to-transparent z-10 pointer-events-none" aria-hidden="true"></div>

  <!-- Animated Scroll Down Indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 pointer-events-none animate-bounce hidden sm:block" aria-hidden="true">
    <svg class="h-6 w-6 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
