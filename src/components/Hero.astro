---
import Button from './Button.astro';
---

<section class="relative h-[100svh] min-h-[600px] lg:h-[100dvh] flex items-center overflow-hidden bg-navy select-none">
  <!-- Video / Image background container -->
  <div class="absolute inset-0 z-0 bg-navy" id="hero-bg-container">
    <!-- Inline Video element for instant browser parsing and preloading -->
    <video
      id="hero-video"
      class="absolute inset-0 h-full w-full object-cover z-0"
      muted
      loop
      playsinline
      preload="auto"
      aria-hidden="true"
    >
      <source src="/videos/hero.webm" type="video/webm" />
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>
    <!-- Dark overlay for text readability -->
    <div class="absolute inset-0 bg-navy/60 z-10" id="hero-overlay"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-7xl px-5 lg:px-10 pt-28 sm:pt-24 pb-10 w-full flex flex-col justify-center h-full">
    <div class="max-w-3xl">
      <!-- Eyebrow -->
      <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-cyan mb-4 animate-fade-in" id="hero-eyebrow">
        OPEN-DECK FREIGHT TRANSPORTATION
      </p>

      <!-- H1 -->
      <div class="overflow-hidden mb-5 lg:mb-8">
        <h1
          id="hero-heading"
          class="font-heading text-[2.6rem] leading-[0.93] sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-extrabold uppercase text-white tracking-tight"
        >
          When the load demands more, the details matter.
        </h1>
      </div>

      <!-- Body content -->
      <div class="space-y-6 lg:space-y-8 animate-fade-in" id="hero-body-content">
        <!-- Description -->
        <p class="text-sm sm:text-base md:text-lg leading-relaxed text-white/75 max-w-xl font-body font-light">
          Flatbed, step deck and open-deck freight handled with clear communication from pickup to delivery.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col xs:flex-row sm:flex-row gap-3 sm:gap-4 pt-1">
          <Button variant="primary" href="/request-a-quote" size="lg" arrow={true} class="group w-full sm:w-auto justify-center">
            REQUEST A FREIGHT QUOTE
          </Button>
          <Button variant="outline" href="/carrier" size="lg" class="w-full sm:w-auto justify-center">
            BECOME A CARRIER PARTNER
          </Button>
        </div>

        <!-- Phone contact -->
        <p class="text-xs text-white/50 font-body pt-1 flex items-center gap-1.5">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
          Or speak with dispatch: 
          <a href="tel:+12244464256" class="text-white/80 hover:text-cyan transition-colors font-semibold">
            +1 (224) 446-4256
          </a>
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  function initHeroVideo() {
    const videoEl = document.getElementById('hero-video') as HTMLVideoElement | null;
    
    // Reset state for page transitions
    (window as any).heroVideoReady = false;

    function triggerVideoReady() {
      if ((window as any).heroVideoReady) return;
      (window as any).heroVideoReady = true;
      document.dispatchEvent(new CustomEvent('hero-video-ready'));
    }

    if (!videoEl) {
      triggerVideoReady();
      return;
    }

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobile = window.innerWidth < 768;

    // Direct playback for instant display if autoplay is allowed
    if (!prefersReducedMotion && !isMobile) {
      videoEl.style.display = 'block';

      // Fallback timeout in case video loading is slow
      const fallback = setTimeout(() => {
        triggerVideoReady();
      }, 700);

      videoEl.addEventListener('playing', () => {
        clearTimeout(fallback);
        triggerVideoReady();
      }, { once: true });

      videoEl.play().catch(() => {
        clearTimeout(fallback);
        triggerVideoReady();
      });
    } else {
      // Pause and hide video element on mobile or reduced motion to save resources
      videoEl.pause();
      videoEl.style.display = 'none';
      triggerVideoReady();
    }
  }

  // Initial load
  initHeroVideo();

  // Re-run on View Transitions page nav
  document.addEventListener('astro:page-load', initHeroVideo);
</script>
