---
import Button from './Button.astro';
---

<section data-header-overlay="true" class="relative h-[100svh] min-h-[600px] lg:h-[100dvh] flex items-center overflow-hidden bg-navy select-none">
  <!-- Video / Image background container -->
  <div class="absolute inset-0 z-0 bg-navy" id="hero-bg-container">
    <!-- Inline Video element for instant browser parsing and preloading -->
    <video
      id="hero-video"
      class="absolute inset-0 h-full w-full object-cover z-0"
      muted
      loop
      playsinline
      preload="none"
      poster="/images/services/open-deck-v2-960.avif"
      aria-hidden="true"
    >
      <source src="/videos/hero-mobile-v3.mp4" type="video/mp4" media="(max-width: 767px)" />
      <source src="/videos/hero-v3.mp4" type="video/mp4" />
    </video>
    <!-- Dark overlay for text readability -->
    <div class="absolute inset-0 bg-navy/60 z-10" id="hero-overlay"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-7xl px-5 lg:px-10 pt-28 sm:pt-24 pb-12 w-full flex flex-col justify-center h-full">
    <div class="max-w-3xl space-y-5 sm:space-y-8">
      <!-- H1 -->
      <div class="overflow-hidden">
        <h1
          id="hero-heading"
          class="font-heading text-[2.2rem] sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-extrabold uppercase text-white tracking-normal leading-[1.02] sm:leading-[0.93]"
        >
          When the load demands more, the details matter.
        </h1>
      </div>

      <!-- Body content -->
      <div class="space-y-5 sm:space-y-8" id="hero-body-content">
        <!-- Description -->
        <p class="text-base sm:text-lg md:text-xl leading-relaxed text-white/85 max-w-2xl font-body font-normal">
          Flatbed, step deck and open-deck freight handled with clear communication from pickup to delivery.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 pt-1">
          <Button variant="primary" href="/request-a-quote" size="lg" arrow={true} class="group w-full sm:w-auto justify-center font-heading font-extrabold tracking-[0.1em]">
            SHIP FREIGHT
          </Button>
          <Button variant="outline" href="/driver-application" size="lg" class="w-full sm:w-auto justify-center font-heading font-extrabold tracking-[0.1em]">
            APPLY TO DRIVE
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initHeroVideo() {
    const videoEl = document.getElementById('hero-video') as HTMLVideoElement | null;
    if (!videoEl) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!prefersReducedMotion) {
      videoEl.style.display = 'block';
      const startPlayback = () => {
        window.setTimeout(() => {
          videoEl.play().catch(() => {
            // The optimized poster remains visible if autoplay is unavailable.
          });
        }, 600);
      };

      if (document.readyState === 'complete') {
        startPlayback();
      } else {
        window.addEventListener('load', startPlayback, { once: true });
      }
    } else {
      // Pause and hide video element on reduced motion to save resources
      videoEl.pause();
      videoEl.style.display = 'none';
    }
  }

  // Re-run on View Transitions page nav
  document.addEventListener('astro:page-load', initHeroVideo);
</script>

<style>
  #hero-body-content {
    animation: hero-reveal 550ms 80ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes hero-reveal {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #hero-body-content {
      animation: none;
    }
  }
</style>
