---
const assurances = [
  {
    lead: 'Always on',
    detail: '24/7 dispatch support',
  },
  {
    lead: 'Purpose built',
    detail: 'Open-deck focused',
  },
  {
    lead: 'Nationwide',
    detail: '48-state coordination',
  },
  {
    lead: 'Responsive',
    detail: 'Quote review in under 1 hour',
  },
];
---

<section class="relative z-20 border-y border-slate-200 bg-white" aria-label="WolfWay service assurances">
  <div class="mx-auto max-w-7xl px-5 lg:px-10">
    <ul class="grid sm:grid-cols-2 lg:grid-cols-4" role="list">
      {assurances.map((item) => (
        <li class="flex min-h-28 items-center gap-4 border-b border-slate-200 py-6 last:border-b-0 sm:px-6 sm:[&:nth-child(odd)]:border-r lg:border-b-0 lg:border-r lg:first:pl-0 lg:last:border-r-0 lg:last:pr-0">
          <span class="h-2.5 w-2.5 shrink-0 bg-cyan" aria-hidden="true"></span>
          <div>
            <p class="font-heading text-xl font-extrabold uppercase leading-none text-ink">{item.lead}</p>
            <p class="mt-1 text-base font-semibold leading-snug text-slate-600">{item.detail}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
