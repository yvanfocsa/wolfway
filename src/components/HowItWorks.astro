---
// src/components/HowItWorks.astro
---

<section class="bg-offwhite py-16 sm:py-20 lg:py-24 select-none" data-animate="fade-up">
  <div class="mx-auto max-w-7xl px-5 lg:px-10">
    <!-- Section Header -->
    <div class="mb-12 sm:mb-16">
      <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-[#005F8A] mb-3">
        LOGISTICS FLOW
      </p>
      <h2 class="font-heading text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold uppercase text-ink">
        How it works
      </h2>
    </div>

    <!-- Steps Grid -->
    <div class="grid gap-10 md:grid-cols-3 relative">
      <!-- Step 1 -->
      <div class="relative flex flex-col group">
        <div class="flex items-baseline justify-between mb-4">
          <span class="font-heading text-6xl lg:text-7xl font-extrabold text-slate-500 group-hover:text-cyan/30 transition-colors duration-300 leading-none">
            01
          </span>
          <!-- Arrow for desktop connecting to step 2 -->
          <span class="hidden md:block text-slate-300 text-2xl font-bold font-mono tracking-widest pointer-events-none pr-8">
            &rarr;
          </span>
        </div>
        <h3 class="font-heading text-lg sm:text-xl font-bold uppercase tracking-wide text-ink">
          Share your load details
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-slate-600 font-body font-light">
          Submit freight specifications including origin, destination, cargo weight, dimensions, and preferred pick-up schedule.
        </p>
      </div>

      <!-- Step 2 -->
      <div class="relative flex flex-col group">
        <div class="flex items-baseline justify-between mb-4">
          <span class="font-heading text-6xl lg:text-7xl font-extrabold text-slate-500 group-hover:text-cyan/30 transition-colors duration-300 leading-none">
            02
          </span>
          <!-- Arrow for desktop connecting to step 3 -->
          <span class="hidden md:block text-slate-300 text-2xl font-bold font-mono tracking-widest pointer-events-none pr-8">
            &rarr;
          </span>
        </div>
        <h3 class="font-heading text-lg sm:text-xl font-bold uppercase tracking-wide text-ink">
          Confirm the right equipment
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-slate-600 font-body font-light">
          Our dispatch team reviews the cargo load specs to match flatbed, step deck, or specialized open-deck trailer configurations.
        </p>
      </div>

      <!-- Step 3 -->
      <div class="relative flex flex-col group">
        <div class="flex items-baseline justify-between mb-4">
          <span class="font-heading text-6xl lg:text-7xl font-extrabold text-slate-500 group-hover:text-cyan/30 transition-colors duration-300 leading-none">
            03
          </span>
        </div>
        <h3 class="font-heading text-lg sm:text-xl font-bold uppercase tracking-wide text-ink">
          Move with confidence
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-slate-600 font-body font-light">
          Your shipment moves with clear carrier coordination, route plan securement, and professional communication from dispatch.
        </p>
      </div>
    </div>
  </div>
</section>
