---
// src/components/HowItWorks.astro
---

<section class="bg-offwhite py-16 sm:py-20 lg:py-24 select-none" data-animate="fade-up">
  <div class="mx-auto max-w-7xl px-5 lg:px-10">
    <!-- Section Header -->
    <div class="mb-12 sm:mb-16 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-[#005F8A] mb-3">
          STREAMLINED PROCESS
        </p>
        <h2 class="font-heading text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold uppercase text-ink">
          From quote to rolling, fast
        </h2>
      </div>
      <p class="text-sm text-slate-500 max-w-md font-body font-light">
        No 30-minute forms or call centers. Experience transparent communication and fast dispatch matching from day one.
      </p>
    </div>

    <!-- Steps Grid -->
    <div class="grid gap-8 md:grid-cols-3 relative">
      <!-- Step 1 -->
      <div class="relative flex flex-col p-8 bg-white border border-slate-200/70 rounded-xl shadow-xs group hover:border-cyan/40 transition-colors">
        <div class="flex items-baseline justify-between mb-4">
          <span class="font-heading text-5xl font-extrabold text-cyan leading-none">
            01
          </span>
          <span class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 bg-slate-100 text-slate-600 rounded">30 SECONDS</span>
        </div>
        <h3 class="font-heading text-xl font-bold uppercase tracking-wide text-ink">
          Pre-qualify or Share Load
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-slate-600 font-body font-light">
          Submit basic cargo dimensions or driver qualifications in a few quick taps without lengthy forms required.
        </p>
      </div>

      <!-- Step 2 -->
      <div class="relative flex flex-col p-8 bg-white border border-slate-200/70 rounded-xl shadow-xs group hover:border-cyan/40 transition-colors">
        <div class="flex items-baseline justify-between mb-4">
          <span class="font-heading text-5xl font-extrabold text-cyan leading-none">
            02
          </span>
          <span class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 bg-slate-100 text-slate-600 rounded">DIRECT CONTACT</span>
        </div>
        <h3 class="font-heading text-xl font-bold uppercase tracking-wide text-ink">
          Talk to Real Dispatch
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-slate-600 font-body font-light">
          A dedicated WolfWay dispatch coordinator or recruiter reviews your request and connects directly by phone or text.
        </p>
      </div>

      <!-- Step 3 -->
      <div class="relative flex flex-col p-8 bg-white border border-slate-200/70 rounded-xl shadow-xs group hover:border-cyan/40 transition-colors">
        <div class="flex items-baseline justify-between mb-4">
          <span class="font-heading text-5xl font-extrabold text-cyan leading-none">
            03
          </span>
          <span class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 bg-emerald-50 text-emerald-700 rounded">LOADED & ROLL</span>
        </div>
        <h3 class="font-heading text-xl font-bold uppercase tracking-wide text-ink">
          Move Freight Safely
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-slate-600 font-body font-light">
          Your cargo rolls on air-ride equipment with end-to-end updates and 24/7 support every mile of the journey.
        </p>
      </div>
    </div>
  </div>
</section>
