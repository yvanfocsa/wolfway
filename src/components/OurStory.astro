---
import Button from './Button.astro';

const operatingStandards = [
  {
    title: 'Safety-first culture',
    description: 'Carrier review, securement planning, and equipment checks happen before a load is assigned.',
  },
  {
    title: 'Human dispatch',
    description: 'Real coordinators stay available around the clock and know the status of the freight they manage.',
  },
  {
    title: 'Focused intake',
    description: 'Shippers share the lane and load details first, without fighting through an oversized general form.',
  },
  {
    title: 'Prepared equipment',
    description: 'Flatbed and step-deck capacity is matched to dimensions, loading method, and delivery constraints.',
  },
];
---

<section class="border-b border-slate-200/70 bg-offwhite py-16 sm:py-20 lg:py-24">
  <div class="mx-auto max-w-7xl px-5 lg:px-10">
    <div class="grid items-start gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-7">
        <h2 class="max-w-3xl font-heading text-3xl font-extrabold uppercase leading-tight text-ink sm:text-4xl lg:text-5xl">
          Built around the people behind the wheel
        </h2>
        <p class="mt-6 max-w-3xl text-base font-normal leading-relaxed text-slate-700 sm:text-lg">
          WolfWay Logistics LLC was founded with a direct understanding of open-deck transportation: drivers need respect, shippers need honest updates, and every load needs careful planning before the first mile.
        </p>
        <p class="mt-5 max-w-3xl text-base font-normal leading-relaxed text-slate-600">
          From standard flatbed freight to complex step-deck and over-dimensional moves, our coordinators keep shippers and drivers aligned from pickup through delivery.
        </p>

        <div class="mt-8 flex flex-wrap gap-4">
          <Button href="/contact" variant="secondary" size="md" class="border-slate-300 text-ink hover:bg-slate-100">
            Contact Our Team
          </Button>
          <Button href="/drive-with-us" variant="primary" size="md" arrow={true}>
            Explore Driver Careers
          </Button>
        </div>
      </div>

      <div class="lg:col-span-5">
        <h3 class="font-heading text-xl font-extrabold uppercase text-ink">Operating standards</h3>
        <div class="mt-4 border-y border-slate-300">
          {operatingStandards.map((item) => (
            <article class="grid gap-2 border-b border-slate-200 py-5 last:border-b-0 sm:grid-cols-[10rem_1fr] sm:gap-5">
              <h4 class="font-heading text-lg font-bold uppercase leading-tight text-ink">{item.title}</h4>
              <p class="text-base leading-relaxed text-slate-600">{item.description}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
