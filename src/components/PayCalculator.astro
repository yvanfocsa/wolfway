---
// src/components/PayCalculator.astro
---

<div class="bg-white border border-slate-200/60 p-8 sm:p-10 rounded-sm shadow-sm relative select-none">
  <!-- Calculator Card -->
  <div class="space-y-6">
    <!-- Tab toggles -->
    <div>
      <span class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-3 font-body">
        Select Driver Class
      </span>
      <div class="grid grid-cols-2 gap-3">
        <button
          type="button"
          id="calc-btn-company"
          class="py-3 px-4 text-xs font-bold uppercase tracking-wider border border-cyan bg-cyan/5 text-cyan rounded-sm transition-all cursor-pointer text-center font-heading"
        >
          Company Driver
        </button>
        <button
          type="button"
          id="calc-btn-owner"
          class="py-3 px-4 text-xs font-bold uppercase tracking-wider border border-slate-200 hover:border-slate-300 text-slate-700 rounded-sm transition-all cursor-pointer text-center font-heading"
        >
          Owner Operator
        </button>
      </div>
    </div>

    <!-- Slider -->
    <div>
      <div class="flex justify-between items-center mb-2">
        <span class="text-xs font-bold uppercase tracking-wider text-slate-700 font-body">
          Expected Weekly Miles
        </span>
        <span id="calc-miles-display" class="text-sm font-bold text-ink font-heading tracking-wide">
          2,500 miles
        </span>
      </div>
      <input
        type="range"
        id="calc-slider"
        min="1500"
        max="3500"
        value="2500"
        step="100"
        class="w-full h-1.5 bg-slate-100 rounded-lg appearance-none cursor-pointer accent-cyan focus:outline-none"
      />
      <div class="flex justify-between text-[10px] text-slate-400 font-body mt-1">
        <span>1,500 mi</span>
        <span>2,500 mi</span>
        <span>3,500 mi</span>
      </div>
    </div>

    <!-- Earnings Display Grid -->
    <div class="grid grid-cols-2 gap-4 border-t border-slate-100 pt-6">
      <div class="bg-slate-50 p-4 border border-slate-100 rounded-sm">
        <span class="block text-[10px] font-bold uppercase tracking-wider text-slate-600 mb-1 font-body">
          Est. Weekly Gross
        </span>
        <span id="calc-weekly-display" class="text-xl sm:text-2xl font-bold font-heading text-ink tracking-wide">
          $1,700
        </span>
      </div>
      <div class="bg-slate-50 p-4 border border-slate-100 rounded-sm">
        <span class="block text-[10px] font-bold uppercase tracking-wider text-slate-600 mb-1 font-body">
          Est. Annual Gross
        </span>
        <span id="calc-annual-display" class="text-xl sm:text-2xl font-bold font-heading text-[#005F8A] tracking-wide">
          $85,000
        </span>
      </div>
    </div>

    <!-- Dynamic Note -->
    <p class="text-[11px] text-slate-500 font-body leading-relaxed font-light">
      * Estimate based on <span id="calc-rate-display">$0.68 / mile</span>. Actual earnings vary based on routes, accessory pays (tarping, stops), and fuel surcharge variations.
    </p>

    <!-- Scroll down button -->
    <a
      href="#driver-form-container"
      class="group flex items-center justify-between w-full p-4 border border-slate-200 bg-slate-50/20 hover:bg-slate-50 hover:border-cyan/30 rounded-sm transition-all duration-300"
    >
      <span class="text-xs font-bold uppercase tracking-wider text-slate-700 group-hover:text-cyan transition-colors">
        Start your application below
      </span>
      <svg class="h-4 w-4 text-slate-400 group-hover:text-cyan group-hover:translate-y-0.5 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 13l-7 7-7-7m14-6l-7 7-7-7" />
      </svg>
    </a>
  </div>
</div>

<script>
  let driverType = 'company'; // 'company' or 'owner'
  const companyRate = 0.68;
  const ownerRate = 2.55; // Net after business percentages

  const btnCompany = document.getElementById('calc-btn-company');
  const btnOwner = document.getElementById('calc-btn-owner');
  const slider = document.getElementById('calc-slider') as HTMLInputElement | null;
  const milesDisplay = document.getElementById('calc-miles-display');
  const weeklyDisplay = document.getElementById('calc-weekly-display');
  const annualDisplay = document.getElementById('calc-annual-display');
  const rateDisplay = document.getElementById('calc-rate-display');

  function calculate() {
    if (!slider || !milesDisplay || !weeklyDisplay || !annualDisplay || !rateDisplay) return;

    const miles = parseInt(slider.value, 10);
    const rate = driverType === 'company' ? companyRate : ownerRate;
    
    // Format miles
    milesDisplay.textContent = `${miles.toLocaleString()} miles`;
    
    // Calculations
    const weekly = Math.round(miles * rate);
    const annual = weekly * 50; // 50 working weeks

    weeklyDisplay.textContent = `$${weekly.toLocaleString()}`;
    annualDisplay.textContent = `$${annual.toLocaleString()}`;
    rateDisplay.textContent = `$${rate.toFixed(2)} / mile`;
  }

  if (btnCompany && btnOwner && slider) {
    btnCompany.addEventListener('click', () => {
      driverType = 'company';
      btnCompany.className = 'py-3 px-4 text-xs font-bold uppercase tracking-wider border border-cyan bg-cyan/5 text-cyan rounded-sm transition-all cursor-pointer text-center font-heading';
      btnOwner.className = 'py-3 px-4 text-xs font-bold uppercase tracking-wider border border-slate-200 hover:border-slate-300 text-slate-700 rounded-sm transition-all cursor-pointer text-center font-heading';
      calculate();
    });

    btnOwner.addEventListener('click', () => {
      driverType = 'owner';
      btnOwner.className = 'py-3 px-4 text-xs font-bold uppercase tracking-wider border border-cyan bg-cyan/5 text-cyan rounded-sm transition-all cursor-pointer text-center font-heading';
      btnCompany.className = 'py-3 px-4 text-xs font-bold uppercase tracking-wider border border-slate-200 hover:border-slate-300 text-slate-700 rounded-sm transition-all cursor-pointer text-center font-heading';
      calculate();
    });

    slider.addEventListener('input', calculate);
    
    // Initialize
    calculate();
    document.addEventListener('astro:page-load', calculate);
  }
</script>
