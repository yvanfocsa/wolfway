---
// src/components/ProcessRouteLine.astro
---

<div class="hidden lg:block bg-offwhite py-12 border-b border-slate-100 overflow-hidden select-none" id="process-route-section">
  <div class="mx-auto max-w-5xl px-10 relative">
    <!-- SVG Route Line -->
    <svg 
      class="w-full h-24 text-cyan" 
      viewBox="0 0 1000 100" 
      fill="none" 
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <!-- Background track (Opacity 5%) -->
      <path 
        d="M 50 50 Q 275 10, 500 50 T 950 50" 
        stroke="currentColor" 
        stroke-width="2" 
        stroke-linecap="round" 
        class="opacity-5"
      />
      <!-- Animated path (Opacity 20%) -->
      <path 
        id="route-animated-path"
        d="M 50 50 Q 275 10, 500 50 T 950 50" 
        stroke="currentColor" 
        stroke-width="2" 
        stroke-linecap="round" 
        stroke-dasharray="1000"
        stroke-dashoffset="1000"
        class="opacity-20"
      />
      
      <!-- Nodes -->
      <circle cx="50" cy="50" r="5" fill="#0B132B" stroke="currentColor" stroke-width="2" />
      <circle cx="500" cy="50" r="5" fill="#0B132B" stroke="currentColor" stroke-width="2" />
      <circle cx="950" cy="50" r="5" fill="#0B132B" stroke="currentColor" stroke-width="2" />
    </svg>

    <!-- Labels -->
    <div class="absolute inset-x-10 top-[70px] flex justify-between text-xs font-mono tracking-widest text-slate-500 uppercase">
      <div class="w-1/3 text-left pl-2">
        <span class="block font-bold text-ink">SHARE YOUR LOAD</span>
      </div>
      <div class="w-1/3 text-center">
        <span class="block font-bold text-ink">COORDINATION</span>
      </div>
      <div class="w-1/3 text-right pr-2">
        <span class="block font-bold text-ink">DELIVERY</span>
      </div>
    </div>
  </div>
</div>
