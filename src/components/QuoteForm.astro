---
import Button from './Button.astro';

const freightTypes = [
  'Flatbed',
  'Step Deck',
  'Open Deck',
  'Other',
];
---

<form id="quote-form" class="space-y-6" novalidate>
  <input type="hidden" name="formType" value="quote" />
  
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <!-- Name -->
    <div>
      <label for="quote-name" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
        Full Name <span class="text-cyan font-bold">*</span>
      </label>
      <input
        type="text"
        id="quote-name"
        name="name"
        required
        autocomplete="name"
        class="w-full border border-slate-200 bg-slate-50/30 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
        placeholder="John Doe"
      />
      <p class="form-error mt-1.5 text-xs text-red-500 hidden">Please enter your name.</p>
    </div>

    <!-- Company -->
    <div>
      <label for="quote-company" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
        Company Name
      </label>
      <input
        type="text"
        id="quote-company"
        name="company"
        autocomplete="organization"
        class="w-full border border-slate-200 bg-slate-50/30 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
        placeholder="Company name"
      />
    </div>

    <!-- Phone -->
    <div>
      <label for="quote-phone" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
        Phone <span class="text-cyan font-bold">*</span>
      </label>
      <input
        type="tel"
        id="quote-phone"
        name="phone"
        required
        autocomplete="tel"
        class="w-full border border-slate-200 bg-slate-50/30 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
        placeholder="(555) 123-4567"
      />
      <p class="form-error mt-1.5 text-xs text-red-500 hidden">Please enter a valid phone number.</p>
    </div>

    <!-- Email -->
    <div>
      <label for="quote-email" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
        Email <span class="text-cyan font-bold">*</span>
      </label>
      <input
        type="email"
        id="quote-email"
        name="email"
        required
        autocomplete="email"
        class="w-full border border-slate-200 bg-slate-50/30 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
        placeholder="john@company.com"
      />
      <p class="form-error mt-1.5 text-xs text-red-500 hidden">Please enter a valid email address.</p>
    </div>

    <!-- Pickup Location -->
    <div>
      <label for="quote-pickup" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
        Pickup Location <span class="text-cyan font-bold">*</span>
      </label>
      <input
        type="text"
        id="quote-pickup"
        name="pickup_location"
        required
        class="w-full border border-slate-200 bg-slate-50/30 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
        placeholder="City, State"
      />
      <p class="form-error mt-1.5 text-xs text-red-500 hidden">Please enter the pickup location.</p>
    </div>

    <!-- Delivery Location -->
    <div>
      <label for="quote-delivery" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
        Delivery Location <span class="text-cyan font-bold">*</span>
      </label>
      <input
        type="text"
        id="quote-delivery"
        name="delivery_location"
        required
        class="w-full border border-slate-200 bg-slate-50/30 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
        placeholder="City, State"
      />
      <p class="form-error mt-1.5 text-xs text-red-500 hidden">Please enter the delivery location.</p>
    </div>

    <!-- Freight Type -->
    <div>
      <label for="quote-freight-type" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
        Freight Type <span class="text-cyan font-bold">*</span>
      </label>
      <div class="relative">
        <select
          id="quote-freight-type"
          name="freight_type"
          required
          class="w-full border border-slate-200 bg-slate-50/30 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 appearance-none cursor-pointer font-body"
        >
          <option value="" disabled selected>Select type</option>
          {freightTypes.map((type) => (
            <option value={type}>{type}</option>
          ))}
        </select>
        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-4 text-slate-500">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </div>
      <p class="form-error mt-1.5 text-xs text-red-500 hidden">Please select a freight type.</p>
    </div>

    <!-- Pickup Date -->
    <div>
      <label for="quote-date" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
        Pickup Date
      </label>
      <input
        type="date"
        id="quote-date"
        name="pickup_date"
        class="w-full border border-slate-200 bg-slate-50/30 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
      />
    </div>
  </div>

  <!-- Message -->
  <div>
    <label for="quote-message" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
      Additional Details
    </label>
    <textarea
      id="quote-message"
      name="message"
      rows="4"
      class="w-full border border-slate-200 bg-slate-50/30 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 resize-y font-body"
      placeholder="Describe your freight, dimensions, weight, special requirements..."
    ></textarea>
  </div>

  <!-- Submit -->
  <div class="pt-2">
    <Button
      type="submit"
      variant="primary"
      size="default"
      arrow={true}
      class="group w-full sm:w-auto rounded-sm justify-center uppercase font-heading tracking-wider"
    >
      Submit Quote Request
    </Button>
  </div>

  <!-- Success -->
  <div id="quote-success" class="hidden p-5 border border-green-500/20 bg-green-500/5 rounded-sm">
    <p class="text-sm font-medium text-green-700 font-body">
      Thank you! Your quote request has been submitted. We'll be in touch within one business day.
    </p>
  </div>

  <!-- Error -->
  <div id="quote-error" class="hidden p-5 border border-red-500/20 bg-red-500/5 rounded-sm">
    <p class="text-sm font-medium text-red-600 font-body">
      Please fix the highlighted fields and try again.
    </p>
  </div>
</form>

<script>
  import { validateForm } from '@/scripts/forms';
  const form = document.getElementById('quote-form') as HTMLFormElement | null;
  if (form) validateForm(form, 'quote-success', 'quote-error');
</script>
