---
import Button from './Button.astro';

const equipmentTypes = [
  'Flatbed',
  'Step Deck',
  'Open Deck',
  'Not sure',
];
---

<form id="quote-form" class="site-form min-h-[500px] space-y-6" novalidate>
  <input type="hidden" name="formType" value="quote" />

  <!-- SUCCESS MESSAGE CARD -->
  <div id="quote-success" class="hidden p-6 border border-green-500/20 bg-green-500/5 rounded-sm">
    <div class="flex items-start gap-3">
      <svg class="h-5 w-5 text-green-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div>
        <h4 class="font-heading text-base font-bold text-green-800 uppercase tracking-wide">Request Received</h4>
        <p class="text-sm text-green-700 font-body font-light mt-1">
          Your request has been received. A WolfWay Logistics LLC team member will review the details and follow up.
        </p>
      </div>
    </div>
  </div>

  <!-- ERROR MESSAGE CARD -->
  <div id="quote-error" class="hidden p-5 border border-red-500/20 bg-red-500/5 rounded-sm">
    <p class="text-sm font-medium text-red-600 font-body">
      Please fix the highlighted fields and try again.
    </p>
  </div>

  <div id="quote-form-content">
    <div class="mb-8 rounded-sm border border-slate-200 bg-slate-50/60 p-4" aria-label="Quote request progress">
      <div class="flex items-center justify-between gap-4">
        <div>
          <p id="quote-step-label" class="font-body text-sm font-bold uppercase tracking-[0.08em] text-cyan-dark" aria-live="polite">
            Step 1 of 2
          </p>
          <p id="quote-step-title" class="mt-1 font-heading text-lg font-bold uppercase leading-none text-ink">
            Shipment Details
          </p>
        </div>
        <div class="flex items-center gap-2" aria-hidden="true">
          <span id="quote-progress-step-1" class="h-2.5 w-2.5 rounded-full bg-cyan"></span>
          <span id="quote-progress-line" class="h-px w-10 bg-slate-300"></span>
          <span id="quote-progress-step-2" class="h-2.5 w-2.5 rounded-full bg-slate-300"></span>
        </div>
      </div>
    </div>

    <!-- STEP 1: LOAD DETAILS -->
    <div id="quote-step-1" class="space-y-6" role="group" aria-labelledby="quote-step-title">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <!-- Pickup City/State -->
        <div>
          <label for="quote-pickup" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
            Pickup City & State <span class="text-cyan-dark font-bold">*</span>
          </label>
          <input
            type="text"
            id="quote-pickup"
            name="pickup_location"
            required
            maxlength="80"
            autocomplete="address-level2"
            aria-describedby="quote-pickup-error"
            aria-invalid="false"
            class="w-full border border-slate-200 bg-slate-50/30 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
            placeholder="e.g. Chicago, IL"
          />
          <p id="quote-pickup-error" class="form-error mt-1.5 text-xs text-red-500 hidden">Please enter the pickup location.</p>
        </div>

        <!-- Delivery City/State -->
        <div>
          <label for="quote-delivery" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
            Delivery City & State <span class="text-cyan-dark font-bold">*</span>
          </label>
          <input
            type="text"
            id="quote-delivery"
            name="delivery_location"
            required
            maxlength="80"
            autocomplete="address-level2"
            aria-describedby="quote-delivery-error"
            aria-invalid="false"
            class="w-full border border-slate-200 bg-slate-50/30 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
            placeholder="e.g. Houston, TX"
          />
          <p id="quote-delivery-error" class="form-error mt-1.5 text-xs text-red-500 hidden">Please enter the delivery location.</p>
        </div>

        <!-- Pickup Date -->
        <div>
          <label for="quote-date" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
            Preferred Pickup Date <span class="text-cyan-dark font-bold">*</span>
          </label>
          <input
            type="date"
            id="quote-date"
            name="pickup_date"
            required
            aria-describedby="quote-date-error"
            aria-invalid="false"
            class="w-full border border-slate-200 bg-slate-50/30 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
          />
          <p id="quote-date-error" class="form-error mt-1.5 text-xs text-red-500 hidden">Please select a pickup date.</p>
        </div>

        <!-- Equipment Needed -->
        <div>
          <label for="quote-equipment" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
            Equipment Needed <span class="text-cyan-dark font-bold">*</span>
          </label>
          <div class="relative">
            <select
              id="quote-equipment"
              name="equipment_type"
              required
              aria-describedby="quote-equipment-error"
              aria-invalid="false"
              class="w-full border border-slate-200 bg-slate-50/30 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 appearance-none cursor-pointer font-body"
            >
              <option value="" disabled selected>Select trailer configuration</option>
              {equipmentTypes.map((type) => (
                <option value={type}>{type}</option>
              ))}
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-4 text-slate-500">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </div>
          <p id="quote-equipment-error" class="form-error mt-1.5 text-xs text-red-500 hidden">Please select equipment type.</p>
        </div>
      </div>

      <div class="flex justify-end border-t border-slate-100 pt-4">
        <button
          type="button"
          id="quote-btn-next"
          class="group/btn inline-flex min-h-12 w-full items-center justify-center rounded-sm border border-transparent bg-cyan px-6 py-3 font-body text-sm font-bold uppercase tracking-[0.07em] text-navy transition-[background-color,transform,box-shadow] duration-200 hover:bg-cyan-hover hover:shadow-[0_6px_8px_rgba(0,168,225,0.2)] outline-none focus-visible:outline focus-visible:outline-3 focus-visible:outline-cyan/70 focus-visible:outline-offset-2 cursor-pointer active:translate-y-[1px] sm:w-auto"
        >
          Next Step
          <svg class="ml-2 h-3.5 w-3.5 shrink-0 transition-transform duration-180 ease-out group-hover/btn:translate-x-1.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- STEP 2: FREIGHT & CONTACT -->
    <div id="quote-step-2" class="space-y-6 hidden" role="group" aria-labelledby="quote-step-title" aria-hidden="true">
      <!-- Freight Specs Grid -->
      <div class="bg-slate-50/50 p-5 border border-slate-200/40 rounded-sm">
        <h4 class="font-heading text-xs font-bold uppercase tracking-wider text-slate-700 mb-4 font-body">Freight Specifications</h4>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
          <!-- Commodity -->
          <div class="sm:col-span-2">
            <label for="quote-commodity" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1.5 font-body">
              Commodity <span class="text-cyan-dark font-bold">*</span>
            </label>
            <input
              type="text"
              id="quote-commodity"
              name="commodity"
              required
              maxlength="120"
              aria-describedby="quote-commodity-error"
              aria-invalid="false"
              class="w-full border border-slate-200 bg-white hover:bg-slate-50 focus:bg-white px-3 py-2 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
              placeholder="e.g. Steel Pipes, Machinery"
            />
            <p id="quote-commodity-error" class="form-error mt-1 text-xs text-red-500 hidden">Enter commodity details.</p>
          </div>

          <!-- Weight -->
          <div>
            <label for="quote-weight" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1.5 font-body">
              Weight (lbs) <span class="text-cyan-dark font-bold">*</span>
            </label>
            <input
              type="text"
              id="quote-weight"
              name="weight"
              required
              maxlength="8"
              inputmode="numeric"
              aria-describedby="quote-weight-error"
              aria-invalid="false"
              class="w-full border border-slate-200 bg-white hover:bg-slate-50 focus:bg-white px-3 py-2 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
              placeholder="e.g. 45000"
            />
            <p id="quote-weight-error" class="form-error mt-1 text-xs text-red-500 hidden">Enter cargo weight.</p>
          </div>

          <!-- Dimensions (Length x Width x Height) -->
          <div>
            <label class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1.5 font-body">
              Dims (L x W x H)
            </label>
            <div class="grid grid-cols-3 gap-1">
              <input
                type="text"
                name="length"
                class="w-full border border-slate-200 bg-white hover:bg-slate-50 focus:bg-white px-1.5 py-2 rounded-sm text-center text-sm text-ink placeholder-slate-400 focus:border-cyan outline-none transition-all font-body"
                placeholder="L"
                aria-label="Length in feet"
              />
              <input
                type="text"
                name="width"
                class="w-full border border-slate-200 bg-white hover:bg-slate-50 focus:bg-white px-1.5 py-2 rounded-sm text-center text-sm text-ink placeholder-slate-400 focus:border-cyan outline-none transition-all font-body"
                placeholder="W"
                aria-label="Width in feet"
              />
              <input
                type="text"
                name="height"
                class="w-full border border-slate-200 bg-white hover:bg-slate-50 focus:bg-white px-1.5 py-2 rounded-sm text-center text-sm text-ink placeholder-slate-400 focus:border-cyan outline-none transition-all font-body"
                placeholder="H"
                aria-label="Height in feet"
              />
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Details Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <!-- Contact Name -->
        <div>
          <label for="quote-name" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
            Full Name <span class="text-cyan-dark font-bold">*</span>
          </label>
          <input
            type="text"
            id="quote-name"
            name="name"
            required
            autocomplete="name"
            aria-describedby="quote-name-error"
            aria-invalid="false"
            class="w-full border border-slate-200 bg-slate-50/30 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
            placeholder="John Doe"
          />
          <p id="quote-name-error" class="form-error mt-1.5 text-xs text-red-500 hidden">Please enter your name.</p>
        </div>

        <!-- Company -->
        <div>
          <label for="quote-company" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
            Company Name
          </label>
          <input
            type="text"
            id="quote-company"
            name="company"
            autocomplete="organization"
            class="w-full border border-slate-200 bg-slate-50/30 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
            placeholder="Company name"
          />
        </div>

        <!-- Phone -->
        <div>
          <label for="quote-phone" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
            Phone Number <span class="text-cyan-dark font-bold">*</span>
          </label>
          <input
            type="tel"
            id="quote-phone"
            name="phone"
            required
            autocomplete="tel"
            aria-describedby="quote-phone-error"
            aria-invalid="false"
            class="w-full border border-slate-200 bg-slate-50/30 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
            placeholder="(555) 123-4567"
          />
          <p id="quote-phone-error" class="form-error mt-1.5 text-xs text-red-500 hidden">Please enter a valid phone number.</p>
        </div>

        <!-- Email -->
        <div>
          <label for="quote-email" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
            Email Address <span class="text-cyan-dark font-bold">*</span>
          </label>
          <input
            type="email"
            id="quote-email"
            name="email"
            required
            autocomplete="email"
            aria-describedby="quote-email-error"
            aria-invalid="false"
            class="w-full border border-slate-200 bg-slate-50/30 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 font-body"
            placeholder="john@company.com"
          />
          <p id="quote-email-error" class="form-error mt-1.5 text-xs text-red-500 hidden">Please enter a valid email address.</p>
        </div>
      </div>

      <!-- File Upload Placeholder -->
      <div>
        <label for="quote-file" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
          Upload Photo / Specs Sheet <span class="text-slate-400 font-normal font-sans">(Optional)</span>
        </label>
        <div class="relative flex items-center justify-center border-2 border-dashed border-slate-200 hover:border-cyan/50 rounded-sm p-6 bg-slate-50/10 transition-colors cursor-pointer group/file">
          <input type="file" id="quote-file" name="attachment" accept=".png,.jpg,.jpeg,.pdf" class="absolute inset-0 opacity-0 cursor-pointer" />
          <div class="text-center">
            <svg class="mx-auto h-8 w-8 text-slate-400 group-hover/file:text-cyan transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z" />
            </svg>
            <span class="mt-2 block text-xs font-semibold text-slate-700 font-body">Click to upload or drag & drop</span>
            <span class="mt-0.5 block text-xs text-slate-500 font-body">PNG, JPG, PDF up to 10MB</span>
          </div>
        </div>
      </div>

      <!-- Message -->
      <div>
        <label for="quote-message" class="block text-xs font-bold uppercase tracking-wider text-slate-700 mb-2 font-body">
          Additional Details
        </label>
        <textarea
          id="quote-message"
          name="message"
          rows="3"
          class="w-full border border-slate-200 bg-slate-50/30 hover:bg-slate-50 focus:bg-white px-4.5 py-3.5 rounded-sm text-sm text-ink placeholder-slate-400 focus:border-cyan focus:ring-4 focus:ring-cyan/10 outline-none transition-all duration-300 resize-y font-body"
          placeholder="Describe any tarping needs, permit specifications, or loading requirements..."
        ></textarea>
      </div>

      <!-- Consent Checkbox -->
      <div class="flex items-start">
        <div class="flex h-5 items-center">
          <input
            id="quote-consent"
            name="consent"
            type="checkbox"
            required
            aria-describedby="quote-consent-error"
            aria-invalid="false"
            class="h-4 w-4 rounded-sm text-cyan border-slate-300 focus:ring-cyan cursor-pointer"
          />
        </div>
        <div class="ml-3 text-xs leading-5">
          <label for="quote-consent" class="font-light text-slate-500 font-body cursor-pointer">
            I agree to receive shipping status updates via email or phone. <span class="text-cyan-dark font-bold">*</span>
          </label>
          <p id="quote-consent-error" class="form-error mt-0.5 text-xs text-red-500 hidden">Consent is required to submit a request.</p>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="flex flex-col-reverse gap-3 border-t border-slate-100 pt-4 sm:flex-row sm:items-center sm:gap-4">
        <button
          type="button"
          id="quote-btn-back"
          class="inline-flex min-h-12 w-full items-center justify-center rounded-sm border border-slate-300 bg-transparent px-6 py-3 font-body text-sm font-bold uppercase tracking-[0.07em] text-slate-700 transition-colors hover:bg-slate-50 outline-none focus-visible:outline focus-visible:outline-3 focus-visible:outline-cyan/70 focus-visible:outline-offset-2 cursor-pointer active:translate-y-[1px] sm:w-auto"
        >
          Back
        </button>
        <Button
          type="submit"
          variant="primary"
          size="default"
          arrow={true}
          class="group w-full justify-center uppercase font-heading tracking-wider sm:w-auto"
        >
          Submit Quote Request
        </Button>
      </div>
    </div>
  </div>

  <!-- Final equipment confirmation notice -->
  <p class="mt-6 border-t border-slate-100/40 pt-3 text-center text-[15px] text-slate-600 font-body">
    Final equipment selection is confirmed by WolfWay Logistics LLC.
  </p>
</form>

<script>
  import { validateForm } from '@/scripts/forms';

  function initProgressiveForm() {
    const form = document.getElementById('quote-form') as HTMLFormElement | null;
    const step1 = document.getElementById('quote-step-1');
    const step2 = document.getElementById('quote-step-2');
    const nextBtn = document.getElementById('quote-btn-next');
    const backBtn = document.getElementById('quote-btn-back');
    const formContent = document.getElementById('quote-form-content');
    const stepLabel = document.getElementById('quote-step-label');
    const stepTitle = document.getElementById('quote-step-title');
    const progressStep1 = document.getElementById('quote-progress-step-1');
    const progressStep2 = document.getElementById('quote-progress-step-2');
    const progressLine = document.getElementById('quote-progress-line');

    if (!form || !step1 || !step2 || !nextBtn || !backBtn) return;
    if (form.dataset.progressiveBound === 'true') return;
    form.dataset.progressiveBound = 'true';
    const formEl = form;
    const stepOne = step1;
    const stepTwo = step2;

    function getFieldError(input: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement) {
      if (input.id) {
        const describedBy = input.getAttribute('aria-describedby')?.split(/\s+/) ?? [];
        const linkedError = describedBy
          .map((id) => document.getElementById(id))
          .find((el) => el?.classList.contains('form-error'));
        if (linkedError) return linkedError;
      }

      return input.parentElement?.querySelector('.form-error')
        ?? input.closest('div')?.querySelector('.form-error')
        ?? null;
    }

    function setFieldInvalid(
      input: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement,
      isInvalid: boolean
    ) {
      input.classList.toggle('border-red-500', isInvalid);
      input.setAttribute('aria-invalid', isInvalid ? 'true' : 'false');
      getFieldError(input)?.classList.toggle('hidden', !isInvalid);
    }

    function updateProgress(stepNumber: 1 | 2) {
      const isStep2 = stepNumber === 2;
      if (stepLabel) stepLabel.textContent = isStep2 ? 'Step 2 of 2' : 'Step 1 of 2';
      if (stepTitle) stepTitle.textContent = isStep2 ? 'Freight & Contact' : 'Shipment Details';
      progressStep1?.classList.toggle('bg-cyan', true);
      progressStep1?.classList.toggle('bg-slate-300', false);
      progressStep2?.classList.toggle('bg-cyan', isStep2);
      progressStep2?.classList.toggle('bg-slate-300', !isStep2);
      progressLine?.classList.toggle('bg-cyan', isStep2);
      progressLine?.classList.toggle('bg-slate-300', !isStep2);
    }

    function showStep(stepNumber: 1 | 2) {
      const isStep2 = stepNumber === 2;
      stepOne.classList.toggle('hidden', isStep2);
      stepTwo.classList.toggle('hidden', !isStep2);
      stepOne.setAttribute('aria-hidden', isStep2 ? 'true' : 'false');
      stepTwo.setAttribute('aria-hidden', isStep2 ? 'false' : 'true');
      updateProgress(stepNumber);

      const nextFocus = document.getElementById(isStep2 ? 'quote-commodity' : 'quote-pickup') as HTMLElement | null;
      requestAnimationFrame(() => nextFocus?.focus());
    }

    // Next Step handler
    nextBtn.addEventListener('click', (e) => {
      e.preventDefault();
      let isStep1Valid = true;
      const invalidFields: Array<HTMLInputElement | HTMLSelectElement> = [];
      const step1Inputs = stepOne.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[required]');
      
      step1Inputs.forEach(input => {
        const val = input.value.trim();
        const isInvalid = !val;
        setFieldInvalid(input, isInvalid);

        if (isInvalid) {
          isStep1Valid = false;
          invalidFields.push(input);
        }
      });

      if (isStep1Valid) {
        showStep(2);
      } else {
        invalidFields[0]?.focus();
      }
    });

    // Back button handler
    backBtn.addEventListener('click', (e) => {
      e.preventDefault();
      showStep(1);
    });

    // Validate the final submit
    validateForm(formEl, 'quote-success', 'quote-error');

    // On successful submit, hide the form content wrapper
    formEl.addEventListener('submit', () => {
      // Check if validation succeeded by observing if success is visible
      setTimeout(() => {
        const successCard = document.getElementById('quote-success');
        if (successCard && !successCard.classList.contains('hidden') && formContent) {
          formContent.classList.add('hidden');
        }
      }, 50);
    });

    formEl.addEventListener('input', (e) => {
      const target = e.target;
      if (target instanceof HTMLInputElement || target instanceof HTMLSelectElement || target instanceof HTMLTextAreaElement) {
        setFieldInvalid(target, false);
      }
    });
  }

  // Initial load
  initProgressiveForm();

  // Astro page-load trigger for persistent view navigation
  document.addEventListener('astro:page-load', initProgressiveForm);
</script>
