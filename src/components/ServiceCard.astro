---
export interface Props {
  title: string;
  description: string;
  imageAlt: string;
  imagePath: string;
  href: string;
  index: number;
}

const { title, description, imageAlt, imagePath, href, index } = Astro.props;
const formattedIndex = String(index).padStart(2, '0');
---

<a
  href={href}
  class="group block relative focus-visible:outline focus-visible:outline-3 focus-visible:outline-cyan/70 focus-visible:outline-offset-4 rounded-sm"
  aria-label={`Learn more about ${title}`}
>
  <!-- Index Counter & Line (Editorial Indicator) -->
  <div class="flex items-center gap-3 mb-3.5 select-none" aria-hidden="true">
    <span class="font-heading text-lg font-bold text-slate-400 tracking-wider">
      {formattedIndex}
    </span>
    <div class="h-[1px] bg-cyan w-0 group-hover:w-16 group-focus-within:w-16 transition-all duration-300 origin-left"></div>
  </div>

  <!-- Image Container with Inset Crop Reveal -->
  <div class="relative aspect-[4/3] overflow-hidden rounded-sm border border-slate-200/40 bg-slate-100">
    <img
      src={imagePath}
      alt={imageAlt}
      loading="lazy"
      class="h-full w-full object-cover transition-all duration-500 ease-out [clip-path:inset(7%_0_7%_0)] group-hover:[clip-path:inset(0)] group-focus-within:[clip-path:inset(0)] group-hover:scale-[1.03] group-focus-within:scale-[1.03]"
    />
  </div>

  <!-- Text Details -->
  <div class="mt-5">
    <h3 class="font-heading text-xl font-bold uppercase tracking-tight text-ink">
      {title}
    </h3>
    <p class="mt-2.5 text-sm leading-relaxed text-slate-600 font-body font-light">
      {description}
    </p>
    <span class="mt-3.5 inline-flex items-center text-xs font-bold uppercase tracking-wider text-[#005F8A] group-hover:text-cyan transition-colors font-body">
      Learn more
      <svg
        class="ml-1.5 h-3.5 w-3.5 transition-transform duration-180 group-hover:translate-x-1 group-focus-within:translate-x-1"
        viewBox="0 0 16 16"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M3 8h10M9 4l4 4-4 4"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </span>
  </div>
</a>
