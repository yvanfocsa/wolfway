---
export interface Props {
  title: string;
  description: string;
  imageAlt: string;
  imagePath: string;
  href: string;
}

const { title, description, imageAlt, imagePath, href } = Astro.props;
---

<a
  href={href}
  class="group block"
>
  <!-- Image Container -->
  <div class="relative aspect-[4/3] overflow-hidden rounded-sm border border-slate-200/40 bg-slate-100 shadow-sm">
    <img
      src={imagePath}
      alt={imageAlt}
      loading="lazy"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
    />
  </div>

  <!-- Text Details -->
  <div class="mt-5">
    <h3 class="font-heading text-xl font-bold uppercase tracking-tight text-ink">
      {title}
    </h3>
    <p class="mt-2 text-sm leading-relaxed text-slate-500 font-body font-light">
      {description}
    </p>
    <span class="mt-3.5 inline-flex items-center text-xs font-bold uppercase tracking-wider text-cyan group-hover:text-cyan/80 transition-colors font-body">
      Learn more
      <svg
        class="ml-1.5 h-3.5 w-3.5 transition-transform duration-200 group-hover:translate-x-1"
        viewBox="0 0 16 16"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M3 8h10M9 4l4 4-4 4"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </span>
  </div>
</a>
