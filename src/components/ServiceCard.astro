---
import ResponsiveImage from './ResponsiveImage.astro';
import type { ResponsiveImageAsset } from '@/content/images';

export interface Props {
  title: string;
  description: string;
  imageAlt: string;
  image: ResponsiveImageAsset;
  href: string;
}

const { title, description, imageAlt, image, href } = Astro.props;
---

<a
  href={href}
  class="group block relative focus-visible:outline focus-visible:outline-3 focus-visible:outline-cyan/70 focus-visible:outline-offset-4 rounded-sm"
  aria-label={`Learn more about ${title}`}
>
  <!-- Image Container with Inset Crop Reveal -->
  <div class="relative aspect-[4/3] overflow-hidden rounded-sm border border-slate-200/40 bg-slate-100">
    <ResponsiveImage
      asset={image}
      alt={imageAlt}
      loading="lazy"
      sizes="(min-width: 768px) 33vw, (min-width: 640px) 50vw, 100vw"
      pictureClass="h-full w-full"
      class="service-image h-full w-full object-cover transition-[transform,clip-path] duration-500 ease-out [clip-path:inset(5%_0_5%_0)] group-hover:[clip-path:inset(0)] group-focus-within:[clip-path:inset(0)] group-hover:scale-[1.03] group-focus-within:scale-[1.03]"
    />
  </div>

  <!-- Text Details -->
  <div class="mt-5">
    <h3 class="service-title font-heading text-2xl font-bold uppercase tracking-normal text-ink">
      {title}
    </h3>
    <p class="service-body mobile-readable mt-2.5 text-base leading-relaxed text-slate-600 font-body font-normal">
      {description}
    </p>
    <span class="service-link mt-3.5 inline-flex items-center text-sm font-bold uppercase tracking-wider text-cyan-dark group-hover:text-cyan transition-colors font-body">
      Learn more
      <svg
        class="ml-1.5 h-3.5 w-3.5 transition-transform duration-180 group-hover:translate-x-1 group-focus-within:translate-x-1"
        viewBox="0 0 16 16"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M3 8h10M9 4l4 4-4 4"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </span>
  </div>
</a>
