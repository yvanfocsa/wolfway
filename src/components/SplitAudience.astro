---
// src/components/SplitAudience.astro
import Button from './Button.astro';
---

<section class="relative overflow-hidden select-none" data-animate="fade-up">
  <div class="grid md:grid-cols-2">
    <!-- Left Panel: Drivers -->
    <div class="relative bg-navy py-20 sm:py-24 px-8 sm:px-12 lg:px-20 flex flex-col justify-center items-start text-white border-b md:border-b-0 border-white/5">
      <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-cyan mb-4">
        CAREERS
      </p>
      <h2 class="font-heading text-3xl sm:text-4xl font-bold uppercase text-white leading-tight">
        Drive With WolfWay
      </h2>
      <p class="mt-4 text-sm leading-relaxed text-slate-350 max-w-md font-body font-light">
        We support our drivers. Consistent flatbed and step-deck freight, top-of-market pay rates, and dispatch coordinators who value your safety and home time.
      </p>
      <div class="mt-8 w-full sm:w-auto">
        <Button href="/drive-with-us" variant="primary" size="lg" arrow={true} class="w-full sm:w-auto justify-center">
          Explore Driver Openings
        </Button>
      </div>
    </div>

    <!-- Right Panel: Carriers -->
    <div class="relative bg-offwhite py-20 sm:py-24 px-8 sm:px-12 lg:px-20 flex flex-col justify-center items-start text-ink">
      <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-[#005F8A] mb-4">
        CARRIER PARTNERS
      </p>
      <h2 class="font-heading text-3xl sm:text-4xl font-bold uppercase text-ink leading-tight">
        Join Our Carrier Network
      </h2>
      <p class="mt-4 text-sm leading-relaxed text-slate-600 max-w-md font-body font-light">
        Partner with a freight coordinator who communicates clearly and respects your business. Fair rates, regular volumes, and prompt payments.
      </p>
      <div class="mt-8 w-full sm:w-auto">
        <Button href="/carrier" variant="secondary" size="lg" arrow={true} class="w-full sm:w-auto justify-center border-slate-300 text-ink hover:bg-slate-100/50">
          Apply as Carrier
        </Button>
      </div>
    </div>
  </div>
</section>
