---
// src/components/TrustBar.astro
---

<div class="relative z-20 bg-navy border-b border-white/5 py-3.5 select-none">
  <div class="mx-auto max-w-7xl px-5 lg:px-10">
    <div class="flex flex-wrap items-center justify-between gap-y-3 gap-x-6 text-xs font-mono tracking-wider text-white/70 uppercase">
      <!-- Left side: DOT / MC Numbers & Authority -->
      <div class="flex items-center gap-5 sm:gap-6 flex-wrap">
        <div class="flex items-center gap-1.5">
          <span class="text-cyan font-bold">USDOT</span>
          <span class="text-white/80 font-bold">4310565</span>
        </div>
        <div class="h-3 w-px bg-white/10 hidden sm:block"></div>
        <div class="flex items-center gap-1.5">
          <span class="text-cyan font-bold">MC</span>
          <span class="text-white/80 font-bold">1682344</span>
        </div>
        <div class="h-3 w-px bg-white/10 hidden md:block"></div>
        <div class="flex items-center gap-1.5 text-white/70">
          <svg class="h-3.5 w-3.5 text-emerald-500 fill-current" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span>FMCSA Registered & Insured</span>
        </div>
      </div>

      <!-- Right side: Google Rating -->
      <div class="flex items-center gap-2">
        <div class="flex items-center gap-1">
          <span class="text-white/80 font-semibold font-body text-xs">5.0</span>
          <div class="flex text-yellow-500">
            {[...Array(5)].map(() => (
              <svg class="h-3 w-3 fill-current" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
        </div>
        <span class="text-xs text-white/60 tracking-wider">Google Reviews</span>
      </div>
    </div>
  </div>
</div>
