---
import SeoHead from '@/components/SeoHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import { SITE_URL } from '@/content/seo';
import '@/styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogImageAlt?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, canonicalUrl, ogImage, ogImageAlt, structuredData } = Astro.props;
const resolvedCanonicalUrl = canonicalUrl ?? new URL(Astro.url.pathname, SITE_URL).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead
      title={title}
      description={description}
      canonicalUrl={resolvedCanonicalUrl}
      ogImage={ogImage}
      ogImageAlt={ogImageAlt}
      structuredData={structuredData}
    />
    <ClientRouter />

    <!-- Forced Light Mode & Color Scheme Lock -->
    <meta name="color-scheme" content="light only" />
  </head>
  <body class="bg-offwhite text-ink antialiased flex flex-col min-h-screen">
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <Header transition:persist />
    <main id="main-content" class="flex-1 flex flex-col min-h-[100dvh]" tabindex="-1">
      <slot />
    </main>
    <Footer />

    <!-- Client-side scripts -->
    <script>
      let enhancementsLoaded = false;

      function scheduleEnhancements() {
        const load = () => {
          import('@/scripts/animations').then(({ initAnimations }) => initAnimations());
          import('@/scripts/smooth-scroll');

          if (document.querySelector('form')) {
            import('@/scripts/form-helpers').then(({ initSmartFormHelpers }) => initSmartFormHelpers());
          }

          enhancementsLoaded = true;
        };

        if (enhancementsLoaded) {
          window.requestIdleCallback(load, { timeout: 500 });
          return;
        }

        const start = () => {
          window.removeEventListener('pointerdown', start);
          window.removeEventListener('keydown', start);
          window.removeEventListener('scroll', start);
          load();
        };

        window.addEventListener('pointerdown', start, { once: true, passive: true });
        window.addEventListener('keydown', start, { once: true });
        window.addEventListener('scroll', start, { once: true, passive: true });
      }

      // Reset scroll position on page swap
      document.addEventListener('astro:after-swap', () => {
        window.scrollTo(0, 0);
        const lenis = (window as any).lenis;
        if (lenis) {
          lenis.scrollTo(0, { immediate: true });
        }
      });

      document.addEventListener('astro:page-load', () => {
        if (!window.location.hash) {
          window.scrollTo(0, 0);
          const lenis = (window as any).lenis;
          if (lenis) {
            lenis.scrollTo(0, { immediate: true });
          }
        }

        scheduleEnhancements();
      });
    </script>
  </body>
</html>
