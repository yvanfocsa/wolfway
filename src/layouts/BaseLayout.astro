---
import SeoHead from '@/components/SeoHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import '@/styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const { title, description, canonicalUrl, ogImage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
    />
    <ClientRouter />
    <noscript>
      <style>
        #hero-eyebrow,
        #hero-heading,
        #hero-body-content {
          opacity: 1 !important;
        }
        #splash-screen { display: none !important; }
      </style>
    </noscript>
    <style is:inline>
      #splash-screen {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #0B1526;
        transition: opacity 0.5s ease, visibility 0.5s ease;
      }
      #splash-screen.is-hidden {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }
      #splash-logo {
        width: 72px;
        height: 72px;
        object-fit: contain;
        margin-bottom: 28px;
        animation: splash-pulse 1.8s ease-in-out infinite;
      }
      #splash-bar-track {
        width: 120px;
        height: 2px;
        background: rgba(255,255,255,0.08);
        border-radius: 2px;
        overflow: hidden;
      }
      #splash-bar-fill {
        width: 40%;
        height: 100%;
        background: #00D4FF;
        border-radius: 2px;
        animation: splash-slide 1.2s ease-in-out infinite;
      }
      @keyframes splash-pulse {
        0%, 100% { opacity: 0.6; transform: scale(1); }
        50% { opacity: 1; transform: scale(1.04); }
      }
      @keyframes splash-slide {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(350%); }
      }
    </style>
  </head>
  <body class="bg-offwhite text-ink antialiased">
    <!-- Splash Screen -->
    <div id="splash-screen" aria-hidden="true">
      <img id="splash-logo" src="/images/logo_icon.png" alt="" width="72" height="72" />
      <div id="splash-bar-track">
        <div id="splash-bar-fill"></div>
      </div>
    </div>

    <Header transition:persist />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Client-side scripts -->
    <script>
      import '@/scripts/smooth-scroll';
      import '@/scripts/animations';

      function dismissSplash() {
        const splash = document.getElementById('splash-screen');
        if (splash && !splash.classList.contains('is-hidden')) {
          splash.classList.add('is-hidden');
          // Remove from DOM after fade-out transition completes
          setTimeout(() => splash.remove(), 600);
        }
      }

      // Reset scroll position on page swap
      document.addEventListener('astro:after-swap', () => {
        // Immediately dismiss splash on navigation (not initial load)
        dismissSplash();
        window.scrollTo(0, 0);
        const lenis = (window as any).lenis;
        if (lenis) {
          lenis.scrollTo(0, { immediate: true });
        }
      });

      // On page load: dismiss splash once video is playing or after timeout
      document.addEventListener('astro:page-load', () => {
        if (!window.location.hash) {
          window.scrollTo(0, 0);
          const lenis = (window as any).lenis;
          if (lenis) {
            lenis.scrollTo(0, { immediate: true });
          }
        }

        const video = document.getElementById('hero-video') as HTMLVideoElement | null;
        if (video) {
          // If video is already playing, dismiss immediately
          if (video.readyState >= 3) {
            dismissSplash();
          } else {
            // Wait for the video to have enough data to play
            video.addEventListener('canplay', () => dismissSplash(), { once: true });
            // Safety timeout: dismiss after 2.5s max no matter what
            setTimeout(() => dismissSplash(), 2500);
          }
        } else {
          // No hero video on this page, dismiss immediately
          dismissSplash();
        }
      });
    </script>
  </body>
</html>
