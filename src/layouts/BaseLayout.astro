---
import SeoHead from '@/components/SeoHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import '@/styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const { title, description, canonicalUrl, ogImage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
    />
    <ClientRouter />
    <script is:inline>
      document.documentElement.classList.add('js');
      // Synchronously inject style tag to prevent FOVT (Flash of Visible Text) before scripts parse
      const style = document.createElement('style');
      style.id = 'js-animation-fallback';
      style.textContent = '#hero-eyebrow, #hero-heading, #hero-body-content { opacity: 0; }';
      document.head.appendChild(style);
    </script>
  </head>
  <body class="bg-offwhite text-ink antialiased">
    <Header transition:persist />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Client-side scripts -->
    <script>
      import '@/scripts/smooth-scroll';
      import '@/scripts/animations';

      // Reset scroll position on page swap
      document.addEventListener('astro:after-swap', () => {
        window.scrollTo(0, 0);
        const lenis = (window as any).lenis;
        if (lenis) {
          lenis.scrollTo(0, { immediate: true });
        }
      });

      // Double-check scroll position on page load, unless navigating to an anchor hash
      document.addEventListener('astro:page-load', () => {
        if (!window.location.hash) {
          window.scrollTo(0, 0);
          const lenis = (window as any).lenis;
          if (lenis) {
            lenis.scrollTo(0, { immediate: true });
          }
        }
      });
    </script>
  </body>
</html>
