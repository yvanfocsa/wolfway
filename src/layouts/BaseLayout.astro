---
import SeoHead from '@/components/SeoHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import '@/styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const { title, description, canonicalUrl, ogImage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
    />
    <ClientRouter />
    <noscript>
      <style>
        #hero-eyebrow,
        #hero-heading,
        #hero-body-content {
          opacity: 1 !important;
        }
        #splash-screen { display: none !important; }
      </style>
    </noscript>
    <style is:inline>
      #splash-screen {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #F6F5F3;
        transition: opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.6s cubic-bezier(0.4, 0, 0.2, 1);
      }
      #splash-screen.is-hidden {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }
      .splash-mark {
        position: relative;
        width: 80px;
        height: 80px;
        margin-bottom: 24px;
      }
      .splash-mark img {
        width: 52px;
        height: 52px;
        object-fit: contain;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
      }
      .splash-ring {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        border: 1.5px solid transparent;
        border-top-color: #0B1526;
        animation: splash-spin 1s cubic-bezier(0.4, 0, 0.2, 1) infinite;
      }
      .splash-ring-outer {
        position: absolute;
        inset: -6px;
        border-radius: 50%;
        border: 1px solid rgba(11, 21, 38, 0.06);
      }
      .splash-name {
        font-family: 'Inter', 'Outfit', system-ui, sans-serif;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: #0B1526;
        opacity: 0.4;
      }
      .splash-shimmer {
        width: 48px;
        height: 1px;
        margin-top: 20px;
        background: linear-gradient(90deg, transparent, rgba(11, 21, 38, 0.15), transparent);
        animation: splash-shimmer 1.6s ease-in-out infinite;
      }
      @keyframes splash-spin {
        to { transform: rotate(360deg); }
      }
      @keyframes splash-shimmer {
        0%, 100% { opacity: 0; transform: scaleX(0.5); }
        50% { opacity: 1; transform: scaleX(1); }
      }
    </style>
  </head>
  <body class="bg-offwhite text-ink antialiased">
    <!-- Splash Screen -->
    <div id="splash-screen" aria-hidden="true">
      <div class="splash-mark">
        <div class="splash-ring-outer"></div>
        <div class="splash-ring"></div>
        <img src="/images/logo_icon.png" alt="" width="52" height="52" />
      </div>
      <span class="splash-name">WolfWay Logistics</span>
      <div class="splash-shimmer"></div>
    </div>

    <Header transition:persist />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Client-side scripts -->
    <script>
      import '@/scripts/smooth-scroll';
      import '@/scripts/animations';

      function dismissSplash() {
        const splash = document.getElementById('splash-screen');
        if (splash && !splash.classList.contains('is-hidden')) {
          splash.classList.add('is-hidden');
          // Remove from DOM after fade-out transition completes
          setTimeout(() => splash.remove(), 600);
        }
      }

      // Reset scroll position on page swap
      document.addEventListener('astro:after-swap', () => {
        // Immediately dismiss splash on navigation (not initial load)
        dismissSplash();
        window.scrollTo(0, 0);
        const lenis = (window as any).lenis;
        if (lenis) {
          lenis.scrollTo(0, { immediate: true });
        }
      });

      // On page load: dismiss splash once video is playing or after timeout
      document.addEventListener('astro:page-load', () => {
        if (!window.location.hash) {
          window.scrollTo(0, 0);
          const lenis = (window as any).lenis;
          if (lenis) {
            lenis.scrollTo(0, { immediate: true });
          }
        }

        const video = document.getElementById('hero-video') as HTMLVideoElement | null;
        if (video) {
          // If video is already playing, dismiss immediately
          if (video.readyState >= 3) {
            dismissSplash();
          } else {
            // Wait for the video to have enough data to play
            video.addEventListener('canplay', () => dismissSplash(), { once: true });
            // Safety timeout: dismiss after 2.5s max no matter what
            setTimeout(() => dismissSplash(), 2500);
          }
        } else {
          // No hero video on this page, dismiss immediately
          dismissSplash();
        }
      });
    </script>
  </body>
</html>
