---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import CTASection from '@/components/CTASection.astro';
import { blogPosts } from '@/content/blog';
---

<BaseLayout
  title="Open-Deck Freight Insights & Industry News | WolfWay Logistics LLC"
  description="Expert articles on open-deck logistics, flatbed securement, air-ride cargo protection, driver culture, and 24/7 dispatch coordination."
>
  <!-- Page Header -->
  <section class="bg-navy pt-36 pb-20 relative overflow-hidden select-none">
    <div class="mx-auto max-w-7xl px-5 lg:px-10 relative z-10 text-center">
      <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-cyan mb-3">
        LOGISTICS INSIGHTS
      </p>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold uppercase text-white leading-none tracking-tight">
        Industry News &amp; Articles
      </h1>
      <p class="mt-4 max-w-2xl mx-auto text-base sm:text-lg text-white/70 font-body font-light leading-relaxed">
        Perspectives on open-deck transportation, cargo securement standards, fleet operations, and driver-first logistics.
      </p>
    </div>
  </section>

  <!-- Blog Grid Section -->
  <section class="bg-offwhite py-16 sm:py-20 border-b border-slate-200/60 select-none">
    <div class="mx-auto max-w-7xl px-5 lg:px-10">
      <div class="grid gap-8 md:grid-cols-2">
        {blogPosts.map((post) => (
          <article class="flex flex-col justify-between p-8 bg-white border border-slate-200/80 rounded-xl shadow-xs hover:border-cyan/40 transition-all duration-300 group">
            <div>
              <div class="flex items-center gap-3 mb-4">
                <span class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 bg-cyan/10 text-[#005F8A] rounded">
                  {post.category}
                </span>
                <span class="text-xs text-slate-400 font-body font-light">
                  {post.date} &bull; {post.readTime}
                </span>
              </div>
              <h2 class="font-heading text-xl sm:text-2xl font-bold uppercase text-ink group-hover:text-cyan transition-colors leading-tight mb-3">
                {post.title}
              </h2>
              <p class="text-sm text-slate-600 font-body font-light leading-relaxed mb-6">
                {post.excerpt}
              </p>
            </div>
            
            <div class="pt-4 border-t border-slate-100 flex items-center justify-between">
              <span class="text-xs text-slate-400 font-body font-medium">{post.author}</span>
              <Button href={`/blog/${post.slug}`} variant="outline" size="sm" arrow={true} class="text-xs border-slate-200 text-ink hover:bg-slate-50">
                Read Article
              </Button>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection
    variant="dark"
    eyebrow="WORK WITH WOLFWAY"
    heading="Partner With Open-Deck Logistics Experts"
    description="Speak directly with our dispatch team or request a freight quote today."
    buttonText="REQUEST A FREIGHT QUOTE"
    buttonHref="/request-a-quote"
  />
</BaseLayout>
