---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import Button from '@/components/Button.astro';
import CTASection from '@/components/CTASection.astro';
import ResponsiveImage from '@/components/ResponsiveImage.astro';
import { blogPosts } from '@/content/blog';
---

<BaseLayout
  title="Open-Deck Freight Insights & Industry News | WolfWay Logistics LLC"
  description="Expert articles on open-deck logistics, flatbed securement, air-ride cargo protection, driver culture, and 24/7 dispatch coordination."
>
  <PageHero
    title="Open-Deck Field Notes"
    description="Practical perspectives on cargo securement, trailer selection, fleet operations, and driver-first logistics."
    align="center"
    compact={true}
  />

  <!-- Blog Grid Section -->
  <section class="bg-offwhite py-16 sm:py-20 border-b border-slate-200/60 select-none">
    <div class="mx-auto max-w-7xl px-5 lg:px-10">
      <div class="grid gap-8 md:grid-cols-2">
        {blogPosts.map((post) => (
          <article class="group flex flex-col overflow-hidden rounded-lg border border-slate-200 bg-white transition-colors duration-300 hover:border-cyan/60">
            <a href={`/blog/${post.slug}`} class="aspect-[16/9] overflow-hidden bg-slate-200" aria-label={`Read ${post.title}`}>
              <ResponsiveImage
                asset={post.image}
                alt={post.imageAlt}
                class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.025]"
                pictureClass="h-full w-full"
                sizes="(min-width: 768px) 50vw, 100vw"
                loading="lazy"
              />
            </a>
            <div class="flex flex-1 flex-col p-6 sm:p-7">
              <div class="flex flex-wrap items-center gap-3 mb-4">
                <span class="rounded bg-cyan/10 px-2.5 py-1 text-sm font-bold uppercase tracking-wide text-cyan-dark">
                  {post.category}
                </span>
                <span class="text-sm text-slate-500 font-body">
                  {post.date} &bull; {post.readTime}
                </span>
              </div>
              <h2 class="font-heading text-xl sm:text-2xl font-bold uppercase text-ink group-hover:text-cyan transition-colors leading-tight mb-3">
                {post.title}
              </h2>
              <p class="mb-6 text-base leading-relaxed text-slate-600 font-body">
                {post.excerpt}
              </p>
              <div class="mt-auto flex flex-col items-start gap-3 border-t border-slate-100 pt-4 sm:flex-row sm:items-center sm:justify-between">
              <span class="text-sm font-semibold text-slate-500 font-body">{post.author}</span>
              <Button href={`/blog/${post.slug}`} variant="outlineInk" size="sm" arrow={true} class="w-full sm:w-auto">
                Read Article
              </Button>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTASection
    variant="dark"
    eyebrow="WORK WITH WOLFWAY"
    heading="Partner With Open-Deck Logistics Experts"
    description="Speak directly with our dispatch team or request a freight quote today."
    buttonText="REQUEST A FREIGHT QUOTE"
    buttonHref="/request-a-quote"
  />
</BaseLayout>
