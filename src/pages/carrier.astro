---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CarrierForm from '@/components/CarrierForm.astro';

const reasons = [
  {
    title: 'Consistent Volume',
    description: 'We move freight every day. Our shippers provide steady, year-round loads so your trucks stay busy.',
    icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  },
  {
    title: 'Fair Rates',
    description: 'We believe in partnerships, not one-sided deals. Our rates reflect the market and respect your bottom line.',
    icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Reliable Communication',
    description: 'Our dispatch team is responsive, transparent, and professional. You\'ll always know where things stand.',
    icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
  },
];
---

<BaseLayout
  title="Carrier Partners"
  description="Apply to join the WolfWay Logistics carrier network. Consistent loads and fair rates for flatbed and open-deck carriers."
>
  <!-- Page Header -->
  <section class="bg-navy pt-36 pb-24 relative overflow-hidden">
    <div class="mx-auto max-w-7xl px-5 lg:px-10 relative z-10">
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold uppercase text-white leading-none tracking-tight">
        Join Our Carrier Network
      </h1>
      <p class="mt-5 max-w-2xl text-base md:text-lg text-white/60 font-body font-light leading-relaxed">
        We're always looking for reliable flatbed and open-deck carriers to grow with us. Apply today and start hauling.
      </p>
    </div>
  </section>

  <!-- Modern Spacious Content Section -->
  <section class="bg-offwhite py-20 sm:py-24 relative overflow-hidden animate-fade-in" data-animate="fade-up">
    <div class="mx-auto max-w-7xl px-5 lg:px-10 relative z-10">
      
      <!-- Side-by-Side Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        
        <!-- Left Column: Reasons to Partner -->
        <div class="lg:col-span-5 space-y-5">
          <div class="mb-2">
            <h2 class="font-heading text-2xl font-bold uppercase text-ink">
              Why Partner With WolfWay
            </h2>
            <p class="text-slate-500 font-body font-light text-sm mt-1">
              We treat our carriers like partners because that's what you are.
            </p>
          </div>

          {reasons.map((r) => (
            <div class="flex items-start gap-4 p-6 bg-white border border-slate-200/40 rounded-sm hover:border-cyan/30 hover:shadow-sm transition-all duration-300 group">
              <!-- Icon Container -->
              <div class="flex-shrink-0 flex items-center justify-center h-11 w-11 rounded-sm border border-slate-200 bg-slate-50 text-slate-600 group-hover:border-cyan/30 group-hover:text-cyan transition-colors">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={r.icon} />
                </svg>
              </div>
              
              <div>
                <h3 class="font-heading text-base font-bold uppercase text-ink mb-2 tracking-tight">
                  {r.title}
                </h3>
                <p class="text-slate-500 font-body font-light text-sm leading-relaxed">
                  {r.description}
                </p>
              </div>
            </div>
          ))}
        </div>

        <!-- Right Column: Carrier Partnership Form -->
        <div class="lg:col-span-7 bg-white p-8 sm:p-12 border border-slate-200/40 rounded-sm shadow-sm relative">
          <!-- Top highlight line -->
          <div class="absolute top-0 left-0 right-0 h-1 bg-cyan rounded-t-sm"></div>
          
          <div class="mb-8">
            <h3 class="font-heading text-2xl font-bold uppercase text-ink">
              Apply to Join
            </h3>
            <p class="text-slate-400 text-xs mt-1.5 font-body">
              Complete the form below and our carrier relations team will review your application.
            </p>
          </div>
          
          <CarrierForm />
        </div>

      </div>

    </div>
  </section>
</BaseLayout>
