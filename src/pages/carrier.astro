---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CarrierForm from '@/components/CarrierForm.astro';
import FAQ from '@/components/FAQ.astro';

const reasons = [
  {
    title: 'Consistent Volume',
    description: 'We move open-deck freight daily. Our shipping partners provide steady, year-round loads so your trucks stay busy and moving.',
    icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  },
  {
    title: 'Fair Rates & Fast Pay',
    description: 'We believe in sustainable partnerships. Our freight rates reflect real-time market indices, with prompt payment schedules.',
    icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: '24/7 Dispatch Support',
    description: 'Clear, direct communication with a dedicated coordinator. No automated loops, just professional dispatchers who answer.',
    icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
  },
];

const requirements = [
  'Active Interstate Authority (MC Number) for at least 6 months',
  'Satisfactory FMCSA safety rating',
  'Minimum $1,000,000 Auto Liability insurance coverage',
  'Minimum $100,000 Cargo Insurance coverage',
  'Proper load securement equipment (chains, straps, binders, tarps)',
];

const faqItems = [
  {
    question: "How do I apply as a carrier partner?",
    answer: "Complete our quick onboarding form below. Our compliance team will review your USDOT safety rating, MC authority history, and active insurance coverage."
  },
  {
    question: "What equipment configurations does WolfWay coordinate?",
    answer: "We primarily move flatbeds, step decks, double drops, and conestogas. All dispatched carriers must carry proper chains, straps, edge protectors, and steel or lumber tarps."
  },
  {
    question: "What are your payment terms?",
    answer: "We offer prompt carrier payment options upon receipt of clean proof of delivery (POD) documents. Standard payment schedules and quick-pay terms are available."
  },
  {
    question: "Are owner operators welcome in the network?",
    answer: "Yes, we coordinate shipments for both fleet carriers and independent owner operators holding active authority and meeting our FMCSA safety requirements."
  }
];
---

<BaseLayout
  title="Carrier Partners"
  description="Apply to join the WolfWay Logistics LLC carrier network. Consistent loads and fair rates for flatbed and open-deck carriers."
>
  <!-- Page Header -->
  <section class="bg-navy pt-36 pb-24 relative overflow-hidden">
    <div class="mx-auto max-w-7xl px-5 lg:px-10 relative z-10">
      <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-cyan mb-3">
        CARRIER NETWORK
      </p>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold uppercase text-white leading-none tracking-tight">
        Join Our Carrier Network
      </h1>
      <p class="mt-5 max-w-2xl text-base md:text-lg text-white/60 font-body font-light leading-relaxed">
        We partner with safety-minded flatbed and open-deck carriers across the United States. Apply today to access consistent volume and fair rates.
      </p>
    </div>
  </section>

  <!-- Section 1: Why Partner With Us (3-Column Grid) -->
  <section class="bg-white py-16 sm:py-20 border-b border-slate-100 select-none">
    <div class="mx-auto max-w-7xl px-5 lg:px-10">
      <div class="mb-12">
        <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-[#005F8A] mb-3">
          MUTUAL GROWTH
        </p>
        <h2 class="font-heading text-2xl sm:text-3xl font-bold uppercase text-ink">
          Why Partner With WolfWay Logistics LLC
        </h2>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {reasons.map((r) => (
          <div class="flex flex-col p-6 bg-slate-50/50 border border-slate-100 rounded-sm hover:border-cyan/20 hover:shadow-sm transition-all duration-300 group">
            <!-- Icon -->
            <div class="flex items-center justify-center h-11 w-11 rounded-sm border border-slate-200 bg-white text-slate-600 group-hover:border-cyan/30 group-hover:text-cyan transition-colors mb-5">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={r.icon} />
              </svg>
            </div>
            <h3 class="font-heading text-base font-bold uppercase text-ink mb-2">
              {r.title}
            </h3>
            <p class="text-sm leading-relaxed text-slate-600 font-body font-light">
              {r.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 2: Requirements (Split Layout) -->
  <section class="bg-[#F5F7FA] py-16 sm:py-20 border-b border-slate-100">
    <div class="mx-auto max-w-7xl px-5 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
        <!-- Requirements Checklist (Left) -->
        <div class="lg:col-span-6 space-y-6">
          <div>
            <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-[#005F8A] mb-3">
              COMPLIANCE STANDARDS
            </p>
            <h2 class="font-heading text-2xl sm:text-3xl font-bold uppercase text-ink">
              Onboarding Requirements
            </h2>
            <p class="text-sm text-slate-600 font-body font-light mt-2 leading-relaxed">
              To maintain the integrity and safety standards of our shipper network, all carriers must meet the following criteria:
            </p>
          </div>

          <ul class="space-y-3">
            {requirements.map((req) => (
              <li class="flex items-start gap-3 text-sm text-slate-600 font-body font-light">
                <svg class="h-5 w-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>{req}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Image Box (Right) -->
        <div class="lg:col-span-6 relative overflow-hidden border border-slate-200/40 rounded-sm shadow-sm aspect-[16/10] bg-slate-200">
          <img
            src="/images/services/open-deck.jpg"
            alt="WolfWay open deck flatbed trailer with cargo secured on the road"
            class="object-cover w-full h-full"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: The Form (Centered, Focused Box) -->
  <section class="bg-white py-20 sm:py-24 border-b border-slate-100">
    <div class="mx-auto max-w-3xl px-5 lg:px-0 relative">
      <!-- Top highlight line -->
      <div class="absolute top-0 left-5 right-5 h-[2px] bg-cyan/30"></div>

      <div class="text-center mb-12 pt-8">
        <h2 class="font-heading text-3xl font-bold uppercase text-ink">
          Apply to Join Network
        </h2>
        <p class="text-slate-600 text-sm mt-2 font-body font-light max-w-lg mx-auto">
          Complete the form below and our onboarding team will review your authority and insurance credentials.
        </p>
      </div>

      <div class="border border-slate-200/60 p-8 sm:p-12 rounded-sm shadow-sm bg-slate-50/10">
        <CarrierForm />
      </div>
    </div>
  </section>

  <!-- Section 4: Onboarding FAQ -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-5 lg:px-10">
      <FAQ items={faqItems} title="Carrier Partner FAQ" eyebrow="CARRIER ONBOARDING" />
    </div>
  </section>
</BaseLayout>
