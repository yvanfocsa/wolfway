---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import DriverForm from '@/components/DriverForm.astro';
import FAQ from '@/components/FAQ.astro';
import ResponsiveImage from '@/components/ResponsiveImage.astro';
import { serviceImages } from '@/content/images';
import { absoluteUrl } from '@/content/seo';

const driverBenefits = [
  {
    title: 'Competitive, Transparent Pay',
    description: 'Per-mile pay, tarp pay, detention compensation, and safety incentives are explained before you commit to a route.',
    icon: 'M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Modern Air-Ride Equipment',
    description: 'Late-model open-deck and flatbed equipment with APUs, inverters, and well-maintained air-ride suspension.',
    icon: 'M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12',
  },
  {
    title: 'A Dispatcher Who Knows Your Load',
    description: 'A real coordinator is available day or night with the route, equipment, and customer context already in hand.',
    icon: 'M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155',
  },
  {
    title: 'Open-Deck Routes With a Plan',
    description: 'Dedicated corridors are planned around freight demand, securement needs, and realistic home-time conversations.',
    icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7',
  },
];

const driverRequirements = [
  'Valid Class A CDL license',
  'At least 1 year of verifiable OTR trucking experience',
  'Clean Motor Vehicle Record (MVR) and PSP safety reports',
  'Open-deck or flatbed securement experience preferred',
  'At least 22 years old and eligible to work in the United States',
];

const driverFAQItems = [
  {
    question: 'What qualifications do I need to apply as a driver?',
    answer: 'You need a valid Class A CDL license, at least one year of verifiable OTR experience, a safe driving record, and familiarity with open-deck or flatbed securement.',
  },
  {
    question: 'How long is the orientation process?',
    answer: 'Orientation is designed to be completed in one day. We cover paperwork, safety procedures, equipment inspection, and the next steps for load assignment.',
  },
  {
    question: 'Do you work with owner-operators as well as company drivers?',
    answer: 'Yes. We welcome applications from qualified company drivers and independent owner-operators who meet our safety and equipment requirements.',
  },
  {
    question: 'How does dispatch communication work?',
    answer: 'Drivers work with a dedicated dispatch coordinator who has the load context, plans ahead, and can be reached around the clock when the route needs attention.',
  },
];

const driverStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'JobPosting',
    title: 'CDL-A Open-Deck Driver',
    description: 'Drive open-deck and flatbed freight with modern air-ride equipment, dedicated dispatch support, and a streamlined one-day orientation.',
    datePosted: '2026-07-01',
    employmentType: 'FULL_TIME',
    directApply: true,
    hiringOrganization: {
      '@type': 'Organization',
      name: 'WolfWay Logistics LLC',
      sameAs: absoluteUrl('/'),
      logo: absoluteUrl('/images/logo_icon.png'),
    },
    jobLocation: {
      '@type': 'Place',
      address: {
        '@type': 'PostalAddress',
        addressCountry: 'US',
      },
    },
    applicantLocationRequirements: {
      '@type': 'Country',
      name: 'United States',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: driverFAQItems.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  },
];
---

<BaseLayout
  title="Drive With Us | CDL-A Driver Careers"
  description="Apply to drive with WolfWay Logistics LLC. Modern air-ride open-deck equipment, streamlined orientation, and 24/7 human dispatch support."
  structuredData={driverStructuredData}
>
  <section class="driver-hero relative h-[100svh] min-h-[600px] overflow-hidden bg-navy text-white lg:h-[100dvh]">
    <div id="hero-bg-container" class="absolute inset-0" aria-hidden="true">
      <ResponsiveImage
        asset={serviceImages.flatbed}
        alt=""
        pictureClass="h-full w-full"
        class="h-full w-full object-cover object-center"
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-navy/80"></div>
    </div>

    <div class="page-shell relative z-10 flex h-full flex-col justify-end pb-8 pt-32 sm:pb-12 lg:pb-16">
      <div class="max-w-4xl">
        <p class="mb-3 text-base font-bold text-cyan">CDL-A OPEN-DECK CAREERS</p>
        <h1 class="max-w-[14ch] font-heading text-[clamp(3.25rem,7.5vw,5.75rem)] font-extrabold uppercase leading-[0.94] tracking-normal text-white">
          Built for drivers who know the road.
        </h1>
        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-white/85 sm:text-xl">
          Modern air-ride equipment, clear pay conversations, and dispatchers who know the load before you call.
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:gap-4">
          <Button variant="primary" href="#pre-qualify-form" size="lg" arrow={true} class="w-full justify-center sm:w-auto">
            Start Pre-Qualification
          </Button>
          <Button variant="outline" href="tel:+12244464256" size="lg" class="w-full justify-center sm:w-auto">
            Call Recruiting
          </Button>
        </div>
      </div>

    </div>
  </section>

  <section class="border-b border-slate-200 bg-white" aria-label="Driver program highlights">
    <dl class="page-shell grid grid-cols-2 sm:grid-cols-4">
      <div class="py-5 pr-4 sm:border-r sm:border-slate-200">
        <dt class="text-[15px] leading-tight text-slate-500">Equipment</dt>
        <dd class="mt-1 font-heading text-2xl font-bold uppercase text-ink">Air-Ride</dd>
      </div>
      <div class="border-l border-slate-200 py-5 pl-4 sm:border-l-0 sm:border-r sm:px-5">
        <dt class="text-[15px] leading-tight text-slate-500">Dispatch</dt>
        <dd class="mt-1 font-heading text-2xl font-bold uppercase text-ink">24 / 7</dd>
      </div>
      <div class="border-t border-slate-200 py-5 pr-4 sm:border-r sm:border-t-0 sm:px-5">
        <dt class="text-[15px] leading-tight text-slate-500">Orientation</dt>
        <dd class="mt-1 font-heading text-2xl font-bold uppercase text-ink">1 Day</dd>
      </div>
      <div class="border-l border-t border-slate-200 py-5 pl-4 sm:border-l-0 sm:border-t-0 sm:pl-5">
        <dt class="text-[15px] leading-tight text-slate-500">Applicants</dt>
        <dd class="mt-1 font-heading text-2xl font-bold uppercase text-cyan-dark">US CDL-A</dd>
      </div>
    </dl>
  </section>

  <section class="section-band bg-white">
    <div class="page-shell">
      <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
        <h2 class="section-title text-ink">A direct path from application to the road</h2>
        <p class="section-copy lg:justify-self-end">
          Start with the essentials. A recruiter reviews your fit, answers the practical questions, and keeps every next step clear.
        </p>
      </div>

      <ol class="mt-14 grid gap-8 md:grid-cols-3 md:gap-0">
        <li class="border-t-2 border-cyan pt-6 md:pr-10">
          <span class="font-heading text-4xl font-extrabold text-cyan-dark">01</span>
          <h3 class="mt-5 font-heading text-2xl font-bold uppercase text-ink">Share the essentials</h3>
          <p class="mt-3 text-base leading-relaxed text-slate-600">Tell us who you are, where you are based, and your CDL-A experience. No SSN or full license number online.</p>
        </li>
        <li class="border-t-2 border-slate-300 pt-6 md:border-l md:px-10">
          <span class="font-heading text-4xl font-extrabold text-slate-400">02</span>
          <h3 class="mt-5 font-heading text-2xl font-bold uppercase text-ink">Talk with a recruiter</h3>
          <p class="mt-3 text-base leading-relaxed text-slate-600">A real person confirms qualifications and covers pay, equipment, routes, and availability with you directly.</p>
        </li>
        <li class="border-t-2 border-slate-300 pt-6 md:border-l md:pl-10">
          <span class="font-heading text-4xl font-extrabold text-slate-400">03</span>
          <h3 class="mt-5 font-heading text-2xl font-bold uppercase text-ink">Orient and roll</h3>
          <p class="mt-3 text-base leading-relaxed text-slate-600">Complete the safety and equipment review, confirm a start date, and move into your first assignment.</p>
        </li>
      </ol>
    </div>
  </section>

  <section class="section-band bg-offwhite">
    <div class="page-shell">
      <div class="max-w-3xl">
        <h2 class="section-title text-ink">The details that matter after mile one</h2>
        <p class="section-copy mt-5">Good equipment is only the start. The day-to-day experience depends on honest communication and decisions made with the driver in the room.</p>
      </div>

      <div class="mt-12 grid gap-x-12 lg:grid-cols-2">
        {driverBenefits.map((benefit) => (
          <article class="grid grid-cols-[3rem_1fr] gap-5 border-t border-slate-300 py-7">
            <div class="flex h-12 w-12 items-center justify-center rounded-md bg-navy text-cyan">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={benefit.icon} />
              </svg>
            </div>
            <div>
              <h3 class="font-heading text-2xl font-bold uppercase leading-tight text-ink">{benefit.title}</h3>
              <p class="mt-2 text-base leading-relaxed text-slate-600">{benefit.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-band bg-white">
    <div class="page-shell grid gap-10 lg:grid-cols-2 lg:items-center lg:gap-16">
      <figure class="relative aspect-[4/3] overflow-hidden rounded-lg bg-slate-200">
        <ResponsiveImage
          asset={serviceImages.openDeck}
          alt="Open-deck trucks staged with secured freight in an industrial yard"
          pictureClass="h-full w-full"
          class="h-full w-full object-cover"
          loading="lazy"
          sizes="(min-width: 1024px) 50vw, 100vw"
        />
        <figcaption class="absolute bottom-0 left-0 bg-navy px-5 py-3 text-base font-semibold text-white">
          Open-deck freight across the lower 48
        </figcaption>
      </figure>

      <div>
        <h2 class="section-title text-ink">Driver criteria</h2>
        <p class="section-copy mt-5">Safety comes before speed. Applicants should be ready to verify the following with our recruiting team.</p>
        <ul class="mt-8 divide-y divide-slate-200 border-y border-slate-200">
          {driverRequirements.map((requirement) => (
            <li class="flex items-start gap-4 py-4 text-base font-semibold leading-relaxed text-slate-700">
              <svg class="mt-0.5 h-6 w-6 shrink-0 text-cyan-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75 10.5 18l9-13.5" />
              </svg>
              <span>{requirement}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section id="pre-qualify-form" class="section-band bg-offwhite">
    <div class="page-shell grid gap-10 lg:grid-cols-[0.72fr_1.28fr] lg:gap-16">
      <aside class="lg:sticky lg:top-28 lg:self-start">
        <h2 class="section-title text-ink">Start your application</h2>
        <p class="section-copy mt-5">Three focused steps. A recruiter follows up directly after reviewing your qualifications.</p>

        <div class="mt-8 border-t border-slate-300">
          <div class="flex gap-4 border-b border-slate-300 py-5">
            <svg class="mt-0.5 h-6 w-6 shrink-0 text-cyan-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div><strong class="block text-base text-navy">No sensitive identity numbers</strong><span class="text-[15px] leading-relaxed text-slate-600">SSN and full CDL details stay out of this public form.</span></div>
          </div>
          <div class="flex gap-4 border-b border-slate-300 py-5">
            <svg class="mt-0.5 h-6 w-6 shrink-0 text-cyan-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            <div><strong class="block text-base text-navy">Human follow-up</strong><span class="text-[15px] leading-relaxed text-slate-600">Questions? Call recruiting at +1 (224) 446-4256.</span></div>
          </div>
        </div>
      </aside>

      <div class="form-panel p-6 sm:p-9 lg:p-10">
        <DriverForm />
      </div>
    </div>
  </section>

  <section class="section-band-compact bg-white">
    <div class="page-shell">
      <FAQ items={driverFAQItems} title="Driver Careers FAQ" eyebrow="" />
    </div>
  </section>
</BaseLayout>
