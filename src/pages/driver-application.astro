---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import DriverForm from '@/components/DriverForm.astro';
---

<BaseLayout
  title="Driver Recruitment Portal | WolfWay Logistics LLC"
  description="Official CDL-A Driver Application Portal for WolfWay Logistics LLC. Complete your 30-second pre-qualification and DOT driver application."
>
  <PageHero
    title="WolfWay Driver Application"
    description="Complete three focused pre-qualification steps. A dedicated recruiter will review your information and contact you within 24 hours."
    align="center"
    compact={true}
  >
    <p slot="actions" class="mt-5 text-base text-white/75">Need help? <a href="tel:+12244464256" class="inline-flex min-h-11 items-center font-bold text-cyan hover:underline">Call recruiting at +1 (224) 446-4256</a></p>
  </PageHero>

  <!-- Standalone Portal Application Container -->
  <section class="bg-offwhite py-16 sm:py-20 border-b border-slate-200/60 select-none flex-1">
    <div class="mx-auto max-w-3xl px-5 lg:px-0">
      <div class="form-panel p-6 sm:p-10">
        <DriverForm />
      </div>

      <!-- Trust Disclosures Footer -->
      <div class="mx-auto mt-8 max-w-2xl space-y-2 text-center text-[15px] leading-relaxed text-slate-600 font-body">
        <p>&copy; 2026 WolfWay Logistics LLC. All information collected is protected under FMCSA DOT equal opportunity standards.</p>
        <p>WolfWay Logistics LLC operates in the United States. This portal is available to US drivers only.</p>
      </div>
    </div>
  </section>
</BaseLayout>
