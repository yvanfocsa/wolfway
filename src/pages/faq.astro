---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import CTASection from '@/components/CTASection.astro';
import { shipperFAQs, driverFAQs } from '@/content/faq';
---

<BaseLayout
  title="Frequently Asked Questions | WolfWay Logistics LLC"
  description="Find quick answers to common questions about freight shipping, open-deck equipment, driver qualification, rates, and 24/7 dispatch support."
>
  <!-- Page Header -->
  <section class="bg-navy pt-36 pb-20 relative overflow-hidden select-none">
    <div class="mx-auto max-w-7xl px-5 lg:px-10 relative z-10 text-center">
      <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-cyan mb-3">
        KNOWLEDGE BASE
      </p>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold uppercase text-white leading-none tracking-tight">
        Frequently Asked Questions
      </h1>
      <p class="mt-4 max-w-2xl mx-auto text-base sm:text-lg text-white/70 font-body font-light leading-relaxed">
        Everything you need to know about shipping open-deck freight, driver opportunities, equipment specs, and dispatch coordination.
      </p>
    </div>
  </section>

  <!-- Interactive FAQ Section -->
  <section class="bg-offwhite py-16 sm:py-20 border-b border-slate-200/60 select-none">
    <div class="mx-auto max-w-5xl px-5 lg:px-10">
      
      <!-- Category Tabs -->
      <div class="flex justify-center mb-10">
        <div class="inline-flex p-1.5 bg-slate-200/70 rounded-xl border border-slate-300/50 gap-2">
          <button
            id="tab-shippers"
            class="px-6 py-3 rounded-lg font-heading text-sm font-bold uppercase tracking-wider transition-all duration-200 bg-white text-ink shadow-xs"
          >
            Shippers
          </button>
          <button
            id="tab-drivers"
            class="px-6 py-3 rounded-lg font-heading text-sm font-bold uppercase tracking-wider transition-all duration-200 text-slate-600 hover:text-ink"
          >
            Drivers
          </button>
        </div>
      </div>

      <!-- Shippers FAQ Container -->
      <div id="faq-shippers-container" class="space-y-4">
        {shipperFAQs.map((faq, idx) => (
          <details class="group bg-white border border-slate-200/80 rounded-xl overflow-hidden transition-all duration-300 shadow-xs open:border-cyan/40">
            <summary class="flex items-center justify-between p-6 cursor-pointer select-none font-heading text-lg font-bold uppercase text-ink group-hover:text-cyan transition-colors">
              <span>{faq.question}</span>
              <span class="ml-4 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-slate-100 group-open:bg-cyan group-open:text-navy transition-colors">
                <svg class="h-4 w-4 transition-transform duration-300 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </summary>
            <div class="px-6 pb-6 pt-2 text-slate-600 font-body font-light text-sm leading-relaxed border-t border-slate-100">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>

      <!-- Drivers FAQ Container (Hidden initially) -->
      <div id="faq-drivers-container" class="space-y-4 hidden">
        {driverFAQs.map((faq, idx) => (
          <details class="group bg-white border border-slate-200/80 rounded-xl overflow-hidden transition-all duration-300 shadow-xs open:border-cyan/40">
            <summary class="flex items-center justify-between p-6 cursor-pointer select-none font-heading text-lg font-bold uppercase text-ink group-hover:text-cyan transition-colors">
              <span>{faq.question}</span>
              <span class="ml-4 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-slate-100 group-open:bg-cyan group-open:text-navy transition-colors">
                <svg class="h-4 w-4 transition-transform duration-300 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </summary>
            <div class="px-6 pb-6 pt-2 text-slate-600 font-body font-light text-sm leading-relaxed border-t border-slate-100">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>

      <!-- Help Card -->
      <div class="mt-14 p-8 bg-white border border-slate-200/80 rounded-xl text-center shadow-xs">
        <h3 class="font-heading text-xl font-bold uppercase text-ink mb-2">Still have questions?</h3>
        <p class="text-sm text-slate-500 font-body font-light mb-6">Our 24/7 dispatch coordinators are standing by to assist with your specific shipping needs.</p>
        <div class="flex justify-center gap-4">
          <Button href="/contact" variant="primary" size="md">
            Speak with Dispatch
          </Button>
          <Button href="/request-a-quote" variant="secondary" size="md">
            Request Freight Quote
          </Button>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <CTASection
    variant="dark"
    eyebrow="READY TO SHIP?"
    heading="Move Your Cargo With Confidence"
    description="Get a fast, transparent quote for flatbed, step deck, or specialized open-deck freight today."
    buttonText="REQUEST A FREIGHT QUOTE"
    buttonHref="/request-a-quote"
  />
</BaseLayout>

<script>
  function setupFAQTabs() {
    const tabShippers = document.getElementById('tab-shippers');
    const tabDrivers = document.getElementById('tab-drivers');
    const containerShippers = document.getElementById('faq-shippers-container');
    const containerDrivers = document.getElementById('faq-drivers-container');

    if (!tabShippers || !tabDrivers || !containerShippers || !containerDrivers) return;

    tabShippers.addEventListener('click', () => {
      tabShippers.className = 'px-6 py-3 rounded-lg font-heading text-sm font-bold uppercase tracking-wider transition-all duration-200 bg-white text-ink shadow-xs';
      tabDrivers.className = 'px-6 py-3 rounded-lg font-heading text-sm font-bold uppercase tracking-wider transition-all duration-200 text-slate-600 hover:text-ink';
      containerShippers.classList.remove('hidden');
      containerDrivers.classList.add('hidden');
    });

    tabDrivers.addEventListener('click', () => {
      tabDrivers.className = 'px-6 py-3 rounded-lg font-heading text-sm font-bold uppercase tracking-wider transition-all duration-200 bg-white text-ink shadow-xs';
      tabShippers.className = 'px-6 py-3 rounded-lg font-heading text-sm font-bold uppercase tracking-wider transition-all duration-200 text-slate-600 hover:text-ink';
      containerDrivers.classList.remove('hidden');
      containerShippers.classList.add('hidden');
    });
  }

  setupFAQTabs();
  document.addEventListener('astro:page-load', setupFAQTabs);
</script>
