---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import AudienceSelector from '@/components/AudienceSelector.astro';
import ProcessRouteLine from '@/components/ProcessRouteLine.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import HowItWorks from '@/components/HowItWorks.astro';
import SplitAudience from '@/components/SplitAudience.astro';
import CTASection from '@/components/CTASection.astro';
import { principles } from '@/content/company';
import { services } from '@/content/services';
---

<BaseLayout
  title="WolfWay Logistics LLC"
  description="Open-deck freight transportation, featuring flatbed, step deck, and open deck logistics built around safety, communication and dependable delivery."
>
  <!-- 1. Video Hero -->
  <Hero />

  <!-- 2. Audience Selector -->
  <AudienceSelector />

  <!-- 3. Process Route Line (Inline SVG) -->
  <ProcessRouteLine />

  <!-- 4. Services Section -->
  <section class="bg-offwhite py-16 sm:py-20 lg:py-28 services-section" data-animate="fade-up">
    <div class="mx-auto max-w-7xl px-5 lg:px-10">
      <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-[#005F8A] mb-3">
        WHAT WE HAUL
      </p>
      <h2 class="font-heading text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold uppercase text-ink mb-12">
        Our Services
      </h2>

      <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3">
        {services.map((s, idx) => (
          <div class="service-card-reveal">
            <ServiceCard
              title={s.title}
              description={s.description}
              imageAlt={s.imageAlt}
              imagePath={s.imagePath}
              href={`/services#${s.slug}`}
              index={idx + 1}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. Brand Principles Section -->
  <section class="bg-white py-16 sm:py-20 lg:py-28 border-b border-slate-100" data-animate="fade-up">
    <div class="mx-auto max-w-7xl px-5 lg:px-10">
      <div class="mb-12 sm:mb-16">
        <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-[#005F8A] mb-3">
          THE WOLFWAY LOGISTICS LLC STANDARD
        </p>
        <h2 class="font-heading text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold uppercase text-ink">
          Safety-first open-deck shipping
        </h2>
      </div>
      <div class="grid gap-8 sm:gap-10 sm:grid-cols-2 md:grid-cols-3">
        {principles.map((p) => (
          <div class="border-t-2 border-cyan pt-5">
            <h3 class="font-heading text-lg sm:text-xl font-semibold uppercase tracking-wide text-ink">
              {p.title}
            </h3>
            <p class="mt-2.5 text-sm leading-relaxed text-slate-600 font-body font-light">
              {p.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. How It Works Section -->
  <HowItWorks />

  <!-- 7. Recruitment & Carrier CTA -->
  <SplitAudience />

  <!-- 8. Final Freight Quote CTA -->
  <CTASection
    variant="dark"
    eyebrow="READY TO SHIP?"
    heading="Ready to Move Your Freight?"
    description="Get a competitive rate quote for flatbed, step deck, or specialized open-deck transportation from pickup to delivery."
    buttonText="REQUEST A FREIGHT QUOTE"
    buttonHref="/request-a-quote"
  />
</BaseLayout>
