---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import HeroTrustBar from '@/components/HeroTrustBar.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import HowItWorks from '@/components/HowItWorks.astro';
import OurStory from '@/components/OurStory.astro';
import SplitAudience from '@/components/SplitAudience.astro';
import CTASection from '@/components/CTASection.astro';
import ComplianceShowcase from '@/components/ComplianceShowcase.astro';
import FreightCapabilities from '@/components/FreightCapabilities.astro';
import { services } from '@/content/services';
import { absoluteUrl } from '@/content/seo';

const homeStructuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Open-deck freight transportation',
    provider: {
      '@type': 'Organization',
      name: 'WolfWay Logistics LLC',
      url: absoluteUrl('/'),
    },
    areaServed: 'United States',
    serviceType: ['Flatbed Freight', 'Step Deck Transport', 'Open Deck Logistics'],
    url: absoluteUrl('/services'),
  },
];
---

<BaseLayout
  title="WolfWay Logistics LLC"
  description="Open-deck freight transportation, featuring flatbed, step deck, and open deck logistics built around safety, communication and dependable delivery."
  structuredData={homeStructuredData}
>
  <!-- 1. Video Hero -->
  <Hero />

  <!-- 2. Trust & Stats Bar -->
  <HeroTrustBar />

  <!-- 3. Our Story / Heritage Section -->
  <OurStory />

  <!-- 4. Services Section -->
  <section class="bg-offwhite py-16 sm:py-20 lg:py-24 services-section">
    <div class="mx-auto max-w-7xl px-5 lg:px-10">
      <div class="mb-12 grid gap-5 md:grid-cols-[1fr_0.8fr] md:items-end">
        <div>
          <h2 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-extrabold uppercase leading-none text-ink">
            Equipment matched to the freight
          </h2>
        </div>
        <p class="max-w-xl text-base sm:text-lg leading-relaxed text-slate-600 md:justify-self-end">
          Flatbed, step deck, and coordinated open-deck capacity for freight that demands more planning than a standard trailer.
        </p>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3">
        {services.map((s) => (
          <div class="service-card-reveal">
            <ServiceCard
              title={s.title}
              description={s.description}
              imageAlt={s.imageAlt}
              image={s.image}
              href={`/services#${s.slug}`}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. Freight Capabilities -->
  <FreightCapabilities />

  <!-- 6. Load Protection / Compliance Section -->
  <ComplianceShowcase />

  <!-- 7. How It Works Section -->
  <HowItWorks />

  <!-- 8. Recruitment & Carrier CTA -->
  <SplitAudience />

  <!-- 9. Final Freight Quote CTA -->
  <CTASection
    variant="dark"
    heading="Ready to Move Your Freight?"
    description="Get a competitive rate quote for flatbed, step deck, or specialized open-deck transportation from pickup to delivery."
    buttonText="REQUEST A FREIGHT QUOTE"
    buttonHref="/request-a-quote"
  />
</BaseLayout>
