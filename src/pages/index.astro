---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import TrustBar from '@/components/TrustBar.astro';
import StatsCounter from '@/components/StatsCounter.astro';
import HowItWorks from '@/components/HowItWorks.astro';
import SplitAudience from '@/components/SplitAudience.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import { principles } from '@/content/company';
import { services } from '@/content/services';

const reviews = [
  {
    name: 'Marcus Vance',
    role: 'Logistics Director, Steelworks Inc.',
    text: 'WolfWay Logistics has moved over 120 loads of heavy flatbed and step-deck cargo for us this year. Their communication is hands-down the best in the industry.',
    stars: 5,
    date: '2 weeks ago',
  },
  {
    name: 'Sarah Jennings',
    role: 'Supply Chain Manager, Apex Energy',
    text: 'Extremely dependable open-deck carrier. We ship high-value power equipment that requires specialized step decks. WolfWay handles every load with absolute safety.',
    stars: 5,
    date: '1 month ago',
  },
  {
    name: 'David K. Miller',
    role: 'Owner Operator, Miller Heavy Haul',
    text: 'Hauling for WolfWay is great. Clear dispatch instructions, fast setup, and prompt weekly pay. They treat owner operators with respect and keep our trucks moving.',
    stars: 5,
    date: '3 weeks ago',
  },
  {
    name: 'Robert Chen',
    role: 'Vanguard Manufacturing',
    text: 'Our previous broker constantly missed pickup windows. Since switching to WolfWay, our delivery success rate is at 99%. Extremely professional and reliable.',
    stars: 5,
    date: '4 days ago',
  },
  {
    name: 'Elena Rostova',
    role: 'Project Logistics Director',
    text: 'Their carriers are top-tier. They arrive on time, understand proper flatbed load securement, and handle oversized freight with maximum care and safety.',
    stars: 5,
    date: '1 week ago',
  },
  {
    name: 'Marcus Thorne',
    role: 'Owner Operator',
    text: 'Best broker I\'ve worked with in ten years of driving. Quick load dispatch, fair detention pay, and they don\'t play games with market rates.',
    stars: 5,
    date: '5 days ago',
  },
  {
    name: 'Jonathan Hale',
    role: 'GE Power Logistics',
    text: 'WolfWay handled our oversized wind turbine shipment flawlessly. The permit coordination, route planning, and escorts were executed perfectly.',
    stars: 5,
    date: '3 days ago',
  },
  {
    name: 'Amanda Ross',
    role: 'Supply Chain Lead',
    text: 'Outstanding customer service. Whenever there is a weather delay or route change, their dispatch team alerts us immediately. Highly recommend.',
    stars: 5,
    date: '1 month ago',
  },
  {
    name: 'Kenji Sato',
    role: 'Operations Manager, Sato Trucking',
    text: 'Fair rates and reliable loads. They keep our fleet active all year round. Dispatch communicates clearly, is transparent, and pays on time.',
    stars: 5,
    date: '2 weeks ago',
  },
];
---

<BaseLayout
  title="WolfWay Logistics LLC"
  description="Open-deck freight transportation, featuring flatbed, step deck, and open deck logistics built around safety, communication and dependable delivery."
>
  <!-- Hero -->
  <Hero />

  <!-- Trust Bar -->
  <TrustBar />

  <!-- Three Principles -->
  <section class="bg-offwhite py-14 sm:py-20 lg:py-28" data-animate="fade-up">
    <div class="mx-auto max-w-7xl px-5 lg:px-10">
      <div class="mb-12 sm:mb-16">
        <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-cyan mb-3">
          THE WOLFWAY STANDARD
        </p>
        <h2 class="font-heading text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold uppercase text-ink">
          Safety-first open-deck shipping
        </h2>
      </div>
      <div class="grid gap-8 sm:gap-10 sm:grid-cols-2 md:grid-cols-3">
        {principles.map((p) => (
          <div class="border-t-2 border-cyan pt-5">
            <h3 class="font-heading text-lg sm:text-xl font-semibold uppercase tracking-wide text-ink">
              {p.title}
            </h3>
            <p class="mt-2.5 text-sm leading-relaxed text-steel">
              {p.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="bg-offwhite py-14 sm:py-20 lg:py-28 border-t border-slate-200/40" data-animate="fade-up">
    <div class="mx-auto max-w-7xl px-5 lg:px-10">
      <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-cyan mb-3">
        WHAT WE HAUL
      </p>
      <h2 class="font-heading text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold uppercase text-ink">
        Our Services
      </h2>

      <div class="mt-8 sm:mt-12 grid gap-8 sm:grid-cols-2 md:grid-cols-3">
        {services.map((s) => (
          <ServiceCard
            title={s.title}
            description={s.description}
            imageAlt={s.imageAlt}
            imagePath={s.imagePath}
            href={`/services#${s.slug}`}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <HowItWorks />

  <!-- Stats Counter Section -->
  <StatsCounter />

  <!-- Google Reviews Section (Premium Carousel - 9 cards total, 3 by 3) -->
  <section class="bg-navy py-14 sm:py-20 lg:py-28 text-white relative overflow-hidden" data-animate="fade-up">
    <!-- Subtle grid lines background -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff03_1px,transparent_1px),linear-gradient(to_bottom,#ffffff03_1px,transparent_1px)] bg-[size:4rem_4rem]" aria-hidden="true"></div>

    <div class="mx-auto max-w-7xl px-5 lg:px-10 relative z-10">
      <!-- Section Header -->
      <div class="text-center max-w-3xl mx-auto mb-10 sm:mb-14 lg:mb-16">
        <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-cyan mb-3">
          TRUSTED BY SHIPPERS & CARRIERS
        </p>
        <h2 class="font-heading text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold uppercase mb-4">What Our Partners Say</h2>
        <div class="flex items-center justify-center gap-1.5 pt-1">
          <span class="text-lg sm:text-xl font-bold text-cyan">5.0</span>
          <div class="flex text-yellow-400">
            {[...Array(5)].map(() => (
              <svg class="h-4 w-4 sm:h-5 sm:w-5 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <span class="text-sm text-steel ml-2 font-body font-medium">Google Reviews</span>
        </div>
      </div>

      <!-- Carousel Container Wrapper -->
      <div id="reviews-carousel-container" class="relative overflow-hidden w-full select-none touch-pan-y">
        <!-- Carousel Track -->
        <div id="reviews-track" class="flex gap-5 sm:gap-6 transition-transform duration-700 ease-[cubic-bezier(0.25,1,0.5,1)]">
          {reviews.map((r) => (
            <div class="review-card w-[85vw] sm:w-[75vw] md:w-[calc((100%-2.5rem)/3)] flex-shrink-0 bg-white/5 backdrop-blur-md border border-white/10 p-5 sm:p-7 flex flex-col justify-between hover:border-cyan/30 transition-all duration-300 group shadow-lg hover:shadow-[0_8px_30px_rgba(0,168,225,0.06)] hover:-translate-y-1 rounded-xl">
              <div>
                <div class="flex text-yellow-400 mb-4">
                  {[...Array(r.stars)].map(() => (
                    <svg class="h-4 w-4 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  ))}
                </div>
                <p class="text-sm leading-relaxed text-white/80 italic font-body font-light">
                  "{r.text}"
                </p>
              </div>
              <div class="mt-6 pt-5 border-t border-white/5 flex items-center justify-between">
                <div>
                  <p class="font-heading text-sm sm:text-base font-bold uppercase tracking-wider text-white">
                    {r.name}
                  </p>
                  <p class="text-xs text-steel font-body mt-0.5">
                    {r.role}
                  </p>
                </div>
                <span class="text-[10px] uppercase tracking-wider text-white/30 font-semibold font-body">
                  {r.date}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Dots — always visible, adapt count per breakpoint via JS -->
      <div id="reviews-dots" class="flex justify-center items-center gap-2 mt-8 sm:mt-10">
        <!-- JS will inject dots -->
      </div>

    </div>
  </section>

  <!-- Split Audience Section (Shippers / Drivers CTAs) -->
  <SplitAudience />
</BaseLayout>

<script>
  const track = document.getElementById('reviews-track') as HTMLElement | null;
  const dotsContainer = document.getElementById('reviews-dots');
  const container = document.getElementById('reviews-carousel-container');

  let currentIndex = 0;
  const TOTAL_REVIEWS = 9;
  const intervalTime = 10000;
  let autoRotateInterval: ReturnType<typeof setInterval>;
  let dots: HTMLButtonElement[] = [];

  function isMd() { return window.innerWidth >= 768; }
  function getSlideCount() { return isMd() ? 3 : TOTAL_REVIEWS; }

  // Build dots dynamically based on breakpoint
  function buildDots() {
    if (!dotsContainer) return;
    const count = getSlideCount();
    dotsContainer.innerHTML = '';
    dots = [];
    for (let i = 0; i < count; i++) {
      const btn = document.createElement('button');
      btn.className = 'rounded-full bg-white/20 transition-all duration-300 cursor-pointer';
      btn.style.cssText = 'width:6px;height:6px;padding:0;border:none;';
      btn.setAttribute('aria-label', `Go to slide ${i + 1}`);
      btn.addEventListener('click', () => {
        currentIndex = i;
        updateCarousel();
        stopAutoRotate();
        startAutoRotate();
      });
      dotsContainer.appendChild(btn);
      dots.push(btn);
    }
  }

  function updateCarousel() {
    if (!track) return;
    const md = isMd();
    const gap = md ? 24 : 20; // gap-6 or gap-5

    if (md) {
      // Desktop: slide by full container width for each group of 3
      const containerW = track.parentElement?.offsetWidth ?? 0;
      track.style.transform = `translateX(calc(-${currentIndex * containerW}px - ${currentIndex * gap}px))`;
    } else {
      // Mobile: each card is ~85vw, slide card by card
      const cardW = track.children[0]?.getBoundingClientRect().width ?? 0;
      track.style.transform = `translateX(calc(-${currentIndex * cardW}px - ${currentIndex * gap}px))`;
    }

    // Update dots
    dots.forEach((dot, idx) => {
      if (idx === currentIndex) {
        dot.style.width = md ? '16px' : '12px';
        dot.style.backgroundColor = '#00A8E1';
      } else {
        dot.style.width = '6px';
        dot.style.backgroundColor = 'rgba(255,255,255,0.2)';
      }
    });
  }

  function startAutoRotate() {
    autoRotateInterval = setInterval(() => {
      currentIndex = (currentIndex + 1) % getSlideCount();
      updateCarousel();
    }, intervalTime);
  }

  function stopAutoRotate() {
    clearInterval(autoRotateInterval);
  }

  // Touch / swipe support
  let touchStartX = 0;
  let touchStartY = 0;
  let isDragging = false;

  container?.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
    isDragging = true;
    stopAutoRotate();
  }, { passive: true });

  container?.addEventListener('touchmove', (e) => {
    if (!isDragging) return;
    const dx = e.touches[0].clientX - touchStartX;
    const dy = e.touches[0].clientY - touchStartY;
    // Only prevent scroll if horizontal gesture dominates
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 5) {
      e.preventDefault();
    }
  }, { passive: false });

  container?.addEventListener('touchend', (e) => {
    if (!isDragging) return;
    isDragging = false;
    const dx = touchStartX - e.changedTouches[0].clientX;
    const dy = touchStartY - e.changedTouches[0].clientY;
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
      const max = getSlideCount() - 1;
      if (dx > 0) currentIndex = Math.min(currentIndex + 1, max);
      else        currentIndex = Math.max(currentIndex - 1, 0);
      updateCarousel();
    }
    startAutoRotate();
  }, { passive: true });

  // Pause on hover (desktop)
  container?.addEventListener('mouseenter', stopAutoRotate);
  container?.addEventListener('mouseleave', startAutoRotate);

  // Resize handler
  let resizeTimeout: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
      const max = getSlideCount() - 1;
      if (currentIndex > max) currentIndex = max;
      buildDots();
      updateCarousel();
    }, 150);
  });

  // Init
  buildDots();
  updateCarousel();
  startAutoRotate();
</script>
