---
import BaseLayout from '@/layouts/BaseLayout.astro';
import QuoteForm from '@/components/QuoteForm.astro';

const industries = [
  'Construction & Heavy Machinery',
  'Steel, Pipe, & Industrial Metal',
  'Energy, Wind, & Oilfield Equipment',
  'Agricultural Machinery & Tractors',
  'Oversized & Permit-Required Loads',
];

const steps = [
  {
    num: '1',
    title: 'Submit Load Specs',
    desc: 'Fill out details about origin, destination, weight, dimensions, and preferred pick-up dates.',
  },
  {
    num: '2',
    title: 'Fast Rate Quote',
    desc: 'Our dispatch team reviews market rates and carrier availability to offer a highly competitive quote.',
  },
  {
    num: '3',
    title: 'Secure Delivery',
    desc: 'Your freight is assigned to a safety-vetted, insured open-deck carrier with continuous status tracking.',
  },
];
---

<BaseLayout
  title="Request a Quote"
  description="Get a competitive freight quote for flatbed, step deck, and open deck transportation."
>
  <!-- Page Header -->
  <section class="bg-navy pt-36 pb-20 relative overflow-hidden">
    <div class="mx-auto max-w-7xl px-5 lg:px-10 relative z-10">
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold uppercase text-white leading-none tracking-tight">
        Request a Freight Quote
      </h1>
      <p class="mt-4 max-w-2xl text-base md:text-lg text-white/60 font-body font-light leading-relaxed">
        Tell us about your open-deck shipment and we'll get back to you with a competitive rate within one business day.
      </p>
    </div>
  </section>

  <!-- Form + Sidebar -->
  <section class="bg-offwhite py-20 animate-fade-in" data-animate="fade-up">
    <div class="mx-auto max-w-7xl px-5 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Form Column -->
        <div class="lg:col-span-2">
          <div class="bg-white p-8 sm:p-12 border border-slate-200/40 rounded-sm shadow-sm relative">
            <!-- Top highlight line -->
            <div class="absolute top-0 left-0 right-0 h-1 bg-cyan rounded-t-sm"></div>

            <div class="mb-10">
              <h2 class="font-heading text-2xl font-bold uppercase text-ink">
                Shipment Details
              </h2>
              <p class="text-slate-600 text-xs mt-1.5 font-body">
                Please complete all required fields (*) to ensure an accurate routing quote.
              </p>
            </div>
            
            <QuoteForm />
          </div>
        </div>

        <!-- Sidebar Contact Info -->
        <aside class="lg:col-span-1 space-y-8">
          <!-- Urgent Support Card -->
          <div class="bg-navy p-8 border border-white/5 shadow-sm rounded-sm relative overflow-hidden">
            <div class="relative z-10">
              <h3 class="font-heading text-2xl font-bold uppercase text-white mb-6">
                Need it faster?
              </h3>
              <p class="text-slate-400 text-sm font-body mb-8 font-light leading-relaxed">
                For urgent or time-sensitive shipments, contact our dispatch coordinators directly for immediate capacity.
              </p>

              <!-- Phone -->
              <div class="flex items-center gap-4 mb-6 group">
                <div class="flex-shrink-0 flex items-center justify-center h-10 w-10 text-cyan">
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                </div>
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-widest text-white/45 mb-0.5 font-body">Phone Support</p>
                  <a href="tel:+12244464256" class="text-white hover:text-cyan transition-colors text-lg font-heading font-semibold uppercase tracking-wider">
                    +1 (224) 446-4256
                  </a>
                </div>
              </div>

              <!-- Email -->
              <div class="flex items-center gap-4 group">
                <div class="flex-shrink-0 flex items-center justify-center h-10 w-10 text-cyan">
                  <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                </div>
                <div>
                  <p class="text-[10px] font-bold uppercase tracking-widest text-white/45 mb-0.5 font-body">Email Dispatch</p>
                  <a href="mailto:wolfwaylogistics@gmail.com" class="text-white hover:text-cyan transition-colors text-sm font-body font-medium">
                    wolfwaylogistics@gmail.com
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Image Box -->
          <div class="relative overflow-hidden border border-slate-200/40 rounded-sm shadow-sm aspect-[16/10] bg-slate-200">
            <img
              src="/images/services/step-deck.jpg"
              alt="WolfWay step deck logistics trailer carrying commercial freight"
              class="object-cover w-full h-full"
              loading="lazy"
            />
          </div>

          <!-- Industries Served -->
          <div class="bg-white p-6 border border-slate-200/40 rounded-sm shadow-sm">
            <h3 class="font-heading text-lg font-bold uppercase text-ink mb-4 tracking-tight">
              Industries Served
            </h3>
            <ul class="space-y-3">
              {industries.map((ind) => (
                <li class="flex items-start gap-3 text-sm text-slate-600 font-body font-light">
                  <span class="h-1.5 w-1.5 bg-cyan rounded-full mt-1.5 shrink-0" aria-hidden="true"></span>
                  <span>{ind}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Booking Process Checklist -->
          <div class="bg-white p-6 border border-slate-200/40 rounded-sm shadow-sm">
            <h3 class="font-heading text-lg font-bold uppercase text-ink mb-4 tracking-tight">
              Our Process
            </h3>
            <div class="space-y-4">
              {steps.map((st) => (
                <div class="flex items-start gap-3.5">
                  <span class="flex-shrink-0 flex items-center justify-center h-6 w-6 rounded-full bg-slate-100 border border-slate-200 text-xs font-bold text-slate-700 font-heading">
                    {st.num}
                  </span>
                  <div>
                    <h4 class="font-heading text-xs font-bold uppercase text-ink tracking-wide">
                      {st.title}
                    </h4>
                    <p class="text-xs text-slate-500 font-body mt-0.5 leading-relaxed">
                      {st.desc}
                    </p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
