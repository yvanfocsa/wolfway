---
import BaseLayout from '@/layouts/BaseLayout.astro';
import QuoteForm from '@/components/QuoteForm.astro';

const industries = [
  'Construction & Heavy Machinery',
  'Steel, Pipe, & Industrial Metal',
  'Energy, Wind, & Oilfield Equipment',
  'Agricultural Machinery & Tractors',
  'Oversized & Permit-Required Loads',
];

const steps = [
  {
    num: '01',
    title: 'Submit Load Specs',
    desc: 'Provide pickup/drop-off details, cargo dimensions, weight, and trailer preferences.',
  },
  {
    num: '02',
    title: 'Fast Rate Review',
    desc: 'Our coordinators analyze market lanes and carrier dispatch options to secure the best rate.',
  },
  {
    num: '03',
    title: 'Dispatch & Track',
    desc: 'Freight is assigned to a vetted, insured driver, with active tracking from pickup to delivery.',
  },
];
---

<BaseLayout
  title="Request a Quote"
  description="Get a competitive freight quote for flatbed, step deck, and open deck transportation."
>
  <!-- Page Header -->
  <section class="bg-navy pt-36 pb-20 relative overflow-hidden">
    <div class="mx-auto max-w-7xl px-5 lg:px-10 relative z-10">
      <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-cyan mb-3">
        SHIP WITH WOLFWAY
      </p>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold uppercase text-white leading-none tracking-tight">
        Request a Freight Quote
      </h1>
      <p class="mt-4 max-w-2xl text-base md:text-lg text-white/60 font-body font-light leading-relaxed">
        Tell us about your open-deck shipment and we'll get back to you with a competitive rate within one business day.
      </p>
    </div>
  </section>

  <!-- Section 1: The Process (Spacious Step Grid) -->
  <section class="bg-white py-16 sm:py-20 border-b border-slate-100 select-none">
    <div class="mx-auto max-w-7xl px-5 lg:px-10">
      <div class="mb-12">
        <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-[#005F8A] mb-3">
          LOGISTICS FLOW
        </p>
        <h2 class="font-heading text-2xl sm:text-3xl font-bold uppercase text-ink">
          Our Booking Process
        </h2>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {steps.map((st) => (
          <div class="flex flex-col group">
            <span class="font-heading text-5xl font-extrabold text-slate-300 group-hover:text-cyan/30 transition-colors duration-300 leading-none mb-4">
              {st.num}
            </span>
            <h3 class="font-heading text-base font-bold uppercase text-ink mb-2">
              {st.title}
            </h3>
            <p class="text-sm leading-relaxed text-slate-600 font-body font-light">
              {st.desc}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 2: Capabilities & Industries (Split Layout) -->
  <section class="bg-[#F5F7FA] py-16 sm:py-20 border-b border-slate-100">
    <div class="mx-auto max-w-7xl px-5 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
        <!-- Image Box (Left) -->
        <div class="lg:col-span-6 relative overflow-hidden border border-slate-200/40 rounded-sm shadow-sm aspect-[16/10] bg-slate-200">
          <img
            src="/images/services/step-deck.jpg"
            alt="WolfWay step deck logistics trailer carrying commercial freight"
            class="object-cover w-full h-full"
            loading="lazy"
          />
        </div>

        <!-- Industries Served List (Right) -->
        <div class="lg:col-span-6 space-y-6">
          <div>
            <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-[#005F8A] mb-3">
              WHAT WE HAUL
            </p>
            <h2 class="font-heading text-2xl sm:text-3xl font-bold uppercase text-ink">
              Industries Served
            </h2>
            <p class="text-sm text-slate-600 font-body font-light mt-2 leading-relaxed">
              We coordinate transport across multiple open-deck configurations, providing expert loading and securement for:
            </p>
          </div>

          <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
            {industries.map((ind) => (
              <li class="flex items-start gap-3 text-sm text-slate-600 font-body font-light">
                <svg class="h-5 w-5 text-cyan shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span>{ind}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: The Form (Centered, Spacious Container) -->
  <section class="bg-white py-20 sm:py-24">
    <div class="mx-auto max-w-3xl px-5 lg:px-0 relative">
      <!-- Top highlight line -->
      <div class="absolute top-0 left-5 right-5 h-[2px] bg-cyan/30"></div>

      <div class="text-center mb-12 pt-8">
        <h2 class="font-heading text-3xl font-bold uppercase text-ink">
          Shipment Details
        </h2>
        <p class="text-slate-600 text-sm mt-2 font-body font-light max-w-lg mx-auto">
          Please fill out the form below. For urgent assistance or dispatch coordination, call us directly at <a href="tel:+12244464256" class="text-cyan font-bold hover:underline">+1 (224) 446-4256</a>.
        </p>
      </div>

      <div class="border border-slate-200/60 p-8 sm:p-12 rounded-sm shadow-sm bg-slate-50/10">
        <QuoteForm />
      </div>
    </div>
  </section>
</BaseLayout>
