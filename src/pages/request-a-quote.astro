---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import QuoteForm from '@/components/QuoteForm.astro';
import { serviceImages } from '@/content/images';
---

<BaseLayout
  title="Request a Quote"
  description="Get a competitive freight quote for flatbed, step deck, and open deck transportation."
>
  <PageHero
    title="Request a Freight Quote"
    description="Share the route, cargo, and timing. Our team will review the details and respond with the right open-deck plan within one business day."
    image={serviceImages.openDeck}
    imageAlt="Open-deck trucks staged with secured freight in an industrial yard"
  />

  <!-- Main Quote Section -->
  <section class="bg-offwhite py-16 sm:py-24 flex-1">
    <div class="mx-auto max-w-7xl px-5 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        
        <!-- Left: Form Container -->
        <div class="form-panel p-6 sm:p-10 lg:col-span-8">
          <div class="mb-8 border-b border-slate-100 pb-6">
            <h2 class="font-heading text-2xl font-bold uppercase text-ink">
              Shipment Specifications
            </h2>
            <p class="mt-2 text-base leading-relaxed text-slate-600 font-body">
              Provide pickup/drop-off locations and cargo details for an accurate rate quote.
            </p>
          </div>
          <QuoteForm />
        </div>

        <!-- Right: Direct Support Sidebar -->
        <div class="lg:col-span-4 space-y-6">
          <div class="p-6 bg-navy text-white rounded-lg space-y-4">
            <h3 class="font-heading text-xl font-bold uppercase text-white">Need Immediate Dispatch?</h3>
            <p class="mobile-readable text-base text-white/75 font-body font-light leading-relaxed">
              Have a time-critical shipment or specialized permit requirements? Speak directly with our coordination desk.
            </p>
            <div class="pt-2">
              <a href="tel:+12244464256" class="inline-flex min-h-11 items-center gap-2 text-base font-bold text-cyan hover:underline font-body">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                +1 (224) 446-4256
              </a>
            </div>
          </div>

          <div class="premium-card p-6 rounded-lg space-y-3">
            <h4 class="font-heading text-lg font-bold uppercase text-ink">WolfWay Guarantee</h4>
            <ul class="relative z-10 space-y-2.5 text-base text-slate-600 font-body">
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-cyan"></span>
                <span>$250,000 Cargo Insurance Standard</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-cyan"></span>
                <span>Dedicated Single Point of Contact</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-cyan"></span>
                <span>100% FMCSA Compliant Fleet</span>
              </li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
