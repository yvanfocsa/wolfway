---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTASection from '@/components/CTASection.astro';
import Button from '@/components/Button.astro';
import EquipmentFitHelper from '@/components/EquipmentFitHelper.astro';
import FAQ from '@/components/FAQ.astro';
import { services } from '@/content/services';

const faqItems = [
  {
    question: "What details do I need to request a freight quote?",
    answer: "You will need to provide the pickup and delivery locations, cargo weight, dimensions (length, width, height), commodity description, preferred pickup date, and requested trailer configuration."
  },
  {
    question: "What open-deck equipment does WolfWay Logistics offer?",
    answer: "We coordinate transport across standard flatbeds, step decks, double drop trailers, and open-deck logistics configurations equipped with chains, straps, binders, and proper tarps."
  },
  {
    question: "How do I apply as a carrier partner?",
    answer: "You can submit an application via our Carrier page. Requirements include active authority for 6 months, a satisfactory FMCSA safety rating, and minimum liability/cargo insurance coverages."
  },
  {
    question: "Can owner operators apply?",
    answer: "Yes, we welcome applications from both fleet operators and independent owner operators with Class A CDL credentials and open-deck securement experience."
  },
  {
    question: "What happens after I submit an application?",
    answer: "Our team reviews submitted credentials. Valid carrier relations applications are reviewed within 2 hours, and driver applications are typically followed up within 24 hours."
  }
];
---

<BaseLayout
  title="Services"
  description="Flatbed freight, step deck transport, and open deck logistics services. Reliable open-deck transportation across the United States."
>
  <!-- Page Header -->
  <section class="bg-navy pt-36 pb-16">
    <div class="mx-auto max-w-7xl px-5 lg:px-10">
      <p class="font-heading text-xs font-semibold uppercase tracking-[0.25em] text-cyan mb-3">
        LOGISTICS DECK
      </p>
      <h1 class="font-heading text-4xl md:text-5xl font-bold uppercase text-white max-w-3xl">
        Open-Deck Transportation Services
      </h1>
      <p class="mt-4 max-w-2xl text-base leading-relaxed text-white/60 font-body font-light">
        WolfWay Logistics coordinates specialized flatbed, step deck, and open-deck transport. From standard cargo lanes to oversized permits, our team matches the right trailer configurations for secure, safe delivery.
      </p>
    </div>
  </section>

  <!-- Service Detail Sections -->
  {services.map((service, index) => {
    const isOdd = index % 2 === 0;
    return (
      <section
        id={service.slug}
        class="py-16 sm:py-20 bg-offwhite border-b border-slate-100/50"
        data-animate="fade-up"
      >
        <div
          class:list={[
            'mx-auto max-w-7xl px-5 lg:px-10 grid gap-10 lg:gap-16 items-center',
            'grid-cols-1 lg:grid-cols-2',
          ]}
        >
          {/* Image */}
          <div
            class:list={[
              'aspect-[16/10] overflow-hidden rounded-sm border border-slate-200/40 bg-slate-100 shadow-sm relative group',
              !isOdd && 'lg:order-2',
            ]}
          >
            <img
              src={service.imagePath}
              alt={service.imageAlt}
              loading="lazy"
              class="h-full w-full object-cover transition-transform duration-500 hover:scale-[1.02]"
            />
          </div>

          {/* Content */}
          <div class:list={[!isOdd && 'lg:order-1']}>
            <p class="font-heading text-xs font-bold uppercase tracking-[0.25em] text-[#005F8A] mb-3">
              SERVICE CONFIGURATION
            </p>
            <h2 class="font-heading text-3xl font-bold uppercase text-ink">
              {service.title}
            </h2>
            <p class="mt-4 text-sm leading-relaxed text-slate-600 font-body font-light">
              {service.longDescription}
            </p>

            {/* Features list */}
            <ul class="mt-6 space-y-3">
              {service.features.map((feature) => (
                <li class="flex items-start gap-3">
                  <svg
                    class="mt-0.5 h-5 w-5 shrink-0 text-cyan"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span class="text-slate-600 text-sm leading-relaxed font-body font-light">{feature}</span>
                </li>
              ))}
            </ul>

            <div class="mt-8">
              <Button
                variant="primary"
                href="/request-a-quote"
                arrow={true}
                class="group"
              >
                Request a Quote for {service.shortTitle}
              </Button>
            </div>
          </div>
        </div>
      </section>
    );
  })}

  <!-- Equipment Fit Helper Section -->
  <section class="bg-offwhite py-16 border-b border-slate-100" data-animate="fade-up">
    <div class="mx-auto max-w-3xl px-5 lg:px-0">
      <EquipmentFitHelper />
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="bg-white py-20 border-b border-slate-100" data-animate="fade-up">
    <div class="mx-auto max-w-7xl px-5 lg:px-10">
      <FAQ items={faqItems} title="Services FAQ" eyebrow="EQUIPMENT & CAPABILITIES" />
    </div>
  </section>

  <!-- Bottom CTA -->
  <CTASection
    variant="dark"
    heading="Need a Custom Solution?"
    description="Every load is different. Whether you need specialized equipment, permit coordination, or dedicated carrier lanes, our team will coordinate a secure open-deck transportation plan."
    buttonText="Contact Us"
    buttonHref="/contact"
  />
</BaseLayout>
